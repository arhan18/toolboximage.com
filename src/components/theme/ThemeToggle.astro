---
interface Props {
  class?: string;
  size?: 'sm' | 'md';
  /** Accessible label override. Defaults to "Toggle theme". */
  ariaLabel?: string;
}

const { class: className = '', size = 'md', ariaLabel = 'Toggle theme' } = Astro.props;
---

<button
  type="button"
  id="theme-toggle"
  class={`theme-toggle ${className}`}
  aria-label={ariaLabel}
  title={ariaLabel}
  data-size={size}
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-full);
    background: var(--color-canvas);
    color: var(--color-ink);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart);
  }

  .theme-toggle[data-size="sm"] {
    width: 28px;
    height: 28px;
  }

  .theme-toggle[data-size="md"] {
    width: 36px;
    height: 36px;
  }

  .theme-toggle:hover {
    background-color: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }

  .theme-toggle:active {
    transform: scale(0.94);
  }

  .theme-toggle:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  /* Icons sit on top of each other for a real crossfade. */
  .theme-icon-sun,
  .theme-icon-moon {
    position: absolute;
    inset: 0;
    margin: auto;
    transition:
      transform var(--dur-slow) var(--ease-spring),
      opacity var(--dur-base) var(--ease-out-quart);
  }

  /* Show/hide icons based on theme via opacity (not display:none) for smooth crossfade. */
  [data-theme="light"] .theme-icon-sun { opacity: 0; transform: rotate(0deg) scale(0.6); pointer-events: none; }
  [data-theme="dark"] .theme-icon-moon { opacity: 0; transform: rotate(0deg) scale(0.6); pointer-events: none; }
  [data-theme="light"] .theme-icon-moon { opacity: 1; transform: rotate(0deg) scale(1); }
  [data-theme="dark"] .theme-icon-sun { opacity: 1; transform: rotate(0deg) scale(1); }

  .theme-toggle:hover .theme-icon-sun { transform: rotate(15deg) scale(1.1); }
  .theme-toggle:hover .theme-icon-moon { transform: rotate(15deg) scale(1.1); }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle,
    .theme-icon-sun,
    .theme-icon-moon { transition: none; }
  }
</style>

<script>
  import { getStoredTheme, setStoredTheme, applyTheme, nextTheme } from '../../lib/theme';

  // Bind toggle buttons (id is shared across pages)
  document.querySelectorAll<HTMLButtonElement>('#theme-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = nextTheme(getStoredTheme() ?? 'system');
      setStoredTheme(next);
      applyTheme(next);
    });
  });
</script>
</content>
</invoke>