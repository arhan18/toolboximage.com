---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<button
  type="button"
  id="theme-toggle"
  class={`theme-slider ${className}`}
  aria-label="Switch to dark mode"
  title="Toggle theme"
>
  <span class="theme-slider-track">
    <svg class="theme-slider-track-icon theme-slider-track-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="5"></circle>
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
    <span class="theme-slider-knob"></span>
    <svg class="theme-slider-track-icon theme-slider-track-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </span>
  <span class="theme-slider-labels">
    <span class="theme-slider-label theme-slider-label-light">Light</span>
    <span class="theme-slider-label theme-slider-label-dark">Dark</span>
  </span>
</button>

<style>
  .theme-slider {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 0;
    font: inherit;
    color: var(--color-body);
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .theme-slider:focus-visible {
    outline: none;
  }

  .theme-slider:focus-visible .theme-slider-track {
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-link) 40%, transparent);
  }

  .theme-slider-track {
    position: relative;
    width: 52px;
    height: 26px;
    border-radius: var(--radius-full);
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 6px;
    transition:
      background-color 400ms cubic-bezier(0.4, 0, 0.2, 1),
      border-color 300ms var(--ease-out-quart);
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .theme-slider:hover .theme-slider-track {
    border-color: var(--color-hairline-strong);
  }

  .theme-slider-track-icon {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    transition: color 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .theme-slider-knob {
    position: absolute;
    top: 3px;
    width: 18px;
    height: 18px;
    border-radius: var(--radius-full);
    background-color: var(--color-canvas);
    box-shadow:
      0 1px 2px rgb(0 0 0 / 0.12),
      0 1px 4px rgb(0 0 0 / 0.08);
    will-change: transform;
    transition: transform 500ms cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 3;
    pointer-events: none;
  }

  .theme-slider-labels {
    display: none;
    gap: 2px;
    font-size: 11px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  @media (min-width: 768px) {
    .theme-slider-labels {
      display: inline-flex;
    }
  }

  .theme-slider-label {
    transition: color 350ms cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--color-mute);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-slider-track,
    .theme-slider-knob,
    .theme-slider-track-icon,
    .theme-slider-label { transition: none; }
  }
</style>

<style is:global>
  [data-theme="dark"] .theme-slider-track {
    background-color: #252525;
    border-color: var(--color-hairline-strong);
  }

  [data-theme="light"] .theme-slider-track-sun {
    color: var(--color-warning);
  }

  [data-theme="dark"] .theme-slider-track-moon {
    color: #a1a1aa;
  }

  [data-theme="light"] .theme-slider-knob {
    transform: translateX(0);
  }

  [data-theme="dark"] .theme-slider-knob {
    transform: translateX(24px);
  }

  :root:not([data-theme="light"]):not([data-theme="dark"]) .theme-slider-knob {
    transform: translateX(12px);
  }

  [data-theme="light"] .theme-slider-label-light {
    color: var(--color-ink);
  }

  [data-theme="dark"] .theme-slider-label-dark {
    color: var(--color-ink);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-theme="light"] .theme-slider-knob,
    [data-theme="dark"] .theme-slider-knob,
    :root:not([data-theme="light"]):not([data-theme="dark"]) .theme-slider-knob {
      transition: none;
    }
  }
</style>

<script>
  import { getStoredTheme, setStoredTheme, applyTheme, nextTheme } from '../../lib/theme';

  const btn = document.getElementById('theme-toggle') as HTMLButtonElement | null;
  if (btn) {
    const labelMap: Record<string, string> = {
      light: 'Switch to dark mode',
      dark: 'Switch to system theme',
      system: 'Switch to light mode',
    };

    const updateLabel = () => {
      const current = getStoredTheme() ?? 'system';
      btn.setAttribute('aria-label', labelMap[current] ?? 'Toggle theme');
    };

    btn.addEventListener('click', () => {
      const next = nextTheme(getStoredTheme() ?? 'system');
      setStoredTheme(next);
      applyTheme(next);
      updateLabel();
    });

    const mq = window.matchMedia('(prefers-color-scheme: dark)');
    mq.addEventListener('change', () => {
      if ((getStoredTheme() ?? 'system') === 'system') {
        applyTheme('system');
      }
    });

    updateLabel();
  }
</script>
