---
/**
 * AppShell — wraps a page with Navbar + Footer + main slot.
 * Use inside <Layout> on every page that should have the full chrome.
 */
import Navbar from '../nav/Navbar.astro';
import Footer from '../base/Footer.astro';

interface Props {
  /** Hide the navbar for full-screen tool UIs. */
  hideNavbar?: boolean;
  /** Hide the footer for tool pages. */
  hideFooter?: boolean;
  /** Class applied to <main> for page-level layout overrides. */
  mainClass?: string;
}

const {
  hideNavbar = false,
  hideFooter = false,
  mainClass = '',
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

{!hideNavbar && <Navbar currentPath={currentPath} />}

<main class:list={['app-main', mainClass]}>
  <slot />
</main>

{!hideFooter && <Footer />}

<style>
  .app-main {
    display: block;
    min-height: calc(100vh - 64px);
  }
</style>