---
import Navbar from '../nav/Navbar.astro';
import Footer from '../base/Footer.astro';
import { currentLangFromPath, type LangCode } from '../../i18n';

interface Props {
  hideNavbar?: boolean;
  hideFooter?: boolean;
  mainClass?: string;
  mainId?: string;
}

const {
  hideNavbar = false,
  hideFooter = false,
  mainClass = '',
  mainId = 'main',
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang: LangCode = currentLangFromPath(Astro.url.pathname);
---

{!hideNavbar && <Navbar currentPath={currentPath} lang={lang} />}

<main id={mainId} tabindex="-1" class:list={['app-main', mainClass]}>
  <slot />
</main>

{!hideFooter && <Footer lang={lang} />}

<style>
  .app-main {
    display: block;
    min-height: calc(100vh - 64px);
    scroll-margin-top: 80px;
  }

  .app-main:focus-visible {
    outline: none;
  }
</style>
