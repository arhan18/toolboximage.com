---
/**
 * Card — the canonical marketing card chrome (DESIGN.md `card-marketing`).
 * Surface: canvas, padding: lg, radius: md, Level 3 soft-stack shadow.
 */
interface Props {
  href?: string;
  /** Visual elevation — see DESIGN.md §Elevation. Defaults to 3. */
  elevation?: 1 | 2 | 3 | 4 | 5;
  /** Surface tone. `default` = canvas, `soft` = canvas-soft. */
  tone?: 'default' | 'soft';
  /** Optional hover lift behaviour. Default true. */
  interactive?: boolean;
  class?: string;
}

const {
  href,
  elevation = 3,
  tone = 'default',
  interactive = true,
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'article';
const classes = [
  'card',
  `card-elev-${elevation}`,
  `card-tone-${tone}`,
  href ? 'card-linked' : '',
  interactive ? 'card-interactive' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag class={classes} href={href}>
  <slot />
</Tag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    text-decoration: none;
    transition:
      box-shadow var(--dur-base) var(--ease-out-quart),
      transform var(--dur-base) var(--ease-out-quart),
      border-color var(--dur-base) var(--ease-out-quart),
      background-color var(--dur-base) var(--ease-out-quart);
    position: relative;
    isolation: isolate;
  }

  .card-tone-default {
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
  }

  .card-tone-soft {
    background-color: var(--color-canvas-soft);
    border: 1px solid transparent;
  }

  /* Elevation levels — DESIGN.md §Elevation */
  .card-elev-1 { box-shadow: var(--shadow-1); }
  .card-elev-2 { box-shadow: var(--shadow-2); }
  .card-elev-3 { box-shadow: var(--shadow-3); }
  .card-elev-4 { box-shadow: var(--shadow-4); }
  .card-elev-5 { box-shadow: var(--shadow-5); }

  /* Hairline that sits *over* the shadow so elevation feels like a card. */
  .card-tone-default.card-elev-1,
  .card-tone-default.card-elev-2,
  .card-tone-default.card-elev-3,
  .card-tone-default.card-elev-4,
  .card-tone-default.card-elev-5 {
    border-color: var(--color-hairline);
  }

  /* Hover lift for non-link cards (e.g. "About" principles) */
  .card-interactive:not(.card-linked):hover {
    box-shadow: var(--shadow-4);
    transform: translateY(-2px);
    border-color: var(--color-hairline-strong);
  }

  /* Linked cards */
  .card-linked {
    cursor: pointer;
  }

  .card-linked::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      transparent 0%,
      color-mix(in srgb, var(--color-link) 0%, transparent) 100%
    );
    transition: background var(--dur-slow) var(--ease-out-quart);
    z-index: 0;
  }

  /* Ensure children sit above the gradient overlay. */
  .card > :global(*) {
    position: relative;
    z-index: 1;
  }

  .card-linked:hover,
  .card-interactive:not(.card-linked):hover {
    box-shadow: var(--shadow-4);
    transform: translateY(-2px);
    border-color: var(--color-hairline-strong);
  }

  .card-linked:hover::after {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-link) 6%, transparent) 0%,
      transparent 60%
    );
  }

  .card-linked:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-color: var(--color-link);
  }

  .card:active:not(:disabled):not([aria-disabled="true"]) {
    transform: translateY(0);
  }

  /* Subtle press effect on click. */
  .card:active {
    transform: scale(0.995);
  }

  @media (prefers-reduced-motion: reduce) {
    .card, .card-linked::after { transition: none; }
  }
</style>
</content>
</invoke>