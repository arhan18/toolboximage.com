---
/**
 * Badge — small inline metadata pill (DESIGN.md `badge-secondary`).
 * Optional `tone` for semantic variants. Always `radius-full`.
 */
interface Props {
  /** Visual variant. */
  tone?: 'neutral' | 'info' | 'success' | 'warning' | 'error';
  /** Optional mono label rendered before content (e.g. `v1.0`, `New`). */
  eyebrow?: string;
  class?: string;
}

const { tone = 'neutral', eyebrow, class: className = '' } = Astro.props;
---

<span class:list={['badge', `badge-${tone}`, className]}>
  {eyebrow && <span class="text-caption-mono badge-eyebrow">{eyebrow}</span>}
  <span class="text-caption badge-text"><slot /></span>
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 0 var(--space-xs);
    height: 22px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-hairline);
    background-color: var(--color-canvas-soft);
    color: var(--color-body);
    white-space: nowrap;
  }

  .badge-eyebrow {
    color: var(--color-mute);
  }

  .badge-info {
    background-color: var(--color-link-bg-soft);
    border-color: transparent;
    color: var(--color-link-deep);
  }

  [data-theme="dark"] .badge-info {
    color: var(--color-link);
  }

  .badge-success {
    background-color: var(--color-cyan-soft);
    border-color: transparent;
    color: var(--color-cyan-deep);
  }

  .badge-warning {
    background-color: var(--color-warning-soft);
    border-color: transparent;
    color: var(--color-warning-deep);
  }

  .badge-error {
    background-color: var(--color-error-soft);
    border-color: transparent;
    color: var(--color-error-deep);
  }
</style>