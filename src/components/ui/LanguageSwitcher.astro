---
/**
 * LanguageSwitcher — dropdown for selecting site language.
 * Currently English-only; more languages coming soon.
 */
interface Props {
  variant?: 'nav' | 'footer';
  class?: string;
}

const { variant = 'nav', class: className = '' } = Astro.props;

const languages = [
  { code: 'en', label: 'English', active: true },
  { code: 'es', label: 'Español', active: false },
  { code: 'fr', label: 'Français', active: false },
  { code: 'de', label: 'Deutsch', active: false },
  { code: 'pt', label: 'Português', active: false },
  { code: 'hi', label: 'हिन्दी', active: false },
];
---

<div class:list={['lang-switcher', `lang-${variant}`, className]}>
  <button
    type="button"
    class="lang-trigger"
    aria-expanded="false"
    aria-label="Select language"
    data-lang-trigger
  >
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <line x1="2" y1="12" x2="22" y2="12"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
    <span class="lang-code">EN</span>
    <svg class="lang-arrow" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </button>
  <div class="lang-dropdown" data-lang-dropdown hidden>
    <div class="lang-list">
      {languages.map((lang) => (
        <span
          class:list={['lang-item', lang.active && 'lang-item-active']}
          aria-current={lang.active ? 'true' : undefined}
        >
          <span class="lang-item-code">{lang.code.toUpperCase()}</span>
          <span class="lang-item-label">{lang.label}</span>
          {lang.active && <span class="lang-item-check">✓</span>}
          {!lang.active && <span class="lang-item-coming text-caption">Soon</span>}
        </span>
      ))}
    </div>
  </div>
</div>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>('[data-lang-trigger]');
  triggers.forEach((trigger) => {
    const dropdown = trigger.parentElement?.querySelector<HTMLElement>('[data-lang-dropdown]');
    if (!dropdown) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!open));
      dropdown.hidden = open;
    });

    document.addEventListener('click', (e) => {
      if (!trigger.parentElement?.contains(e.target as Node)) {
        trigger.setAttribute('aria-expanded', 'false');
        dropdown.hidden = true;
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && trigger.getAttribute('aria-expanded') === 'true') {
        trigger.setAttribute('aria-expanded', 'false');
        dropdown.hidden = true;
        trigger.focus();
      }
    });
  });
</script>

<style>
  .lang-switcher {
    position: relative;
  }

  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xxs);
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-full);
    background-color: var(--color-canvas);
    color: var(--color-body);
    font: inherit;
    font-size: var(--font-size-xs);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart);
  }

  .lang-trigger:hover {
    border-color: var(--color-hairline-strong);
    color: var(--color-ink);
  }

  .lang-trigger:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  .lang-code {
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
  }

  .lang-arrow {
    transition: transform var(--dur-base) var(--ease-out-quart);
  }

  .lang-trigger[aria-expanded="true"] .lang-arrow {
    transform: rotate(180deg);
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    min-width: 180px;
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-3);
    z-index: 110;
    overflow: hidden;
  }

  .lang-list {
    display: flex;
    flex-direction: column;
    padding: var(--space-xs);
  }

  .lang-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    cursor: default;
    transition: background-color var(--dur-fast) var(--ease-out-quart);
  }

  .lang-item:hover {
    background-color: var(--color-canvas-soft);
  }

  .lang-item-active {
    color: var(--color-ink);
    font-weight: var(--weight-medium);
  }

  .lang-item:not(.lang-item-active) {
    color: var(--color-mute);
  }

  .lang-item-code {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 20px;
    border-radius: var(--radius-xs);
    background-color: var(--color-canvas-soft);
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
    color: var(--color-body);
  }

  .lang-item-active .lang-item-code {
    background-color: var(--color-link-bg-soft);
    color: var(--color-link-deep);
  }

  [data-theme="dark"] .lang-item-active .lang-item-code {
    color: var(--color-link);
  }

  .lang-item-label {
    flex: 1;
    font-size: var(--font-size-sm);
  }

  .lang-item-check {
    font-size: 12px;
    color: var(--color-link-deep);
  }

  [data-theme="dark"] .lang-item-check {
    color: var(--color-link);
  }

  .lang-item-coming {
    font-size: 10px;
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Footer variant */
  .lang-footer .lang-trigger {
    border-color: transparent;
    background-color: transparent;
    padding: var(--space-xxs) var(--space-xs);
  }

  .lang-footer .lang-trigger:hover {
    border-color: var(--color-hairline);
  }

  .lang-footer .lang-dropdown {
    right: auto;
    left: 0;
  }
</style>
