---
/**
 * Button — DESIGN.md `button-primary` / `button-secondary`.
 * Pill-shaped at marketing scale (lg), `--radius-sm` at nav scale (sm).
 */
interface Props {
  label?: string;
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  /** Accessible label override (when the visible label is non-descriptive). */
  ariaLabel?: string;
  class?: string;
}

const {
  label,
  href,
  variant = 'primary',
  size = 'lg',
  type = 'button',
  disabled = false,
  ariaLabel,
  class: className = '',
} = Astro.props;

const classes = ['btn', `btn-${variant}`, `btn-${size}`, className]
  .filter(Boolean)
  .join(' ');

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes} aria-label={ariaLabel} aria-disabled={disabled}>
    {label && <span class="btn-label">{label}</span>}
    <slot />
  </a>
) : (
  <button
    type={type}
    class={classes}
    disabled={disabled}
    aria-label={ariaLabel}
  >
    {label && <span class="btn-label">{label}</span>}
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    border: none;
    cursor: pointer;
    transition:
      background-color 0.15s ease,
      color 0.15s ease,
      opacity 0.15s ease,
      transform 0.1s ease,
      box-shadow 0.15s ease;
    text-decoration: none;
    white-space: nowrap;
    font-family: var(--font-sans);
    user-select: none;
  }

  .btn:active:not(:disabled):not([aria-disabled="true"]) {
    transform: scale(0.98);
  }

  .btn:disabled,
  .btn[aria-disabled="true"] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 3px;
  }

  /* Sizes — see DESIGN.md `button-*` */
  .btn-lg {
    padding: 0 var(--space-sm);
    height: 48px;
    font-size: var(--text-button-lg);
    font-weight: var(--weight-medium);
    line-height: var(--leading-body-md);
    border-radius: var(--radius-pill);
  }

  .btn-md {
    padding: 0 var(--space-sm);
    height: 40px;
    font-size: var(--text-button-md);
    font-weight: var(--weight-medium);
    line-height: var(--leading-body-sm);
    border-radius: var(--radius-pill);
  }

  .btn-sm {
    padding: 0 var(--space-xs);
    height: 28px;
    font-size: var(--text-button-md);
    font-weight: var(--weight-medium);
    line-height: var(--leading-body-sm);
    border-radius: var(--radius-sm);
  }

  /* Variants */
  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    box-shadow:
      0 1px 1px rgb(0 0 0 / 0.04),
      inset 0 1px 0 rgb(255 255 255 / 0.08);
    position: relative;
  }

  .btn-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: 0 0 0 0 transparent;
    transition: box-shadow 0.2s ease;
  }

  .btn-primary:hover:not(:disabled):not([aria-disabled="true"]) {
    background-color: var(--color-primary);
    transform: translateY(-1px);
    box-shadow:
      0 1px 1px rgb(0 0 0 / 0.04),
      0 6px 16px -6px rgb(0 0 0 / 0.28),
      inset 0 1px 0 rgb(255 255 255 / 0.1);
  }

  .btn-primary:hover:not(:disabled):not([aria-disabled="true"])::after {
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-on-primary) 12%, transparent);
  }

  .btn-secondary {
    background-color: var(--color-canvas);
    color: var(--color-ink);
    box-shadow:
      inset 0 0 0 1px var(--color-hairline),
      0 1px 1px rgb(0 0 0 / 0.02);
    position: relative;
  }

  .btn-secondary:hover:not(:disabled):not([aria-disabled="true"]) {
    background-color: var(--color-canvas);
    transform: translateY(-1px);
    box-shadow:
      inset 0 0 0 1px var(--color-hairline-strong),
      0 6px 16px -8px rgb(0 0 0 / 0.18),
      0 1px 2px rgb(0 0 0 / 0.04);
  }

  .btn-ghost {
    background-color: transparent;
    color: var(--color-ink);
  }

  .btn-ghost:hover:not(:disabled):not([aria-disabled="true"]) {
    background-color: var(--color-canvas-soft);
    transform: translateY(-1px);
  }

  .btn-label {
    display: inline-block;
  }

  .btn :global(svg) {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .btn-lg :global(svg) {
    width: 18px;
    height: 18px;
  }
</style>