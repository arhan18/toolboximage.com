---
/**
 * Button — DESIGN.md `button-primary` / `button-secondary`.
 * Pill-shaped at marketing scale (lg), `--radius-sm` at nav scale (sm).
 */
interface Props {
  label?: string;
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  /** Accessible label override (when the visible label is non-descriptive). */
  ariaLabel?: string;
  class?: string;
}

const {
  label,
  href,
  variant = 'primary',
  size = 'lg',
  type = 'button',
  disabled = false,
  ariaLabel,
  class: className = '',
} = Astro.props;

const classes = ['btn', `btn-${variant}`, `btn-${size}`, className]
  .filter(Boolean)
  .join(' ');

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes} aria-label={ariaLabel} aria-disabled={disabled}>
    {label && <span class="btn-label">{label}</span>}
    <slot />
  </a>
) : (
  <button
    type={type}
    class={classes}
    disabled={disabled}
    aria-label={ariaLabel}
  >
    {label && <span class="btn-label">{label}</span>}
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    border: 1px solid transparent;
    cursor: pointer;
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart),
      opacity var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart),
      box-shadow var(--dur-fast) var(--ease-out-quart);
    text-decoration: none;
    white-space: nowrap;
    font-family: var(--font-sans);
    user-select: none;
    will-change: transform;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .btn:active:not(:disabled):not([aria-disabled="true"]) {
    transform: scale(0.985);
  }

  .btn:disabled,
  .btn[aria-disabled="true"] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  /* Sizes — see DESIGN.md `button-*` */
  .btn-lg {
    padding: 0 var(--space-md);
    height: 48px;
    font-size: var(--text-button-lg);
    font-weight: var(--weight-medium);
    line-height: var(--leading-body-md);
    border-radius: var(--radius-pill);
    gap: var(--space-sm);
  }

  .btn-md {
    padding: 0 var(--space-sm);
    height: 40px;
    font-size: var(--text-button-md);
    font-weight: var(--weight-medium);
    line-height: var(--leading-body-sm);
    border-radius: var(--radius-pill);
  }

  .btn-sm {
    padding: 0 var(--space-sm);
    min-height: 44px;
    font-size: var(--text-button-md);
    font-weight: var(--weight-medium);
    line-height: var(--leading-body-sm);
    border-radius: var(--radius-sm);
  }

  /* Variants */
  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    box-shadow: var(--shadow-1);
    position: relative;
    border-color: transparent;
  }

  .btn-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: 0 0 0 0 transparent;
    transition: box-shadow var(--dur-base) var(--ease-out-quart);
  }

  .btn-primary:hover:not(:disabled):not([aria-disabled="true"]) {
    background-color: var(--color-primary);
    transform: translateY(-1px);
    box-shadow: var(--shadow-3);
  }

  .btn-primary:hover:not(:disabled):not([aria-disabled="true"])::after {
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-on-primary) 12%, transparent);
  }

  .btn-secondary {
    background-color: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-1);
    border-color: transparent;
    position: relative;
  }

  .btn-secondary:hover:not(:disabled):not([aria-disabled="true"]) {
    background-color: var(--color-canvas);
    color: var(--color-ink);
    transform: translateY(-1px);
    box-shadow: var(--shadow-3);
  }

  .btn-ghost {
    background-color: transparent;
    color: var(--color-body);
    border-color: transparent;
  }

  .btn-ghost:hover:not(:disabled):not([aria-disabled="true"]) {
    background-color: var(--color-canvas-soft);
    color: var(--color-ink);
    border-color: var(--color-hairline);
    transform: translateY(-1px);
  }

  .btn-label {
    display: inline-block;
  }

  .btn :global(svg) {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform var(--dur-fast) var(--ease-out-quart);
  }

  .btn-lg :global(svg) {
    width: 18px;
    height: 18px;
  }

  /* On dark polarity-flipped surfaces (CTA bands), the secondary reads better
     with the canvas tone so it lifts off the dark ground. */
  .btn-on-dark.btn-secondary {
    background-color: color-mix(in srgb, var(--color-on-primary) 12%, transparent);
    color: var(--color-on-primary);
    box-shadow: var(--shadow-1), inset 0 0 0 1px color-mix(in srgb, var(--color-on-primary) 22%, transparent);
  }

  .btn-on-dark.btn-secondary:hover:not(:disabled):not([aria-disabled="true"]) {
    background-color: color-mix(in srgb, var(--color-on-primary) 18%, transparent);
    box-shadow: var(--shadow-3), inset 0 0 0 1px color-mix(in srgb, var(--color-on-primary) 36%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .btn { transition: none; }
  }
</style>
</content>
</invoke>