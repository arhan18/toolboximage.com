---
import Logo from '../brand/Logo.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const columns = [
  {
    label: 'Tools',
    links: [
      { href: '/compressor/', label: 'Compressor' },
      { href: '/blog/compression-basics/', label: 'How compression works' },
    ],
  },
  {
    label: 'Resources',
    links: [
      { href: '/blog/', label: 'Blog' },
      { href: '/faq/', label: 'FAQ' },
    ],
  },
  {
    label: 'Company',
    links: [
      { href: '/about/', label: 'About' },
      { href: '/contact/', label: 'Contact' },
      { href: '/legal/privacy/', label: 'Privacy' },
      { href: '/legal/terms/', label: 'Terms' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class:list={['site-footer', className]}>
  <div class="footer-inner container">
    <div class="footer-brand">
      <Logo size={20} />
      <p class="text-caption footer-tagline">
        Fast, private image tools that run entirely in your browser.
        No uploads. No tracking. No compromises.
      </p>
    </div>

    <div class="footer-columns">
      {columns.map((col) => (
        <div class="footer-column">
          <h4 class="text-caption-mono footer-column-label">{col.label}</h4>
          <ul class="footer-links">
            {col.links.map((l) => (
              <li><a href={l.href} class="text-body-sm footer-link" data-astro-prefetch="hover">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="footer-bottom container">
    <p class="text-caption footer-copy">
      &copy; {year} ToolBox Image. All rights reserved.
    </p>
    <p class="text-caption footer-status">
      <span class="footer-status-dot" aria-hidden="true"></span>
      All systems operational
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding: var(--space-4xl) 0 var(--space-xl);
    margin-top: var(--space-5xl);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3xl);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 320px;
  }

  .footer-tagline {
    color: var(--color-mute);
    margin: 0;
    line-height: 1.5;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3xl);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-column-label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-mute);
    margin: 0;
    font-weight: var(--weight-medium);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-link {
    color: var(--color-body);
    text-decoration: none;
    display: inline-block;
    padding: 2px 0;
    border-radius: var(--radius-xs);
    transition:
      color var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart);
    position: relative;
  }

  .footer-link:hover {
    color: var(--color-ink);
    transform: translateX(2px);
  }

  .footer-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  .footer-bottom {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-hairline);
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--color-mute);
  }

  .footer-copy { margin: 0; }
  .footer-status {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .footer-status-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background-color: var(--color-cyan-deep);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-cyan-deep) 25%, transparent);
    animation: footer-status-pulse 2.4s var(--ease-in-out-soft) infinite;
  }

  @keyframes footer-status-pulse {
    0%, 100% {
      box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-cyan-deep) 25%, transparent);
    }
    50% {
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-cyan-deep) 12%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-status-dot { animation: none; }
    .footer-link { transition: none; }
  }

  @media (max-width: 1023px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--space-2xl);
    }

    .footer-columns {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-xl);
    }
  }

  @media (max-width: 600px) {
    .footer-columns {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .footer-brand {
      max-width: 100%;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
</content>
</invoke>