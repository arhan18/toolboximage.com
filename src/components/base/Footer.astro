---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<footer class:list={['site-footer', className]}>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="ToolBox Image — Home">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="4" />
          <path d="M7 8h2l2 3 2-3h2v8h-2v-5l-2 3-2-3v5H7V8z" />
        </svg>
        <span class="text-body-sm-strong">ToolBox Image</span>
      </a>
      <p class="text-caption" style="color: var(--color-mute);">
        Fast, private image tools that run entirely in your browser.
        No uploads. No tracking. No compromises.
      </p>
    </div>

    <div class="footer-columns">
      <div class="footer-column">
        <h4 class="text-caption-mono footer-column-label">Tools</h4>
        <ul class="footer-links">
          <li><a href="/compressor" class="text-body-sm">Compressor</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="text-caption-mono footer-column-label">Company</h4>
        <ul class="footer-links">
          <li><a href="/privacy" class="text-body-sm">Privacy</a></li>
          <li><a href="/terms" class="text-body-sm">Terms</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="text-caption" style="color: var(--color-mute);">
      &copy; {new Date().getFullYear()} ToolBox Image. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding: var(--space-4xl) var(--space-lg) var(--space-xl);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: var(--space-3xl);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 320px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-ink);
  }

  .footer-columns {
    display: flex;
    gap: var(--space-3xl);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-column-label {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-mute);
    margin: 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-links a {
    color: var(--color-body);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--color-ink);
  }

  .footer-bottom {
    max-width: 1400px;
    margin: var(--space-xl) auto 0;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-hairline);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--space-xl);
    }

    .footer-columns {
      flex-direction: column;
      gap: var(--space-xl);
    }

    .footer-brand {
      max-width: 100%;
    }
  }
</style>
