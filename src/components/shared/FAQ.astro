---
/**
 * FAQ — accessible accordion. Uses native <details>/<summary> for
 * full keyboard + screen reader support; CSS smooths the open/close.
 */
interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  items: FaqItem[];
  /** Visual variant — default light, `dark` for polarity-flipped surface. */
  tone?: 'light' | 'dark';
  class?: string;
}

const { items, tone = 'light', class: className = '' } = Astro.props;
---

<ul class:list={['faq', `faq-${tone}`, className]} role="list">
  {items.map((item, i) => (
    <li class="faq-item">
      <details class="faq-details" name={items.length > 1 ? `faq-g${i}` : undefined}>
        <summary class="faq-summary text-body-md-strong">
          <span class="faq-question">
            <span class="faq-num text-caption-mono" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span>{item.q}</span>
          </span>
          <span class="faq-toggle" aria-hidden="true">
            <svg
              class="faq-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
          </span>
        </summary>
        <div class="faq-answer text-body-md">
          <p>{item.a}</p>
        </div>
      </details>
    </li>
  ))}
</ul>

<style>
  .faq {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .faq-item {
    border-radius: var(--radius-md);
    background-color: var(--color-canvas);
    box-shadow: var(--shadow-2);
    transition:
      box-shadow var(--dur-base) var(--ease-out-quart),
      transform var(--dur-base) var(--ease-out-quart);
    scroll-margin-top: 100px;
  }

  .faq-item:hover {
    box-shadow: var(--shadow-3);
  }

  .faq-item:has(.faq-details[open]) {
    box-shadow: var(--shadow-3);
  }

  .faq-dark .faq-item {
    background-color: color-mix(in srgb, var(--color-on-primary) 6%, var(--color-primary));
    box-shadow: none;
    border: 1px solid color-mix(in srgb, var(--color-on-primary) 12%, transparent);
  }

  .faq-details {
    overflow: hidden;
  }

  .faq-details[open] .faq-toggle .faq-icon {
    transform: rotate(45deg);
  }

  .faq-details[open] .faq-answer {
    grid-template-rows: 1fr;
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-lg);
    cursor: pointer;
    color: var(--color-ink);
    list-style: none;
    transition: background-color var(--dur-fast) var(--ease-out-quart);
  }

  .faq-summary:hover {
    background-color: color-mix(in srgb, var(--color-canvas-soft) 60%, transparent);
  }

  .faq-dark .faq-summary {
    color: var(--color-on-primary);
  }

  .faq-dark .faq-summary:hover {
    background-color: color-mix(in srgb, var(--color-on-primary) 6%, transparent);
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-inset);
    border-radius: var(--radius-md);
  }

  .faq-question {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    min-width: 0;
  }

  .faq-num {
    color: var(--color-mute);
    font-feature-settings: var(--tnum);
    flex-shrink: 0;
    padding-top: 2px;
  }

  .faq-toggle {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart);
  }

  .faq-dark .faq-toggle {
    background-color: color-mix(in srgb, var(--color-on-primary) 8%, transparent);
    border-color: color-mix(in srgb, var(--color-on-primary) 14%, transparent);
  }

  .faq-summary:hover .faq-toggle {
    background-color: var(--color-canvas);
    border-color: var(--color-hairline-strong);
  }

  .faq-icon {
    transition: transform var(--dur-base) var(--ease-spring);
    color: var(--color-mute);
  }

  .faq-dark .faq-icon {
    color: color-mix(in srgb, var(--color-on-primary) 60%, transparent);
  }

  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--dur-base) var(--ease-out-quart);
    color: var(--color-body);
  }

  .faq-answer > p {
    overflow: hidden;
    margin: 0;
    padding: 0 var(--space-lg) var(--space-lg);
    line-height: var(--leading-body-md);
  }

  .faq-answer > p > :global(*) + * {
    margin-top: var(--space-md);
  }

  .faq-dark .faq-answer {
    color: color-mix(in srgb, var(--color-on-primary) 75%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-toggle .faq-icon,
    .faq-answer { transition: none; }
  }
</style>
</content>
</invoke>