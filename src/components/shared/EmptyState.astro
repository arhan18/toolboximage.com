---
/**
 * EmptyState — friendly, illustrated empty-state block. Use anywhere a list,
 * table, or feature surface might be empty.
 */
interface Props {
  /** Visual tone. */
  tone?: 'soft' | 'canvas';
  /** Padding level. */
  padding?: 'sm' | 'md' | 'lg';
  /** Optional badge eyebrow shown above the title. */
  eyebrow?: string;
  title: string;
  /** Description text below the title. */
  description?: string;
  /** Optional CTA slot — typically one or two buttons. */
  class?: string;
}

const {
  tone = 'soft',
  padding = 'lg',
  eyebrow,
  title,
  description,
  class: className = '',
} = Astro.props;
---

<div class:list={['empty-state', `empty-tone-${tone}`, `empty-pad-${padding}`, className]}>
  <div class="empty-art" aria-hidden="true">
    <svg viewBox="0 0 96 96" width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="14" y="22" width="68" height="52" rx="6" />
      <path d="M14 60l16-16 14 14 10-10 28 28" />
      <circle cx="62" cy="38" r="6" />
      <line x1="34" y1="14" x2="62" y2="14" />
    </svg>
  </div>
  {eyebrow && <p class="text-caption-mono empty-eyebrow">{eyebrow}</p>}
  <h3 class="empty-title text-display-sm">{title}</h3>
  {description && <p class="empty-desc text-body-md">{description}</p>}
  <div class="empty-actions">
    <slot />
  </div>
</div>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-hairline);
    transition: background-color var(--dur-base) var(--ease-out-quart);
  }

  .empty-tone-soft {
    background-color: var(--color-canvas-soft);
  }

  .empty-tone-canvas {
    background-color: var(--color-canvas);
    box-shadow: var(--shadow-2);
  }

  .empty-pad-sm { padding: var(--space-lg); }
  .empty-pad-md { padding: var(--space-2xl); }
  .empty-pad-lg { padding: var(--space-4xl) var(--space-xl); }

  .empty-art {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-link) 10%, transparent),
      color-mix(in srgb, var(--color-violet) 10%, transparent)
    );
    border: 1px solid var(--color-hairline);
    color: var(--color-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-xs);
    box-shadow: var(--shadow-1);
    transition: transform var(--dur-slow) var(--ease-spring);
  }

  .empty-state:hover .empty-art {
    transform: translateY(-2px) rotate(-3deg);
  }

  .empty-eyebrow {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    font-weight: var(--weight-medium);
  }

  .empty-title {
    margin: 0;
    color: var(--color-ink);
    text-wrap: balance;
    max-width: 28ch;
  }

  .empty-desc {
    margin: 0;
    color: var(--color-body);
    max-width: 44ch;
    text-wrap: pretty;
  }

  .empty-actions {
    margin-top: var(--space-md);
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .empty-art { transition: none; }
  }
</style>
</content>
</invoke>