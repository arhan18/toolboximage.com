---
/**
 * PageHeader — consistent top of content pages.
 * Mono eyebrow + display headline + lead paragraph. Optional CTA slot.
 */
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'start' | 'center';
  /** Optional accent color for the eyebrow mono prefix. */
  accent?: boolean;
  class?: string;
}

const { eyebrow, title, lead, align = 'start', accent = false, class: className = '' } = Astro.props;
---

<header class:list={['page-header', `align-${align}`, accent ? 'with-accent' : '', className]}>
  {eyebrow && <p class="text-caption-mono page-eyebrow">{eyebrow}</p>}
  <h1 class="text-display-xl page-title">{title}</h1>
  {lead && <p class="text-body-lg page-lead">{lead}</p>}
  {Astro.slots.has('cta') && <div class="page-cta"><slot name="cta" /></div>}
</header>

<style>
  .page-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 720px;
  }

  .align-center {
    align-items: center;
    text-align: center;
    margin-inline: auto;
  }

  .page-eyebrow {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .with-accent .page-eyebrow::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: linear-gradient(
      135deg,
      var(--gradient-develop-start),
      var(--gradient-preview-end)
    );
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-link) 14%, transparent);
  }

  .page-title {
    margin: 0;
    color: var(--color-ink);
    letter-spacing: var(--tracking-display-xl);
    text-wrap: balance;
  }

  .page-lead {
    margin: 0;
    color: var(--color-body);
    max-width: 56ch;
    text-wrap: pretty;
  }

  .align-center .page-lead {
    margin-inline: auto;
  }

  .page-cta {
    margin-top: var(--space-sm);
  }
</style>
</content>
</invoke>