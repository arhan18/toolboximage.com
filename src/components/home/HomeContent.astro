---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import IconBox from '../ui/IconBox.astro';
import Badge from '../ui/Badge.astro';
import SectionHeader from '../shared/SectionHeader.astro';
import Reveal from '../shared/Reveal.astro';
import MeshGradient from '../shared/MeshGradient.astro';
import DropZone from '../shared/DropZone.astro';
import BeforeAfter from '../shared/BeforeAfter.astro';
import FAQ from '../shared/FAQ.astro';
import { useTranslations, LANG_CODES, type LangCode } from '../../i18n';

interface Props {
  lang?: LangCode;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const isEn = lang === 'en';
const p = (key: string) => t(key);

const whyItems = [
  { title: p('why.shield.title'), body: p('why.shield.body'), icon: 'shield' },
  { title: p('why.user.title'), body: p('why.user.body'), icon: 'user' },
  { title: p('why.eye.title'), body: p('why.eye.body'), icon: 'eye' },
];

const features = [
  { title: isEn ? 'Drag & drop.' : p('step1.title'), body: isEn ? 'Drop a folder of 500 photos. We will handle the queue.' : p('step1.body'), icon: 'mouse' },
  { title: isEn ? 'Paste from clipboard.' : 'क्लिपबोर्ड से पेस्ट करें.', body: isEn ? 'Screenshot, ⌘V, done. No intermediate file.' : 'Screenshot लें, ⌘V दबाएं, हो गया।', icon: 'clipboard' },
  { title: isEn ? 'Batch processing.' : 'एकसाथ प्रोसेसिंग।', body: isEn ? 'Process hundreds of images in parallel on web workers.' : 'एक साथ सैकड़ों इमेज प्रोसेस करें।', icon: 'stack' },
  { title: isEn ? 'Format conversion.' : 'फ़ॉर्मैट बदलें।', body: isEn ? 'JPG → WebP, PNG → AVIF — pick any source, any target.' : 'JPG → WebP, PNG → AVIF — कोई भी सोर्स, कोई भी टार्गेट।', icon: 'swap' },
  { title: isEn ? 'Quality controls.' : 'क्वालिटी कंट्रोल।', body: isEn ? 'Fine-tune quality, target size, or visual parity per image.' : 'हर इमेज की क्वालिटी, साइज़ या विज़ुअल पैरिटी सेट करें।', icon: 'sliders' },
  { title: isEn ? 'Side-by-side preview.' : 'साथ-साथ प्रीव्यू।', body: isEn ? 'Compare before and after at full resolution before you download.' : 'डाउनलोड करने से पहले फुल रिज़ॉल्यूशन में तुलना करें।', icon: 'compare' },
];

const steps = [
  { n: '01', title: p('step1.title'), body: p('step1.body') },
  { n: '02', title: p('step2.title'), body: p('step2.body') },
  { n: '03', title: p('step3.title'), body: p('step3.body') },
  { n: '04', title: p('step4.title'), body: p('step4.body') },
];

const upcoming = [
  { title: 'Image Cropper', body: isEn ? 'Drag-to-crop with safe-area guides for social platforms.' : 'सोशल प्लेटफ़ॉर्म के लिए क्रॉप गाइड।', status: 'Next' },
  { title: 'Watermark', body: isEn ? 'Tile or corner watermarks with opacity, scale, and rotation controls.' : 'वॉटरमार्क जोड़ें — ओपैसिटी, स्केल और रोटेशन कंट्रोल।', status: 'Planned' },
  { title: 'Background Remover', body: isEn ? 'One-click subject isolation. WebGPU-accelerated.' : 'एक क्लिक में बैकग्राउंड हटाएं।', status: 'Planned' },
  { title: 'EXIF Cleaner', body: isEn ? 'Strip metadata before sharing — keep the pixels, lose the trail.' : 'शेयर करने से पहले मेटाडेटा हटाएं।', status: 'Planned' },
];

const faqItems = [
  { q: p('faq.q1'), a: p('faq.a1') },
  { q: p('faq.q2'), a: p('faq.a2') },
  { q: p('faq.q3'), a: p('faq.a3') },
  { q: p('faq.q4'), a: p('faq.a4') },
  { q: p('faq.q5'), a: p('faq.a5') },
  { q: p('faq.q6'), a: p('faq.a6') },
];

const toolsGrid = [
  { href: isEn ? '/compressor/' : `/${lang}/compressor/`, label: isEn ? 'Image Compressor' : p('tools.compressor'), desc: isEn ? 'Batch image compressor with adjustable quality. 100% secure & offline.' : p('tools.compressorDesc'), cat: 'Optimize', status: 'Live' },
  { href: isEn ? '/bulk-image-compressor/' : `/${lang}/bulk-image-compressor/`, label: isEn ? 'Bulk Compressor' : p('tools.bulk'), desc: isEn ? 'Batch process up to 200 images in parallel.' : p('tools.bulkDesc'), cat: 'Optimize', status: 'Live' },
  { href: isEn ? '/image-compressor-100kb/' : `/${lang}/image-compressor-100kb/`, label: isEn ? 'Compress to 100 KB' : p('tools.target'), desc: isEn ? 'Compress images to exactly 100 KB or less.' : p('tools.targetDesc'), cat: 'Optimize', status: 'Live' },
  { href: isEn ? '/image-compressor-for-discord/' : `/${lang}/image-compressor-for-discord/`, label: isEn ? 'Discord Image Limit' : p('tools.discord'), desc: isEn ? 'Compress images to stay under Discord\'s 8 MB limit.' : p('tools.discordDesc'), cat: 'Optimize', status: 'Live' },
  { href: isEn ? '/compress-for-email/' : `/${lang}/compress-for-email/`, label: isEn ? 'Email Image Size' : p('tools.email'), desc: isEn ? 'Shrink images for email attachments (under 25 MB).' : p('tools.emailDesc'), cat: 'Optimize', status: 'Live' },
  { href: isEn ? '/tools/rotator/' : `/${lang}/tools/rotator/`, label: 'Rotate Image', desc: 'Rotate and flip images with precision controls.', cat: 'Edit', status: 'Live' },
  { href: isEn ? '/tools/converter/' : `/${lang}/tools/converter/`, label: 'Format Converter', desc: 'Convert images between JPEG, PNG, WebP, AVIF & more.', cat: 'Convert', status: 'Live' },
  { href: isEn ? '/tools/resizer/' : `/${lang}/tools/resizer/`, label: 'Image Resizer', desc: 'Resize images to exact dimensions or aspect ratios.', cat: 'Resize', status: 'Live' },
  { href: isEn ? '/tools/cropper/' : `/${lang}/tools/cropper/`, label: 'Image Cropper', desc: 'Crop images with preset ratios or freeform selection.', cat: 'Resize', status: 'Soon' },
  { href: isEn ? '/tools/flipper/' : `/${lang}/tools/flipper/`, label: 'Image Flipper', desc: 'Flip images horizontally, vertically, or both.', cat: 'Edit', status: 'Soon' },
  { href: isEn ? '/tools/heic-converter/' : `/${lang}/tools/heic-converter/`, label: 'HEIC to JPEG', desc: 'Convert Apple HEIC/HEIF photos to JPEG or PNG.', cat: 'Convert', status: 'Soon' },
  { href: isEn ? '/tools/background-remover/' : `/${lang}/tools/background-remover/`, label: 'Background Remover', desc: 'Remove image backgrounds automatically.', cat: 'Edit', status: 'Planned' },
  { href: isEn ? '/tools/blur/' : `/${lang}/tools/blur/`, label: 'Blur Image', desc: 'Blur faces, license plates, or custom regions.', cat: 'Edit', status: 'Planned' },
];

const pickerTools = [
  { href: isEn ? '/compressor/' : `/${lang}/compressor/`, label: isEn ? 'Image Compressor' : p('tools.compressor'), desc: isEn ? 'Compress any format' : p('tools.compressorDesc'), icon: 'compress' },
  { href: isEn ? '/tools/rotator/' : `/${lang}/tools/rotator/`, label: 'Rotate Image', desc: '90°, 180°, custom', icon: 'rotate' },
  { href: isEn ? '/bulk-image-compressor/' : `/${lang}/bulk-image-compressor/`, label: isEn ? 'Bulk Compressor' : p('tools.bulk'), desc: 'Batch 200 files', icon: 'bulk' },
  { href: isEn ? '/image-compressor-100kb/' : `/${lang}/image-compressor-100kb/`, label: isEn ? '100 KB Target' : p('tools.target'), desc: isEn ? 'Exact file size' : p('tools.targetDesc'), icon: 'target' },
  { href: isEn ? '/image-compressor-for-discord/' : `/${lang}/image-compressor-for-discord/`, label: isEn ? 'Discord Limit' : p('tools.discord'), desc: 'Under 8 MB', icon: 'discord' },
  { href: isEn ? '/compress-for-email/' : `/${lang}/compress-for-email/`, label: isEn ? 'Email Attachments' : p('tools.email'), desc: 'Under 25 MB', icon: 'email' },
];

const langInfo: Record<string, { label: string; flag: string }> = {
  en: { label: 'English', flag: '🇬🇧' }, es: { label: 'Español', flag: '🇪🇸' },
  fr: { label: 'Français', flag: '🇫🇷' }, de: { label: 'Deutsch', flag: '🇩🇪' },
  it: { label: 'Italiano', flag: '🇮🇹' }, pt: { label: 'Português', flag: '🇵🇹' },
  ru: { label: 'Русский', flag: '🇷🇺' }, zh: { label: '中文', flag: '🇨🇳' },
  ja: { label: '日本語', flag: '🇯🇵' }, ko: { label: '한국어', flag: '🇰🇷' },
  ar: { label: 'العربية', flag: '🇸🇦' }, hi: { label: 'हिन्दी', flag: '🇮🇳' },
  tr: { label: 'Türkçe', flag: '🇹🇷' },
};
---

<!-- ============================================================
     HERO
     ============================================================ -->
<section class="hero">
  <MeshGradient intensity="normal" />

  <div class="container hero-inner">
    <Reveal>
      <Badge eyebrow={isEn ? 'Free Image Compressor' : p('hero.badge')} tone="info" class="hero-badge">
        {isEn ? 'Image Compressor is live' : p('tools.live')}
      </Badge>
    </Reveal>

    <Reveal delay={80}>
      <h1 class="text-display-xl hero-title">
        {p('hero.title')}
      </h1>
    </Reveal>

    <Reveal delay={160}>
      <p class="text-body-lg hero-subtitle">
        {p('hero.lead')}
      </p>
    </Reveal>

    <Reveal delay={220}>
      <div class="hero-actions">
        <Button label={isEn ? 'Try the Tools' : p('hero.cta')} href={isEn ? '/image-tools/' : `/${lang}/image-tools/`} variant="primary" size="lg">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </Button>
        <Button label={isEn ? 'Try the Compressor' : p('nav.compressor')} href={isEn ? '/compressor/' : `/${lang}/compressor/`} variant="secondary" size="lg" />
      </div>
    </Reveal>

    <Reveal delay={280}>
      <nav class="hero-links" aria-label="More pages">
        <a href={isEn ? '/about/' : `/${lang}/about/`} class="hero-link">{p('nav.about')}</a>
        <span class="hero-link-sep" aria-hidden="true">·</span>
        <a href={isEn ? '/contact/' : `/${lang}/contact/`} class="hero-link">{p('nav.contact')}</a>
        <span class="hero-link-sep" aria-hidden="true">·</span>
        <a href={isEn ? '/legal/privacy/' : `/${lang}/legal/privacy/`} class="hero-link">{p('footer.privacy')}</a>
        <span class="hero-link-sep" aria-hidden="true">·</span>
        <a href={isEn ? '/legal/terms/' : `/${lang}/legal/terms/`} class="hero-link">{p('footer.terms')}</a>
      </nav>
    </Reveal>

    <Reveal delay={300}>
      <div class="hero-search">
        <svg class="hero-search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="search" class="hero-search-input" data-tool-search placeholder={isEn ? 'Search tools…' : 'टूल्स खोजें…'} aria-label={isEn ? 'Search tools' : 'टूल्स खोजें'} />
      </div>
    </Reveal>

    <Reveal delay={360} class="hero-drop">
      <DropZone />
    </Reveal>
  </div>
</section>

<!-- ============================================================
     TOOL PICKER OVERLAY
     ============================================================ -->
<div class="tool-picker-overlay" data-tool-picker-overlay hidden role="dialog" aria-label={isEn ? 'Choose a tool' : 'टूल चुनें'} aria-modal="true">
  <div class="tool-picker-backdrop" data-tool-picker-close></div>
  <div class="tool-picker stack stack-lg">
    <div class="tool-picker-heading">
      <p class="text-display-sm tool-picker-title">
        {isEn ? 'Your image is ready — where should we go?' : 'आपकी इमेज तैयार है — कहाँ जाएँ?'}
      </p>
      <p class="text-body-sm tool-picker-sub">
        {isEn ? 'Choose a tool to continue with your uploaded file.' : 'अपलोड की गई फ़ाइल के लिए एक टूल चुनें।'}
      </p>
    </div>
    <div class="tool-picker-grid">
      {pickerTools.map((tool) => (
        <a href={tool.href} class="tool-picker-card" data-tool-picker-link>
          <div class="tool-picker-card-icon" aria-hidden="true">
            {tool.icon === 'compress' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>}
            {tool.icon === 'rotate' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>}
            {tool.icon === 'bulk' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>}
            {tool.icon === 'target' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>}
            {tool.icon === 'discord' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="4"/><path d="M8 16V8l8 4-8 4z"/></svg>}
            {tool.icon === 'email' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>}
          </div>
          <p class="text-body-sm-strong tool-picker-card-label">{tool.label}</p>
          <p class="text-caption tool-picker-card-desc">{tool.desc}</p>
        </a>
      ))}
    </div>
    <button type="button" class="tool-picker-cancel" data-tool-picker-close>
      {isEn ? 'Cancel — remove files' : 'रद्द करें — फ़ाइलें हटाएँ'}
    </button>
  </div>
</div>

<script>
  import { storeFiles } from '../../lib/file-transfer';

  const overlay = document.querySelector<HTMLElement>('[data-tool-picker-overlay]');
  const closeBtns = document.querySelectorAll<HTMLElement>('[data-tool-picker-close]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-tool-picker-link]');

  window.addEventListener('toolboximage:files', async (e) => {
    const detail = (e as CustomEvent<{ files: File[] }>).detail;
    if (!detail?.files?.length) return;
    await storeFiles(detail.files);
    if (overlay) overlay.hidden = false;
  });

  closeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (overlay) overlay.hidden = true;
    });
  });

  links.forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = link.getAttribute('href');
      if (href) window.location.href = href;
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay && !overlay.hidden) {
      overlay.hidden = true;
    }
  });
</script>

<!-- ============================================================
     TOOLS — TABS + GRID
     ============================================================ -->
<section class="band band-canvas home-tools">
  <div class="container stack stack-2xl">
    <Reveal>
      <div class="home-tools-header">
        <Badge eyebrow="Toolbox" tone="info">{isEn ? 'All tools' : p('tools.title')}</Badge>
        <a href={isEn ? '/image-tools/' : `/${lang}/image-tools/`} class="home-tools-link">{isEn ? 'View all →' : 'सब देखें →'}</a>
      </div>
    </Reveal>

    <Reveal delay={10}>
      <nav class="tools-tabs" role="tablist" aria-label={isEn ? 'Tool categories' : 'टूल कैटेगरी'}>
        {['All', 'Optimize', 'Convert', 'Resize', 'Edit'].map((tab, i) => (
          <button
            type="button"
            class:list={['tools-tab', i === 0 && 'tools-tab-active']}
            role="tab"
            aria-selected={i === 0}
            data-tools-tab={tab}
          >{tab}</button>
        ))}
      </nav>
    </Reveal>

    <div class="tools-grid" data-tool-grid>
      {toolsGrid.map((tool) => (
        <a
          href={tool.href}
          class:list={['tool-card', tool.status !== 'Live' && 'tool-card-dim']}
          data-tool-cat={tool.cat}
          data-tool-status={tool.status}
        >
          <span class="tool-card-badge">{tool.cat.toUpperCase()}</span>
          <p class="text-body-sm-strong tool-card-label">{tool.label}</p>
          <p class="text-caption tool-card-desc">{tool.desc}</p>
          <span class="tool-card-status">
            {tool.status === 'Live' ? 'Free' : tool.status === 'Soon' ? (isEn ? 'Coming soon' : 'जल्द आ रहा है') : (isEn ? 'Planned' : 'आने वाला है')}
          </span>
        </a>
      ))}
    </div>

    <div class="tools-pagination" data-tools-pagination>
      <span class="tools-pagination-count text-caption" data-tools-count></span>
      <nav class="tools-pagination-nav" aria-label={isEn ? 'Tool pages' : 'टूल पेज'}>
        <button type="button" class="tools-page-btn" data-page-prev disabled>{isEn ? 'Previous' : 'पिछला'}</button>
        <div class="tools-page-numbers" data-page-numbers></div>
        <button type="button" class="tools-page-btn" data-page-next disabled>{isEn ? 'Next' : 'अगला'}</button>
      </nav>
    </div>
  </div>
</section>

<script>
  const PER_PAGE = 9;
  const searchInput = document.querySelector<HTMLInputElement>('[data-tool-search]');
  const toolGrid = document.querySelector<HTMLElement>('[data-tool-grid]');
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tools-tab]');
  const countEl = document.querySelector<HTMLElement>('[data-tools-count]');
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-page-prev]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-page-next]');
  const pageNumbersEl = document.querySelector<HTMLElement>('[data-page-numbers]');

  let activeTab = 'All';
  let currentPage = 1;
  let filteredCards: HTMLAnchorElement[] = [];

  const getFiltered = (): HTMLAnchorElement[] => {
    if (!toolGrid) return [];
    const cards = Array.from(toolGrid.querySelectorAll<HTMLAnchorElement>('.tool-card'));
    const q = searchInput?.value.toLowerCase().trim() || '';
    return cards.filter((card) => {
      const cat = card.dataset.toolCat || '';
      const label = card.querySelector('.tool-card-label')?.textContent?.toLowerCase() || '';
      const matchCat = activeTab === 'All' || cat === activeTab;
      const words = q ? label.split(' ') : [];
      const matchSearch = !q || label.startsWith(q) || words.some((w) => w.startsWith(q));
      return matchCat && matchSearch;
    });
  };

  const renderPage = () => {
    const total = filteredCards.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;
    const start = (currentPage - 1) * PER_PAGE;
    const end = Math.min(start + PER_PAGE, total);
    toolGrid?.querySelectorAll<HTMLAnchorElement>('.tool-card').forEach((card, i) => {
      const inPage = i >= start && i < end;
      const isFiltered = filteredCards.includes(card);
      card.style.display = isFiltered && inPage ? '' : 'none';
    });
    if (countEl) {
      if (total === 0) {
        countEl.textContent = 'No tools found';
      } else {
        countEl.textContent = `Showing ${start + 1}–${end} of ${total} tools`;
      }
    }
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
    if (pageNumbersEl) {
      pageNumbersEl.innerHTML = '';
      for (let p = 1; p <= totalPages; p++) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = `tools-page-num${p === currentPage ? ' tools-page-num-active' : ''}`;
        btn.textContent = String(p);
        btn.addEventListener('click', () => { currentPage = p; renderPage(); });
        pageNumbersEl.appendChild(btn);
      }
    }
  };

  const updateTools = () => {
    currentPage = 1;
    filteredCards = getFiltered();
    renderPage();
  };

  tabs.forEach((btn) => {
    btn.addEventListener('click', () => {
      tabs.forEach((b) => {
        b.classList.remove('tools-tab-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('tools-tab-active');
      btn.setAttribute('aria-selected', 'true');
      activeTab = btn.dataset.toolsTab || 'All';
      updateTools();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', updateTools);
  }

  prevBtn?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderPage(); } });
  nextBtn?.addEventListener('click', () => { if (currentPage < Math.ceil(filteredCards.length / PER_PAGE)) { currentPage++; renderPage(); } });

  updateTools();
</script>

<!-- ============================================================
     WHY TOOLBOX IMAGE
     ============================================================ -->
<section class="band band-soft" id="why">
  <div class="container stack stack-3xl">
    <SectionHeader eyebrow={isEn ? 'Why ToolBox Image' : p('features.why.title')} leadMaxWidth="560px">
      <h2 class="text-display-lg">{isEn ? "Privacy isn't a feature. It's the architecture." : p('features.why.title')}</h2>
      <p class="lead">
        {isEn ? 'Most "free" image tools earn their keep by uploading your files, training on them, or showing you ads. We earn it by being the fastest, cleanest, most private tool on the web.' : p('features.why.lead')}
      </p>
    </SectionHeader>

    <div class="why-grid">
      {whyItems.map((w, i) => (
