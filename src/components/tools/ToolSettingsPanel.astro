---
import type { ToolConfig } from '../../types';
import { useTranslations, type LangCode } from '../../i18n';

interface Props {
  tool: ToolConfig;
  lang?: LangCode;
}

const { tool, lang = 'en' } = Astro.props;
const _ = useTranslations(lang);
const hasSettings = tool.steps?.includes('configure') ?? true;
---

<section class="tool-settings" aria-label={_('settings.title')} data-tool-settings data-tool-id={tool.id} hidden={!hasSettings}>
  <header class="tool-settings-header">
    <h2 class="text-display-sm tool-settings-title">{_('settings.title')}</h2>
    <slot name="settings-actions" />
  </header>
  <div class="tool-settings-body" data-tool-settings-body>
    <slot name="settings-controls">
      <p class="text-body-sm" style="color:var(--color-body);">
        Configure this tool once it is available.
      </p>
    </slot>
  </div>
</section>

<style>
  .tool-settings {
    background-color: var(--color-canvas);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-2);
    overflow: hidden;
  }

  .tool-settings-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-lg);
    border-bottom: 1px solid var(--color-hairline);
  }

  .tool-settings-title {
    margin: 0;
  }

  .tool-settings-body {
    padding: var(--space-lg);
  }
</style>
