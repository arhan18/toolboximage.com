---
import ToolUpload from './ToolUpload.astro';
import ToolSettingsPanel from './ToolSettingsPanel.astro';
import { getTool } from '../../lib/tools';
import { useTranslations, type LangCode } from '../../i18n';

interface Props {
  lang?: LangCode;
}

const { lang = 'en' } = Astro.props;
const _ = useTranslations(lang);
const tool = getTool('image-to-pdf')!;

const pageSizes = [
  { id: 'fit', key: 'pdfPage.fit' },
  { id: 'a4', key: 'pdfPage.a4' },
  { id: 'letter', key: 'pdfPage.letter' },
];
const orientations = [
  { id: 'auto', key: 'pdfPage.auto' },
  { id: 'portrait', key: 'pdfPage.portrait' },
  { id: 'landscape', key: 'pdfPage.landscape' },
];
const margins = [
  { id: 'none', key: 'pdfPage.marginNone' },
  { id: 'small', key: 'pdfPage.marginSmall' },
  { id: 'normal', key: 'pdfPage.marginNormal' },
];
const fits = [
  { id: 'contain', key: 'pdfPage.fitContain' },
  { id: 'cover', key: 'pdfPage.fitCover' },
];
---

<section class="pdf-workflow stack stack-lg">
  <ToolUpload {tool} {lang} />

  <ToolSettingsPanel {tool} {lang}>
    <div slot="settings-actions">
      <span class="text-caption-mono" style="color:var(--color-mute);" data-pdf-file-count></span>
    </div>
    <div slot="settings-controls">
      <fieldset class="pdf-fieldset">
        <legend class="text-caption-mono pdf-label">{_('pdfPage.pageSize')}</legend>
        <div class="pdf-btn-row" data-pdf-page-size>
          {pageSizes.map((s) => (
            <button type="button" class="pdf-opt-btn" data-pdf-opt={s.id}>{_(s.key)}</button>
          ))}
        </div>
      </fieldset>
      <fieldset class="pdf-fieldset">
        <legend class="text-caption-mono pdf-label">{_('pdfPage.orientation')}</legend>
        <div class="pdf-btn-row" data-pdf-orientation>
          {orientations.map((o) => (
            <button type="button" class="pdf-opt-btn" data-pdf-opt={o.id}>{_(o.key)}</button>
          ))}
        </div>
      </fieldset>
      <fieldset class="pdf-fieldset">
        <legend class="text-caption-mono pdf-label">{_('pdfPage.margins')}</legend>
        <div class="pdf-btn-row" data-pdf-margins>
          {margins.map((m) => (
            <button type="button" class="pdf-opt-btn" data-pdf-opt={m.id}>{_(m.key)}</button>
          ))}
        </div>
      </fieldset>
      <fieldset class="pdf-fieldset">
        <legend class="text-caption-mono pdf-label">{_('pdfPage.imageFit')}</legend>
        <div class="pdf-btn-row" data-pdf-fit>
          {fits.map((f) => (
            <button type="button" class="pdf-opt-btn" data-pdf-opt={f.id}>{_(f.key)}</button>
          ))}
        </div>
      </fieldset>
      <fieldset class="pdf-fieldset">
        <legend class="text-caption-mono pdf-label">{_('pdfPage.format')}</legend>
        <div class="pdf-btn-row" data-pdf-encoding>
          <button type="button" class="pdf-opt-btn" data-pdf-opt="jpeg" data-active="true">{_('pdfPage.jpeg')}</button>
          <button type="button" class="pdf-opt-btn" data-pdf-opt="png">{_('pdfPage.png')}</button>
        </div>
        <p class="text-caption pdf-format-hint" data-pdf-format-hint data-jpeg-hint={_('pdfPage.formatJpegHint')} data-png-hint={_('pdfPage.formatPngHint')}>{_('pdfPage.formatJpegHint')}</p>
      </fieldset>
      <div class="pdf-quality" data-pdf-quality-section>
        <label class="text-caption-mono pdf-label" for="pdf-quality">{_('pdfPage.quality')}</label>
        <div class="pdf-quality-row">
          <input type="range" id="pdf-quality" class="pdf-range" data-pdf-quality min="1" max="100" value="85" />
          <span class="text-body-sm-strong pdf-quality-value" data-pdf-quality-value>85%</span>
        </div>
      </div>
    </div>
  </ToolSettingsPanel>

  <section class="pdf-preview" data-pdf-preview hidden>
    <div class="pdf-preview-header">
      <span class="text-caption-mono pdf-preview-title">{_('pdfPage.images')}</span>
      <button type="button" class="pdf-clear-all-btn" data-pdf-clear-all hidden>{_('tool.clear')}</button>
    </div>
    <div class="pdf-thumb-grid" data-pdf-thumb-grid></div>

    <div class="pdf-viewer" data-pdf-viewer hidden>
      <div class="pdf-viewer-header">
        <span class="text-caption-mono pdf-preview-title">{_('pdfPage.pdfPreview')}</span>
        <span class="text-caption-mono" data-pdf-page-info data-pages-text={_('pdfPage.pages')}></span>
      </div>
      <div class="pdf-viewer-iframe-wrap">
        <iframe class="pdf-iframe" data-pdf-iframe title="PDF Preview"></iframe>
      </div>
    </div>
  </section>

  <section class="pdf-download" data-pdf-download hidden>
    <div class="pdf-download-bar">
      <div class="pdf-download-info">
        <p class="text-caption-mono pdf-download-label">{_('pdfPage.downloadBtn')}</p>
        <p class="text-body-sm-strong" data-pdf-download-name data-filename="images.pdf"></p>
      </div>
      <button type="button" class="results-btn results-btn-primary" data-pdf-download-btn>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        {_('pdfPage.downloadBtn')}
      </button>
      <button type="button" class="results-btn results-btn-ghost" data-pdf-clear>
        {_('tool.clear')}
      </button>
    </div>
  </section>
</section>

<script>
  const thumbGrid = document.querySelector<HTMLElement>('[data-pdf-thumb-grid]');
  const previewArea = document.querySelector<HTMLElement>('[data-pdf-preview]');
  const downloadSection = document.querySelector<HTMLElement>('[data-pdf-download]');
  const downloadBtn = document.querySelector<HTMLButtonElement>('[data-pdf-download-btn]');
  const downloadNameEl = document.querySelector<HTMLElement>('[data-pdf-download-name]');
  const clearAllBtn = document.querySelector<HTMLButtonElement>('[data-pdf-clear-all]');
  const clearBtns = document.querySelectorAll<HTMLButtonElement>('[data-pdf-clear]');
  const fileCountEl = document.querySelector<HTMLElement>('[data-pdf-file-count]');

  const pageSizeBtns = document.querySelectorAll<HTMLButtonElement>('[data-pdf-page-size] [data-pdf-opt]');
  const orientationBtns = document.querySelectorAll<HTMLButtonElement>('[data-pdf-orientation] [data-pdf-opt]');
  const marginBtns = document.querySelectorAll<HTMLButtonElement>('[data-pdf-margins] [data-pdf-opt]');
  const fitBtns = document.querySelectorAll<HTMLButtonElement>('[data-pdf-fit] [data-pdf-opt]');
  const encodingBtns = document.querySelectorAll<HTMLButtonElement>('[data-pdf-encoding] [data-pdf-opt]');
  const formatHintEl = document.querySelector<HTMLElement>('[data-pdf-format-hint]');
  const qualitySection = document.querySelector<HTMLElement>('[data-pdf-quality-section]');
  const qualityInput = document.querySelector<HTMLInputElement>('[data-pdf-quality]');
  const qualityValueEl = document.querySelector<HTMLElement>('[data-pdf-quality-value]');
  const pdfViewer = document.querySelector<HTMLElement>('[data-pdf-viewer]');
  const pdfIframe = document.querySelector<HTMLIFrameElement>('[data-pdf-iframe]');
  const pdfPageInfo = document.querySelector<HTMLElement>('[data-pdf-page-info]');

  interface PdfImage {
    file: File;
    img: HTMLImageElement;
    dataUrl: string;
  }

  let images: PdfImage[] = [];
  let filesBeingProcessed = false;
  let pdfLoaded = false;
  let currentPdfBlob: Blob | null = null;
  let currentPdfUrl: string | null = null;

  // Default selections
  let selectedPageSize = 'fit';
  let selectedOrientation = 'auto';
  let selectedMargins = 'none';
  let selectedFit = 'contain';
  let selectedEncoding = 'jpeg';
  let selectedQuality = 85;

  const PAGE_DIMS: Record<string, [number, number]> = {
    a4: [595.28, 841.89],
    letter: [612, 792],
  };

  const MARGIN_PTS: Record<string, number> = {
    none: 0,
    small: 28.35,
    normal: 56.69,
  };

  // Set initial active states
  pageSizeBtns[0] && (pageSizeBtns[0].dataset.active = 'true');
  orientationBtns[0] && (orientationBtns[0].dataset.active = 'true');
  marginBtns[0] && (marginBtns[0].dataset.active = 'true');
  fitBtns[0] && (fitBtns[0].dataset.active = 'true');

  const handleOptClick = (btns: NodeListOf<HTMLButtonElement>, setter: (v: string) => void) => {
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        btns.forEach((b) => b.dataset.active = 'false');
        btn.dataset.active = 'true';
        setter(btn.dataset.pdfOpt!);
      });
    });
  };

  handleOptClick(pageSizeBtns, (v) => { selectedPageSize = v; });
  handleOptClick(orientationBtns, (v) => { selectedOrientation = v; });
  handleOptClick(marginBtns, (v) => { selectedMargins = v; });
  handleOptClick(fitBtns, (v) => { selectedFit = v; });
  handleOptClick(encodingBtns, (v) => {
    selectedEncoding = v;
    if (qualitySection) qualitySection.hidden = v !== 'jpeg';
    if (formatHintEl) {
      formatHintEl.textContent = v === 'jpeg'
        ? formatHintEl.dataset.jpegHint || 'JPEG reduces quality slightly but makes the PDF file 5–10× smaller'
        : formatHintEl.dataset.pngHint || 'PNG preserves perfect quality but makes the PDF file much larger';
    }
    if (images.length) generatePdf();
  });

  if (qualityInput && qualityValueEl) {
    qualityInput.addEventListener('input', () => {
      selectedQuality = Number(qualityInput.value);
      qualityValueEl.textContent = selectedQuality + '%';
      if (images.length) generatePdf();
    });
  }

  const formatBytes = (bytes: number): string => {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  };

  const loadPdfLib = async (): Promise<void> => {
    if (pdfLoaded) return;
    if ((window as any).PDFLib) { pdfLoaded = true; return; }
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js';
      script.onload = () => { pdfLoaded = true; resolve(); };
      script.onerror = () => reject(new Error('Failed to load pdf-lib'));
      document.head.appendChild(script);
    });
  };

  const loadImageAsDataUrl = (file: File): Promise<{ img: HTMLImageElement; dataUrl: string }> => {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const dataUrl = reader.result as string;
        const img = new Image();
        img.onload = () => resolve({ img, dataUrl });
        img.onerror = () => reject(new Error('Failed to decode image'));
        img.src = dataUrl;
      };
      reader.onerror = () => reject(new Error('Failed to read file'));
      reader.readAsDataURL(file);
    });
  };

  const renderThumbnails = () => {
    if (!thumbGrid) return;
    thumbGrid.innerHTML = '';
    images.forEach((item, idx) => {
      const card = document.createElement('div');
      card.className = 'pdf-thumb-card';
      card.innerHTML = `
        <div class="pdf-thumb-img-wrap">
          <img src="${item.dataUrl}" alt="${item.file.name}" class="pdf-thumb-img" />
        </div>
        <div class="pdf-thumb-info">
          <span class="text-caption pdf-thumb-name" title="${item.file.name}">${item.file.name}</span>
          <span class="text-caption pdf-thumb-size">${item.img.naturalWidth}×${item.img.naturalHeight} · ${formatBytes(item.file.size)}</span>
        </div>
        <div class="pdf-thumb-actions">
          <button type="button" class="pdf-thumb-btn" data-pdf-move-up="${idx}" ${idx === 0 ? 'disabled' : ''} aria-label="Move up">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
          </button>
          <button type="button" class="pdf-thumb-btn" data-pdf-move-down="${idx}" ${idx === images.length - 1 ? 'disabled' : ''} aria-label="Move down">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <button type="button" class="pdf-thumb-btn pdf-thumb-remove" data-pdf-remove="${idx}" aria-label="Remove">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      `;
      const upBtn = card.querySelector<HTMLButtonElement>('[data-pdf-move-up]');
      const downBtn = card.querySelector<HTMLButtonElement>('[data-pdf-move-down]');
      const removeBtn = card.querySelector<HTMLButtonElement>('[data-pdf-remove]');
      upBtn?.addEventListener('click', () => moveImage(Number(upBtn.dataset.pdfMoveUp), -1));
      downBtn?.addEventListener('click', () => moveImage(Number(downBtn.dataset.pdfMoveDown), 1));
      removeBtn?.addEventListener('click', () => removeImage(Number(removeBtn.dataset.pdfRemove)));
      thumbGrid.appendChild(card);
    });
    updateCount();
  };

  const moveImage = (idx: number, dir: -1 | 1) => {
    const newIdx = idx + dir;
    if (newIdx < 0 || newIdx >= images.length) return;
    [images[idx], images[newIdx]] = [images[newIdx], images[idx]];
    renderThumbnails();
    currentPdfBlob = null;
    if (currentPdfUrl) { URL.revokeObjectURL(currentPdfUrl); currentPdfUrl = null; }
  };

  const removeImage = (idx: number) => {
    images.splice(idx, 1);
    if (images.length === 0) {
      doClear();
      return;
    }
    renderThumbnails();
    currentPdfBlob = null;
    if (currentPdfUrl) { URL.revokeObjectURL(currentPdfUrl); currentPdfUrl = null; }
  };

  const updateCount = () => {
    if (fileCountEl) fileCountEl.textContent = `${images.length} file${images.length !== 1 ? 's' : ''}`;
    if (clearAllBtn) clearAllBtn.hidden = images.length === 0;
  };

  const imageEncodeBlob = (img: HTMLImageElement, encoding: string, quality: number): Promise<Blob> => {
    return new Promise((resolve) => {
      const canvas = document.createElement('canvas');
      canvas.width = img.naturalWidth;
      canvas.height = img.naturalHeight;
      const ctx = canvas.getContext('2d')!;
      ctx.drawImage(img, 0, 0);
      const mime = encoding === 'jpeg' ? 'image/jpeg' : 'image/png';
      const q = encoding === 'jpeg' ? quality / 100 : undefined;
      canvas.toBlob((blob) => resolve(blob!), mime, q);
    });
  };

  const generatePdf = async (): Promise<void> => {
    if (!images.length) return;
    await loadPdfLib();

    const PDFLib = (window as any).PDFLib;
    const doc = await PDFLib.PDFDocument.create();

    for (const item of images) {
      let width = item.img.naturalWidth;
      let height = item.img.naturalHeight;

      // Determine page dimensions
      let pageW: number, pageH: number;

      if (selectedPageSize === 'fit') {
        // Use image dimensions in points (1pt = 1/72 inch, assume 72 DPI)
        pageW = width;
        pageH = height;
      } else {
        [pageW, pageH] = PAGE_DIMS[selectedPageSize] || PAGE_DIMS.a4;
      }

      // Apply orientation
      if (selectedOrientation === 'portrait' && pageW > pageH) {
        [pageW, pageH] = [pageH, pageW];
      } else if (selectedOrientation === 'landscape' && pageH > pageW) {
        [pageW, pageH] = [pageH, pageW];
      } else if (selectedOrientation === 'auto') {
        // Auto: match orientation to image
        const imgIsLandscape = width > height;
        const pageIsLandscape = pageW > pageH;
        if (imgIsLandscape !== pageIsLandscape) {
          [pageW, pageH] = [pageH, pageW];
        }
      }

      const margin = MARGIN_PTS[selectedMargins] || 0;
      const availW = pageW - margin * 2;
      const availH = pageH - margin * 2;

      // Calculate image position/size
      let drawW: number, drawH: number;
      const imgAspect = width / height;
      const availAspect = availW / availH;

      if (selectedFit === 'contain') {
        if (imgAspect > availAspect) {
          drawW = availW;
          drawH = availW / imgAspect;
        } else {
          drawH = availH;
          drawW = availH * imgAspect;
        }
      } else {
        // cover
        if (imgAspect > availAspect) {
          drawH = availH;
          drawW = availH * imgAspect;
        } else {
          drawW = availW;
          drawH = availW / imgAspect;
        }
      }

      const x = margin + (availW - drawW) / 2;
      const y = margin + (availH - drawH) / 2;

      // Embed image
      const encodedBlob = await imageEncodeBlob(item.img, selectedEncoding, selectedQuality);
      const encodedBytes = new Uint8Array(await encodedBlob.arrayBuffer());
      const pdfImg = selectedEncoding === 'jpeg'
        ? await doc.embedJpg(encodedBytes)
        : await doc.embedPng(encodedBytes);

      const page = doc.addPage([pageW, pageH]);
      page.drawImage(pdfImg, {
        x,
        y,
        width: drawW,
        height: drawH,
      });
    }

    const pdfBytes = await doc.save();
    const blob = new Blob([pdfBytes], { type: 'application/pdf' });
    if (currentPdfUrl) URL.revokeObjectURL(currentPdfUrl);
    currentPdfBlob = blob;
    currentPdfUrl = URL.createObjectURL(blob);

    if (downloadSection) downloadSection.hidden = false;
    if (downloadNameEl) {
      const name = images.length === 1
        ? images[0].file.name.replace(/\.[^.]+$/, '') + '.pdf'
        : 'combined_images.pdf';
      downloadNameEl.textContent = `${name} · ${formatBytes(blob.size)}`;
      downloadNameEl.dataset.filename = name;
    }

    const pageCount = doc.getPageCount();
    if (pdfViewer) pdfViewer.hidden = false;
    if (pdfIframe && currentPdfUrl) {
      if (pdfIframe.src.startsWith('blob:')) URL.revokeObjectURL(pdfIframe.src);
      pdfIframe.src = currentPdfUrl;
    }
    if (pdfPageInfo) {
      const label = pdfPageInfo.dataset.pagesText || 'pages';
      pdfPageInfo.textContent = `${pageCount} ${label}`;
    }
  };

  if (downloadBtn) {
    downloadBtn.addEventListener('click', () => {
      if (!currentPdfUrl) return;
      const a = document.createElement('a');
      a.href = currentPdfUrl;
      a.download = downloadNameEl?.dataset.filename || 'images.pdf';
      a.click();
    });
  }

  const doClear = () => {
    images = [];
    filesBeingProcessed = false;
    if (currentPdfUrl) URL.revokeObjectURL(currentPdfUrl);
    currentPdfBlob = null;
    currentPdfUrl = null;
    if (previewArea) previewArea.hidden = true;
    if (downloadSection) downloadSection.hidden = true;
    if (thumbGrid) thumbGrid.innerHTML = '';
    if (pdfViewer) pdfViewer.hidden = true;
    if (pdfIframe) { if (pdfIframe.src.startsWith('blob:')) URL.revokeObjectURL(pdfIframe.src); pdfIframe.src = ''; }
    updateCount();
    const uploadZone = document.querySelector<HTMLElement>('[data-tool-upload]');
    uploadZone?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  };

  clearBtns.forEach((btn) => btn.addEventListener('click', doClear));
  if (clearAllBtn) clearAllBtn.addEventListener('click', doClear);

  const showError = (msg: string) => {
    const errorsEl = document.querySelector<HTMLElement>('[data-tool-errors]');
    const errorsList = document.querySelector<HTMLElement>('[data-tool-errors-list]');
    if (errorsEl && errorsList) {
      errorsList.innerHTML = `<li>${msg}</li>`;
      errorsEl.hidden = false;
    }
  };

  const onFilesReceived = async (files: File[]) => {
    if (filesBeingProcessed || !files.length) return;
    filesBeingProcessed = true;

    let validCount = 0;
    for (const file of files) {
      try {
        const result = await loadImageAsDataUrl(file);
        images.push({ file, img: result.img, dataUrl: result.dataUrl });
        validCount++;
      } catch {
        // Skip files that can't be decoded
      }
    }

    if (validCount === 0) {
      showError('No valid images could be loaded. Try a different file format (JPEG, PNG, WebP, etc.)');
      return;
    }

    if (previewArea) previewArea.hidden = false;
    renderThumbnails();
    previewArea?.scrollIntoView({ behavior: 'smooth', block: 'start' });

    try {
      await generatePdf();
    } catch (e) {
      console.error('PDF generation failed:', e);
      showError('Failed to generate PDF. The PDF library may not have loaded. Please check your internet connection and try again.');
    }
  };

  window.addEventListener('toolboximage:files', async (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail?.files?.length) onFilesReceived(detail.files);
  });

  // Capture-phase file input listener (catches uploads even if CustomEvent fails)
  const fileInput = document.querySelector<HTMLInputElement>('[data-action="file-input"]');
  if (fileInput) {
    fileInput.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (!target.files?.length) return;
      const files = Array.from(target.files);
      setTimeout(() => {
        if (!filesBeingProcessed) onFilesReceived(files);
      }, 0);
    }, { capture: true });
  }

  (async () => {
    if (sessionStorage.getItem('toolboximage:transfer') === '1') {
      sessionStorage.removeItem('toolboximage:transfer');
      const { retrieveFiles } = await import('../../lib/file-transfer');
      const files = await retrieveFiles();
      if (files.length) onFilesReceived(files);
    }
  })();

  window.addEventListener('beforeunload', () => {
    if (images.length && sessionStorage.getItem('toolboximage:transfer') === '1') {
      sessionStorage.removeItem('toolboximage:transfer');
      import('../../lib/file-transfer').then(m => m.storeFiles(images.map(i => i.file)));
    }
  });
</script>

<style>
  .pdf-workflow { display: flex; flex-direction: column; gap: var(--space-2xl); }

  .pdf-fieldset { border: none; margin: 0; padding: 0; }
  .pdf-label { color: var(--color-mute); margin: 0 0 var(--space-sm); display: block; }

  .pdf-btn-row { display: flex; gap: var(--space-xs); flex-wrap: wrap; }
  .pdf-opt-btn {
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    color: var(--color-body);
    cursor: pointer;
    font: inherit;
    font-size: var(--text-body-sm);
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .pdf-opt-btn:hover { background: var(--color-canvas-soft); border-color: var(--color-hairline-strong); }
  .pdf-opt-btn[data-active="true"] { border-color: var(--color-link); background: color-mix(in srgb, var(--color-link) 10%, transparent); color: var(--color-link-deep); }

  .pdf-preview { background: var(--color-canvas); border-radius: var(--radius-lg); box-shadow: var(--shadow-2); overflow: hidden; padding: var(--space-lg); }
  .pdf-preview-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-md); }
