---
import type { ToolConfig } from '../../types';
import { useTranslations, type LangCode } from '../../i18n';

interface Props {
  tool: ToolConfig;
  lang?: LangCode;
}

const { tool, lang = 'en' } = Astro.props;
const _ = useTranslations(lang);

const formatList = tool.inputFormats
  ? tool.inputFormats
      .map((m) => m.replace('image/', '').replace('application/', '').toUpperCase())
      .join(', ')
  : 'Various formats';
---

<section class="tool-upload" aria-label={_('upload.dropzone')}>
  <div
    id="tool-upload-zone"
    class="tool-upload-zone"
    role="button"
    tabindex="0"
    aria-label={_('upload.dropzone')}
    data-tool-upload
  >
    <div class="tool-upload-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="17 8 12 3 7 8" />
        <line x1="12" y1="3" x2="12" y2="15" />
      </svg>
    </div>
    <p class="text-display-sm tool-upload-title">{_('upload.dropzone')}</p>
    <p class="text-body-sm tool-upload-sub">
      <button type="button" class="tool-upload-link" data-action="browse">{_('upload.browse')}</button>
      <span class="tool-upload-divider">·</span>
      <button type="button" class="tool-upload-link" data-action="paste">{_('upload.paste')}</button>
    </p>
    <p class="text-caption-mono tool-upload-formats">{formatList}</p>
    <input type="file" multiple accept={tool.inputFormats?.join(',') ?? '*/*'} data-action="file-input" hidden aria-hidden="true" />
  </div>
  <div class="tool-upload-errors" data-tool-errors hidden role="alert" aria-live="polite">
    <p class="text-caption-mono tool-upload-errors-label" data-i18n="upload.skipped">{_('upload.skipped')}</p>
    <ul class="tool-upload-errors-list" data-tool-errors-list></ul>
  </div>
</section>

<script>
  type FilesPayload = { files: File[] };

  const zone = document.querySelector<HTMLElement>('[data-tool-upload]');
  if (zone) {
    const input = zone.querySelector<HTMLInputElement>('[data-action="file-input"]')!;
    const browseBtn = zone.querySelector<HTMLButtonElement>('[data-action="browse"]')!;
    const pasteBtn = zone.querySelector<HTMLButtonElement>('[data-action="paste"]')!;
    const errorsEl = document.querySelector<HTMLElement>('[data-tool-errors]');
    const errorsList = document.querySelector<HTMLElement>('[data-tool-errors-list]');

    const ACCEPTED_EXT = new Set(['jpg', 'jpeg', 'png', 'webp', 'avif', 'gif', 'svg', 'heic', 'heif']);

    const isImage = (f: File) => {
      if (f.type.startsWith('image/')) return true;
      const ext = f.name.split('.').pop()?.toLowerCase() ?? '';
      return ACCEPTED_EXT.has(ext);
    };

    const emit = (files: File[]) => {
      if (!files.length) return;
      window.dispatchEvent(
        new CustomEvent<FilesPayload>('toolboximage:files', { detail: { files } })
      );
    };

    const handleFiles = (allFiles: FileList | File[]) => {
      const valid: File[] = [];
      const skipped: string[] = [];
      for (const f of Array.from(allFiles)) {
        if (isImage(f)) valid.push(f);
        else skipped.push(f.name);
      }
      if (skipped.length && errorsEl && errorsList) {
        errorsList.innerHTML = skipped.map((n) => `<li>${n}</li>`).join('');
        errorsEl.hidden = false;
      }
      emit(valid);
    };

    zone.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        input.click();
      }
    });

    browseBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      input.click();
    });

    pasteBtn.addEventListener('click', async (e) => {
      e.stopPropagation();
      try {
        if (!navigator.clipboard || !('read' in navigator.clipboard)) return;
        const items = await (navigator.clipboard as Clipboard).read();
        const files: File[] = [];
        for (const it of items) {
          for (const type of it.types) {
            if (type.startsWith('image/')) {
              const blob = await it.getType(type);
              files.push(new File([blob], `pasted-${Date.now()}.${type.split('/')[1]}`, { type }));
            }
          }
        }
        if (files.length) emit(files);
      } catch {
        // Permission denied or no image — silent
      }
    });

    input.addEventListener('change', () => {
      if (input.files) handleFiles(input.files);
      input.value = '';
    });

    zone.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-action="paste"]')) return;
      input.click();
    });

    ['dragenter', 'dragover'].forEach((ev) => {
      zone.addEventListener(ev, (e) => {
        e.preventDefault();
        zone.dataset.dragover = 'true';
      });
    });

    ['dragleave', 'drop'].forEach((ev) => {
      zone.addEventListener(ev, (e) => {
        e.preventDefault();
        if (ev === 'dragleave' && zone.contains(e.relatedTarget as Node)) return;
        zone.dataset.dragover = 'false';
      });
    });

    zone.addEventListener('drop', (e) => {
      const dt = (e as DragEvent).dataTransfer;
      if (!dt) return;
      handleFiles(dt.files);
    });

    document.addEventListener('paste', (e) => {
      if (document.activeElement !== zone) return;
      const items = e.clipboardData?.items;
      if (!items) return;
      const files: File[] = [];
      for (const it of Array.from(items)) {
        if (it.kind === 'file') {
          const f = it.getAsFile();
          if (f && isImage(f)) files.push(f);
        }
      }
      if (files.length) {
        e.preventDefault();
        emit(files);
      }
    });
  }
</script>

<style>
  .tool-upload-zone {
    border: 1.5px dashed var(--color-hairline-strong);
    border-radius: var(--radius-lg);
    padding: var(--space-4xl) var(--space-xl);
    text-align: center;
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out-quart), background-color var(--dur-fast) var(--ease-out-quart);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    background-color: var(--color-canvas-soft);
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .tool-upload-zone:hover,
  .tool-upload-zone:focus-visible,
  .tool-upload-zone[data-dragover="true"] {
    border-color: var(--color-link);
    background-color: var(--color-canvas);
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .tool-upload-icon {
    color: var(--color-mute);
    margin-bottom: var(--space-xs);
  }

  .tool-upload-title {
    margin: 0;
  }

  .tool-upload-sub {
    color: var(--color-body);
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .tool-upload-link {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-link);
    cursor: pointer;
    font: inherit;
    font-size: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .tool-upload-link:hover {
    color: var(--color-link-deep);
  }

  .tool-upload-link:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }

  .tool-upload-divider {
    color: var(--color-hairline-strong);
  }

  .tool-upload-formats {
    color: var(--color-mute);
    margin: var(--space-sm) 0 0;
  }

  .tool-upload-errors {
    margin-top: var(--space-sm);
    padding: var(--space-md);
    background-color: var(--color-error-soft);
    border-radius: var(--radius-md);
  }

  .tool-upload-errors-label {
    color: var(--color-error-deep);
    margin: 0 0 var(--space-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .tool-upload-errors-list {
    list-style: none;
    margin: 0;
    padding: 0;
    color: var(--color-error-deep);
    font-size: var(--text-body-sm);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
</style>
