---
import ToolUpload from '../../components/tools/ToolUpload.astro';
import ToolSettingsPanel from '../../components/tools/ToolSettingsPanel.astro';
import { getTool } from '../../lib/tools';
import { useTranslations, type LangCode } from '../../i18n';

interface Props {
  lang?: LangCode;
}

const { lang = 'en' } = Astro.props;
const _ = useTranslations(lang);
const tool = getTool('rotator')!;
---
<section class="rotator-workflow stack stack-lg">
  <ToolUpload {tool} {lang} />

  <section class="rotator-preview-area" data-rotator-preview hidden>
    <figure class="rotator-preview-fig">
      <figcaption class="text-caption-mono rotator-preview-label">{_('rotator.original')}</figcaption>
      <div class="rotator-preview-frame">
        <img data-rotator-original-img alt={_('rotator.original')} class="rotator-preview-img" />
      </div>
      <p class="text-caption rotator-preview-size" data-rotator-original-size></p>
    </figure>
    <div class="rotator-preview-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </div>
    <figure class="rotator-preview-fig">
      <figcaption class="text-caption-mono rotator-preview-label" data-rotator-result-label data-i18n="rotator.preview">{_('rotator.preview')}</figcaption>
      <div class="rotator-preview-frame">
        <img data-rotator-result-img alt={_('rotator.preview')} class="rotator-preview-img" />
      </div>
      <p class="text-caption rotator-preview-size" data-rotator-result-size></p>
    </figure>
  </section>

  <ToolSettingsPanel {tool} {lang}>
    <div slot="settings-controls">
      <div class="rotator-controls">
        <fieldset class="rotator-presets">
          <legend class="text-caption-mono rotator-label">{_('rotator.rotate')}</legend>
          <div class="rotator-grid">
            {[
              { deg: 90, key: 'rotator.deg90cw', icon: 'cw' },
              { deg: 180, key: 'rotator.deg180', icon: '180' },
              { deg: 270, key: 'rotator.deg90ccw', icon: 'ccw' },
              { deg: -90, key: 'rotator.flipH', icon: 'flip-h' },
              { deg: -180, key: 'rotator.flipV', icon: 'flip-v' },
            ].map((btn) => (
              <button type="button" class="rotator-btn" data-rotator-preset={btn.deg} data-i18n={btn.key} aria-label={_(btn.key)}>
                {btn.icon === 'cw' && <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>}
                {btn.icon === '180' && <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="21"/><polyline points="5 14 12 21 19 14"/></svg>}
                {btn.icon === 'ccw' && <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.12-9.36L1 10"/></svg>}
                {btn.icon === 'flip-h' && <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"/><path d="M12 3v18"/><path d="M3 12h18"/></svg>}
                {btn.icon === 'flip-v' && <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"/><path d="M3 12h18"/></svg>}
                <span class="rotator-btn-label">{_(btn.key)}</span>
              </button>
            ))}
          </div>
        </fieldset>
        <label class="rotator-custom">
          <span class="text-caption-mono rotator-label">{_('rotator.customAngle')}</span>
          <input type="number" class="rotator-input" data-rotator-custom min="-360" max="360" value="0" step="1" />
          <span class="text-caption rotator-unit">{_('rotator.degrees')}</span>
        </label>
      </div>
    </div>
  </ToolSettingsPanel>

  <section class="rotator-download" data-rotator-download hidden>
    <div class="rotator-download-bar">
      <div class="rotator-download-info" data-rotator-download-info>
        <p class="text-caption-mono rotator-download-label">{_('rotator.result')}</p>
        <p class="text-body-sm-strong" data-rotator-download-name></p>
      </div>
      <button type="button" class="results-btn results-btn-primary" data-rotator-download-btn>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        {_('rotator.download')}
      </button>
    </div>
  </section>
</section>

<script>
  const resultLabel = document.querySelector<HTMLElement>('[data-rotator-result-label]');
  const origSize = document.querySelector<HTMLElement>('[data-rotator-original-size]');
  const resultSize = document.querySelector<HTMLElement>('[data-rotator-result-size]');
  const presetBtns = document.querySelectorAll<HTMLButtonElement>('[data-rotator-preset]');
  const customInput = document.querySelector<HTMLInputElement>('[data-rotator-custom]');
  const previewArea = document.querySelector<HTMLElement>('[data-rotator-preview]');
  const origImg = document.querySelector<HTMLImageElement>('[data-rotator-original-img]');
  const resultImg = document.querySelector<HTMLImageElement>('[data-rotator-result-img]');
  const downloadSection = document.querySelector<HTMLElement>('[data-rotator-download]');
  const downloadBtn = document.querySelector<HTMLButtonElement>('[data-rotator-download-btn]');
  const downloadNameEl = document.querySelector<HTMLElement>('[data-rotator-download-name]');

  const i18n = (key: string): string => {
    const el = document.querySelector<HTMLElement>(`[data-i18n="${key}"]`);
    return el?.textContent ?? key;
  };

  let currentFile: File | null = null;
  let currentImg: HTMLImageElement | null = null;
  let currentBlobUrl: string | null = null;
  let transformCount = 0;

  const formatBytes = (bytes: number): string => {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  };

  const dataUrlToBlob = (dataUrl: string): Blob => {
    const parts = dataUrl.split(',');
    const mime = parts[0].match(/:(.*?);/)![1];
    const bytes = atob(parts[1]);
    const arr = new Uint8Array(bytes.length);
    for (let i = 0; i < bytes.length; i++) arr[i] = bytes.charCodeAt(i);
    return new Blob([arr], { type: mime });
  };

  const transformOne = (img: HTMLImageElement, transform: number): { blob: Blob; width: number; height: number } => {
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d')!;
    const w = img.width;
    const h = img.height;
    if (transform === -90) {
      canvas.width = w; canvas.height = h;
      ctx.translate(w, 0); ctx.scale(-1, 1);
      ctx.drawImage(img, 0, 0);
    } else if (transform === -180) {
      canvas.width = w; canvas.height = h;
      ctx.translate(0, h); ctx.scale(1, -1);
      ctx.drawImage(img, 0, 0);
    } else if (transform === 0) {
      canvas.width = w; canvas.height = h;
      ctx.drawImage(img, 0, 0);
    } else {
      const rad = (transform * Math.PI) / 180;
      const sin = Math.abs(Math.sin(rad));
      const cos = Math.abs(Math.cos(rad));
      canvas.width = Math.round(w * cos + h * sin);
      canvas.height = Math.round(w * sin + h * cos);
      ctx.translate(canvas.width / 2, canvas.height / 2);
      ctx.rotate(rad);
      ctx.drawImage(img, -w / 2, -h / 2);
    }
    return { blob: dataUrlToBlob(canvas.toDataURL('image/png')), width: canvas.width, height: canvas.height };
  };

  const loadBlob = (blob: Blob): Promise<HTMLImageElement> =>
    new Promise((resolve) => {
      const img = new Image();
      img.onload = () => resolve(img);
      img.src = URL.createObjectURL(blob);
    });

  const applyAndShow = async (transform: number) => {
    if (!currentImg) return;
    const result = transformOne(currentImg, transform);
    if (currentBlobUrl) URL.revokeObjectURL(currentBlobUrl);
    currentBlobUrl = URL.createObjectURL(result.blob);
    if (resultImg) resultImg.src = currentBlobUrl;
    if (resultSize) resultSize.textContent = `${result.width} × ${result.height} · ${formatBytes(result.blob.size)}`;
    if (downloadSection) downloadSection.hidden = false;
    const nextImg = await loadBlob(result.blob);
    nextImg.width = result.width;
    nextImg.height = result.height;
    currentImg = nextImg;
    transformCount++;
    if (resultLabel) {
      const flipHLabel = i18n('rotator.flipH');
      const flipVLabel = i18n('rotator.flipV');
      const name = transform === -90 ? flipHLabel : transform === -180 ? flipVLabel : `${i18n('rotator.rotate')} ${transform}°`;
      resultLabel.textContent = `Step ${transformCount}: ${name}`;
    }
    if (downloadNameEl && currentFile) {
      downloadNameEl.textContent = currentFile.name.replace(/\.[^.]+$/, '') + '_edited.' + (currentFile.name.split('.').pop() || 'jpg');
    }
  };

  presetBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const deg = Number(btn.dataset.rotatorPreset);
      presetBtns.forEach((b) => b.dataset.active = String(b === btn));
      if (customInput) customInput.value = '0';
      applyAndShow(deg);
    });
  });

  if (customInput) {
    customInput.addEventListener('input', () => {
      presetBtns.forEach((b) => b.dataset.active = 'false');
      applyAndShow(Number(customInput.value) || 0);
    });
  }

  if (downloadBtn) {
    downloadBtn.addEventListener('click', () => {
      if (!currentFile || !currentBlobUrl) return;
      const name = currentFile.name.replace(/\.[^.]+$/, '') + '_edited.' + (currentFile.name.split('.').pop() || 'jpg');
      const a = document.createElement('a');
      a.href = currentBlobUrl;
      a.download = name;
      a.click();
    });
  }

  const onFilesReceived = async (files: File[]) => {
    if (!files.length) return;
    const file = files[0];
    currentFile = file;
    transformCount = 0;
    const origUrl = URL.createObjectURL(file);
    const img = new Image();
    await new Promise<void>((resolve, reject) => {
      img.onload = () => resolve();
      img.onerror = () => reject(new Error('Failed to load'));
      img.src = origUrl;
    });
    currentImg = img;
    if (origImg) origImg.src = origUrl;
    if (origSize) origSize.textContent = `${img.width} × ${img.height} · ${formatBytes(file.size)}`;
    if (previewArea) previewArea.hidden = false;
    if (resultImg) resultImg.src = origUrl;
    if (resultSize) resultSize.textContent = `${img.width} × ${img.height} · ${formatBytes(file.size)}`;
    if (resultLabel) resultLabel.textContent = i18n('rotator.original');
    if (downloadSection) downloadSection.hidden = true;
  };

  window.addEventListener('toolboximage:files', async (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail?.files?.length) onFilesReceived(detail.files);
  });

  (async () => {
    const { retrieveFiles } = await import('../../lib/file-transfer');
    const files = await retrieveFiles();
    if (files.length) onFilesReceived(files);
  })();
</script>

<style>
  .rotator-workflow { display: flex; flex-direction: column; gap: var(--space-2xl); }
  .rotator-controls { display: flex; flex-direction: column; gap: var(--space-lg); }
  .rotator-presets { border: none; margin: 0; padding: 0; }
  .rotator-label { color: var(--color-mute); margin: 0 0 var(--space-sm); display: block; }
  .rotator-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: var(--space-xs); }
  .rotator-btn { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: var(--space-sm) var(--space-xs); border-radius: var(--radius-md); border: 1px solid var(--color-hairline); background: var(--color-canvas); color: var(--color-ink); cursor: pointer; transition: background 0.15s ease, border-color 0.15s ease; }
  .rotator-btn:hover { background: var(--color-canvas-soft); border-color: var(--color-hairline-strong); }
  .rotator-btn:focus-visible { outline: none; box-shadow: var(--focus-ring-tight); }
  .rotator-btn[data-active="true"] { border-color: var(--color-link); background: color-mix(in srgb, var(--color-link) 10%, transparent); }
  .rotator-btn-label { font-size: 11px; line-height: 1; color: var(--color-body); }
  .rotator-custom { display: flex; align-items: center; gap: var(--space-sm); }
  .rotator-input { width: 80px; padding: var(--space-xs) var(--space-sm); border-radius: var(--radius-md); border: 1px solid var(--color-hairline); background: var(--color-canvas); color: var(--color-ink); font-size: var(--text-body-sm); font-family: var(--font-mono); text-align: center; }
  .rotator-input:focus { outline: none; border-color: var(--color-link); box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-link) 20%, transparent); }
  .rotator-unit { color: var(--color-mute); }
  .rotator-preview-area { display: flex; align-items: center; gap: var(--space-md); padding: var(--space-lg); background: var(--color-canvas); border-radius: var(--radius-lg); box-shadow: var(--shadow-2); }
  .rotator-preview-fig { margin: 0; flex: 1; min-width: 0; display: flex; flex-direction: column; gap: var(--space-xs); }
  .rotator-preview-label { color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.06em; }
  .rotator-preview-frame { position: relative; width: 100%; min-height: 200px; display: flex; align-items: center; justify-content: center; background: repeating-conic-gradient(var(--color-hairline) 0% 25%, transparent 0% 50%) 0 0 / 16px 16px; border-radius: var(--radius-sm); overflow: hidden; }
  .rotator-preview-img { max-width: 100%; max-height: 320px; object-fit: contain; display: block; }
  .rotator-preview-size { margin: 0; color: var(--color-body); }
  .rotator-preview-arrow { flex-shrink: 0; color: var(--color-mute); }
  .rotator-download { background: var(--color-canvas); border-radius: var(--radius-lg); box-shadow: var(--shadow-2); overflow: hidden; }
  .rotator-download-bar { display: flex; align-items: center; justify-content: space-between; gap: var(--space-md); padding: var(--space-lg); }
  .rotator-download-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .rotator-download-label { color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.06em; }
  .rotator-download .results-btn { appearance: none; display: inline-flex; align-items: center; gap: var(--space-xs); height: 40px; padding: 0 var(--space-md); border-radius: var(--radius-pill); border: 1px solid transparent; cursor: pointer; font-family: inherit; font-size: var(--text-body-sm); font-weight: var(--weight-medium); transition: background-color var(--dur-fast) var(--ease-out-quart), color var(--dur-fast) var(--ease-out-quart); white-space: nowrap; -webkit-tap-highlight-color: transparent; }
  .rotator-download .results-btn:focus-visible { outline: none; box-shadow: var(--focus-ring-tight); }
  .rotator-download .results-btn-primary { background-color: var(--color-primary); color: var(--color-on-primary); }
  .rotator-download .results-btn-primary:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 6px 16px -6px rgb(0 0 0 / 0.28); }
  @media (max-width: 600px) {
    .rotator-grid { grid-template-columns: repeat(3, 1fr); }
    .rotator-preview-area { flex-direction: column; }
    .rotator-preview-arrow { transform: rotate(90deg); }
  }
</style>
