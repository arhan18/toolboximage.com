---
/**
 * ResultsSummary — aggregate stats + bulk download bar.
 * Markup only — wired by the page-level script.
 */
---

<section class="results-summary" data-results-summary hidden aria-label="Results summary">
  <div class="results-header">
    <div class="results-title-block">
      <p class="text-caption-mono results-eyebrow">
        <span class="results-eyebrow-dot" aria-hidden="true"></span>
        Done
      </p>
      <h2 class="text-display-sm results-title">Your images are ready.</h2>
    </div>
    <div class="results-actions">
      <button type="button" class="results-btn results-btn-secondary" data-action="download-all">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download all (.zip)
      </button>
      <button type="button" class="results-btn results-btn-primary" data-action="download-one" data-download-first="1">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download
      </button>
    </div>
  </div>

  <div class="results-stats" data-results-stats>
    <div class="result-stat">
      <span class="result-stat-label text-caption-mono">Original</span>
      <span class="result-stat-value text-display-md" data-result-stat="original">0 B</span>
    </div>
    <div class="result-stat result-stat-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </div>
    <div class="result-stat result-stat-accent">
      <span class="result-stat-label text-caption-mono">New</span>
      <span class="result-stat-value text-display-md" data-result-stat="new">0 B</span>
    </div>
    <div class="result-stat result-stat-saved">
      <span class="result-stat-label text-caption-mono">Saved</span>
      <span class="result-stat-value text-display-md" data-result-stat="saved">0 B</span>
      <span class="result-stat-sub text-caption" data-result-stat="saved-pct">−0%</span>
    </div>
    <div class="result-stat">
      <span class="result-stat-label text-caption-mono">Ratio</span>
      <span class="result-stat-value text-display-md" data-result-stat="ratio">1.00×</span>
    </div>
  </div>

  <!-- Before/After demo on the first completed image. -->
  <div class="results-ba" data-results-ba hidden>
    <div class="results-ba-head">
      <p class="text-caption-mono results-ba-eyebrow">Spot check</p>
      <p class="text-body-sm results-ba-copy">
        Drag the divider or switch to side-by-side / zoom to compare the first image.
      </p>
    </div>
    <div data-ba-mount></div>
  </div>
</section>

<style>
  .results-summary {
    margin-top: var(--space-md);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-3);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    animation: results-rise 0.6s var(--ease-out-quart);
  }

  @keyframes results-rise {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .results-summary { animation: none; }
  }

  .results-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .results-title-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .results-eyebrow {
    color: var(--color-cyan-deep);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    font-weight: var(--weight-medium);
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .results-eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background-color: var(--color-cyan-deep);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-cyan-deep) 25%, transparent);
    animation: results-dot-pulse 1.6s var(--ease-in-out-soft) infinite;
  }

  @keyframes results-dot-pulse {
    0%, 100% {
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-cyan-deep) 25%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-cyan-deep) 8%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .results-eyebrow-dot { animation: none; }
  }

  .results-title {
    margin: 0;
  }

  .results-actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .results-btn {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    height: 40px;
    padding: 0 var(--space-md);
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    cursor: pointer;
    font-family: inherit;
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart),
      box-shadow var(--dur-fast) var(--ease-out-quart);
    white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
  }

  .results-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  .results-btn:active:not(:disabled) {
    transform: scale(0.985);
  }

  .results-btn-primary {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .results-btn-primary:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px -6px rgb(0 0 0 / 0.28);
  }

  .results-btn-secondary {
    background-color: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: inset 0 0 0 1px var(--color-hairline);
  }

  .results-btn-secondary:hover:not(:disabled) {
    background-color: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }

  .results-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .results-stats {
    display: grid;
    grid-template-columns: 1fr auto 1fr 1fr 1fr;
    gap: var(--space-lg);
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
  }

  .result-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .result-stat-label {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--weight-medium);
  }

  .result-stat-value {
    color: var(--color-ink);
    font-feature-settings: var(--tnum);
    line-height: 1.1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color var(--dur-base) var(--ease-out-quart);
  }

  .result-stat-accent .result-stat-value {
    color: var(--color-cyan-deep);
  }

  .result-stat-saved .result-stat-value {
    color: var(--color-success);
  }

  [data-theme="dark"] .result-stat-saved .result-stat-value {
    color: var(--color-cyan);
  }

  .result-stat-sub {
    color: var(--color-cyan-deep);
    font-feature-settings: var(--tnum);
  }

  .result-stat-arrow {
    color: var(--color-mute);
    align-self: center;
  }

  .results-ba {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-hairline);
  }

  .results-ba-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .results-ba-eyebrow {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    font-weight: var(--weight-medium);
  }

  .results-ba-copy {
    color: var(--color-body);
    max-width: 48ch;
    margin: 0;
  }

  @media (max-width: 600px) {
    .results-header {
      flex-direction: column;
    }

    .results-actions {
      width: 100%;
    }

    .results-btn {
      flex: 1;
      justify-content: center;
    }

    .results-stats {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
    }

    .result-stat-arrow {
      display: none;
    }
  }
</style>
</content>
</invoke>