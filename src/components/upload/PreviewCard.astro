---
/**
 * PreviewCard — single upload preview tile.
 * Renders empty markup; the queue script in /compressor attaches behavior.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<template id="tpl-preview-card" data-preview-card-template>
  <article class="preview-card" data-preview-card tabindex="0">
    <div class="preview-thumb" aria-hidden="true">
      <img alt="" />
      <span class="preview-status" data-preview-status>
        <svg class="preview-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9" opacity="0.2"/>
          <path d="M21 12a9 9 0 0 1-9 9"/>
        </svg>
      </span>
    </div>
    <div class="preview-meta">
      <p class="preview-name" data-preview-name></p>
      <p class="preview-sub text-caption">
        <span data-preview-size></span>
        <span class="preview-dot" aria-hidden="true">·</span>
        <span data-preview-dims></span>
      </p>
      <p class="preview-error text-caption" data-preview-error hidden></p>
    </div>
    <div class="preview-actions">
      <button type="button" class="preview-action" data-action="up" aria-label="Move up">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
      </button>
      <button type="button" class="preview-action" data-action="down" aria-label="Move down">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <button type="button" class="preview-action preview-action-remove" data-action="remove" aria-label="Remove from queue">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </article>
</template>

<style>
  .preview-card {
    position: relative;
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: var(--space-md);
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-canvas);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-2);
    transition: box-shadow 0.2s ease, transform 0.15s ease, opacity 0.2s ease;
  }

  .preview-card[data-dragging="true"] {
    opacity: 0.5;
    box-shadow: var(--shadow-4);
    transform: scale(1.01);
  }

  .preview-card[data-status="error"] {
    box-shadow: var(--shadow-2), 0 0 0 1px var(--color-error);
  }

  .preview-card:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }

  .preview-thumb {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background-color: var(--color-canvas-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-mute);
  }

  .preview-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .preview-status {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgb(255 255 255 / 0.6);
    backdrop-filter: blur(2px);
    color: var(--color-ink);
  }

  [data-theme="dark"] .preview-status {
    background-color: rgb(0 0 0 / 0.5);
  }

  .preview-card[data-status="ready"] .preview-status,
  .preview-card[data-status="error"] .preview-status {
    display: none;
  }

  .preview-card[data-status="error"] .preview-thumb::after {
    content: '!';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-error);
    font-family: var(--font-mono);
    font-size: 24px;
    font-weight: var(--weight-semibold);
  }

  .preview-card[data-status="error"] .preview-thumb img {
    opacity: 0.2;
  }

  .preview-spinner {
    animation: preview-spin 0.8s linear infinite;
    color: var(--color-ink);
  }

  @keyframes preview-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .preview-spinner { animation: none; }
  }

  .preview-meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .preview-name {
    margin: 0;
    color: var(--color-ink);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-body-sm);
    letter-spacing: var(--tracking-body-sm);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .preview-sub {
    color: var(--color-mute);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin: 0;
  }

  .preview-dot {
    color: var(--color-hairline-strong);
  }

  .preview-error {
    color: var(--color-error-deep);
    margin: 0;
  }

  .preview-card[data-status="error"] .preview-error {
    display: block;
  }

  .preview-card[data-status="error"] .preview-sub {
    display: none;
  }

  .preview-actions {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .preview-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .preview-action:hover {
    background-color: var(--color-canvas-soft);
    color: var(--color-ink);
    border-color: var(--color-hairline);
  }

  .preview-action:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }

  .preview-action:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .preview-action-remove:hover {
    background-color: var(--color-error-soft);
    border-color: transparent;
    color: var(--color-error-deep);
  }

  @media (max-width: 600px) {
    .preview-card {
      grid-template-columns: 56px 1fr;
      grid-template-rows: auto auto;
      gap: var(--space-sm) var(--space-md);
      padding: var(--space-sm);
    }

    .preview-thumb {
      width: 56px;
      height: 56px;
      grid-row: span 2;
    }

    .preview-actions {
      grid-column: 2;
      justify-content: flex-end;
    }
  }
</style>