---
/**
 * PreviewCard — single upload preview tile.
 * Renders empty markup; the queue script in /compressor attaches behavior.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<template id="tpl-preview-card" data-preview-card-template>
  <article class="preview-card" data-preview-card tabindex="0">
    <div class="preview-thumb" aria-hidden="true">
      <img alt="" loading="lazy" decoding="async" />
      <span class="preview-status" data-preview-status>
        <svg class="preview-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9" opacity="0.2"/>
          <path d="M21 12a9 9 0 0 1-9 9"/>
        </svg>
      </span>
      <span class="preview-thumb-done" data-preview-done hidden>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </span>
    </div>

    <div class="preview-body">
      <div class="preview-row">
        <div class="preview-meta">
          <p class="preview-name" data-preview-name></p>
          <p class="preview-sub text-caption">
            <span data-preview-size></span>
            <span class="preview-dot" aria-hidden="true">·</span>
            <span data-preview-dims></span>
          </p>
          <p class="preview-error text-caption" data-preview-error hidden></p>
        </div>
        <div class="preview-actions">
          <button type="button" class="preview-action" data-action="up" aria-label="Move up" title="Move up">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
          </button>
          <button type="button" class="preview-action" data-action="down" aria-label="Move down" title="Move down">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <button type="button" class="preview-action" data-action="retry" aria-label="Retry compression" title="Retry" hidden>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          </button>
          <button type="button" class="preview-action" data-action="download" aria-label="Download compressed file" title="Download" hidden>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </button>
          <button type="button" class="preview-action preview-action-remove" data-action="remove" aria-label="Remove from queue" title="Remove">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>

      <div class="preview-progress" data-preview-progress hidden>
        <div class="preview-progress-bar" data-preview-progress-bar></div>
      </div>

      <!-- Per-item statistics — visible once job is done -->
      <div class="preview-stats" data-preview-stats hidden>
        <div class="preview-stat">
          <span class="preview-stat-label text-caption-mono">Original</span>
          <span class="preview-stat-value" data-stat="original">—</span>
        </div>
        <div class="preview-stat preview-stat-accent">
          <span class="preview-stat-label text-caption-mono">New</span>
          <span class="preview-stat-value" data-stat="new">—</span>
        </div>
        <div class="preview-stat">
          <span class="preview-stat-label text-caption-mono">Saved</span>
          <span class="preview-stat-value preview-stat-saved" data-stat="saved">—</span>
        </div>
        <div class="preview-stat">
          <span class="preview-stat-label text-caption-mono">Ratio</span>
          <span class="preview-stat-value" data-stat="ratio">—</span>
        </div>
        <div class="preview-stat">
          <span class="preview-stat-label text-caption-mono">Dimensions</span>
          <span class="preview-stat-value" data-stat="dims">—</span>
        </div>
        <p class="preview-note text-caption" data-stat="note" hidden></p>
      </div>
    </div>
  </article>
</template>

<style>
  .preview-card {
    position: relative;
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-2);
    transition:
      box-shadow var(--dur-base) var(--ease-out-quart),
      transform var(--dur-base) var(--ease-out-quart),
      border-color var(--dur-base) var(--ease-out-quart),
      opacity var(--dur-base) var(--ease-out-quart);
  }

  .preview-card:hover {
    border-color: var(--color-hairline-strong);
    box-shadow: var(--shadow-3);
  }

  .preview-card[data-dragging="true"] {
    opacity: 0.5;
    box-shadow: var(--shadow-4);
    transform: scale(1.01);
  }

  .preview-card[data-job-status="error"] {
    border-color: color-mix(in srgb, var(--color-error) 40%, var(--color-hairline));
  }

  .preview-card[data-job-status="done"] {
    border-color: color-mix(in srgb, var(--color-cyan-deep) 45%, var(--color-hairline));
  }

  .preview-card[data-job-status="running"] {
    border-color: color-mix(in srgb, var(--color-link) 30%, var(--color-hairline));
  }

  .preview-card:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
    border-color: var(--color-link);
  }

  .preview-thumb {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background-color: var(--color-canvas-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-mute);
    grid-row: span 2;
    box-shadow: var(--shadow-1);
  }

  .preview-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease-out-quart);
  }

  .preview-card:hover .preview-thumb img {
    transform: scale(1.04);
  }

  .preview-status {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgb(255 255 255 / 0.6);
    backdrop-filter: blur(2px);
    color: var(--color-ink);
  }

  [data-theme="dark"] .preview-status {
    background-color: rgb(0 0 0 / 0.5);
  }

  .preview-card[data-status="ready"] .preview-status,
  .preview-card[data-status="error"] .preview-status {
    display: none;
  }

  .preview-card[data-status="error"] .preview-thumb::after {
    content: '!';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-error);
    font-family: var(--font-mono);
    font-size: 24px;
    font-weight: var(--weight-semibold);
  }

  .preview-card[data-status="error"] .preview-thumb img {
    opacity: 0.2;
  }

  .preview-spinner {
    animation: preview-spin 0.8s linear infinite;
    color: var(--color-ink);
  }

  @keyframes preview-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .preview-spinner { animation: none; }
  }

  /* Success tick on thumbnail after job completes. */
  .preview-thumb-done {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-full);
    background-color: var(--color-cyan-deep);
    color: var(--color-on-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-2);
    animation: preview-done-pop 0.4s var(--ease-spring);
  }

  @keyframes preview-done-pop {
    from { opacity: 0; transform: scale(0.4) rotate(-30deg); }
    to { opacity: 1; transform: scale(1) rotate(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .preview-thumb-done { animation: none; }
  }

  .preview-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .preview-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .preview-meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .preview-name {
    margin: 0;
    color: var(--color-ink);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-body-sm);
    letter-spacing: var(--tracking-body-sm);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .preview-sub {
    color: var(--color-mute);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin: 0;
    font-feature-settings: var(--tnum);
  }

  .preview-dot { color: var(--color-hairline-strong); }

  .preview-error {
    color: var(--color-error-deep);
    margin: 0;
  }

  .preview-card[data-status="error"] .preview-error { display: block; }
  .preview-card[data-status="error"] .preview-sub { display: none; }

  .preview-actions {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    opacity: 0;
    transform: translateX(4px);
    transition:
      opacity var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart);
  }

  .preview-card:hover .preview-actions,
  .preview-card:focus-within .preview-actions,
  .preview-card[data-job-status="done"] .preview-actions,
  .preview-card[data-job-status="error"] .preview-actions {
    opacity: 1;
    transform: translateX(0);
  }

  .preview-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    background: transparent;
    color: var(--color-mute);
    cursor: pointer;
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart);
    -webkit-tap-highlight-color: transparent;
  }

  .preview-action:hover {
    background-color: var(--color-canvas-soft);
    color: var(--color-ink);
    border-color: var(--color-hairline);
  }

  .preview-action:active:not(:disabled) {
    transform: scale(0.94);
  }

  .preview-action:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  .preview-action:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .preview-action-remove:hover {
    background-color: var(--color-error-soft);
    border-color: transparent;
    color: var(--color-error-deep);
  }

  .preview-action[data-action="download"] {
    color: var(--color-cyan-deep);
  }

  .preview-action[data-action="download"]:hover {
    background-color: color-mix(in srgb, var(--color-cyan) 14%, transparent);
    color: var(--color-cyan-deep);
    border-color: color-mix(in srgb, var(--color-cyan-deep) 30%, transparent);
  }

  /* Progress bar */
  .preview-progress {
    height: 4px;
    width: 100%;
    background-color: var(--color-canvas-soft);
    border-radius: var(--radius-full);
    overflow: hidden;
    position: relative;
  }

  .preview-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--gradient-develop-start), var(--gradient-preview-end));
    background-size: 200% 100%;
    border-radius: inherit;
    transition: width 0.3s var(--ease-out-quart);
    animation: progress-shimmer 2s linear infinite;
  }

  .preview-card[data-job-status="done"] .preview-progress-bar {
    background: linear-gradient(90deg, var(--color-cyan-deep), var(--color-cyan));
    animation: none;
  }

  .preview-card[data-job-status="error"] .preview-progress-bar {
    background: var(--color-error);
    animation: none;
  }

  @keyframes progress-shimmer {
    0% { background-position: 0% 0; }
    100% { background-position: 200% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .preview-progress-bar,
    .preview-thumb-done { animation: none; }
  }

  /* ---------- Per-item statistics ---------- */
  .preview-stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-sm) var(--space-md);
    padding-top: var(--space-xs);
    border-top: 1px dashed var(--color-hairline);
    margin-top: var(--space-xxs);
    animation: preview-stats-in 0.36s var(--ease-out-quart);
  }

  @keyframes preview-stats-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .preview-stats { animation: none; }
  }

  .preview-card:not([data-job-status="done"]) .preview-stats {
    display: none;
  }

  .preview-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .preview-stat-label {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 10px;
    font-weight: var(--weight-medium);
  }

  .preview-stat-value {
    color: var(--color-ink);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-semibold);
    line-height: 1.2;
    font-feature-settings: var(--tnum);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .preview-stat-accent .preview-stat-value {
    color: var(--color-cyan-deep);
  }

  .preview-stat-saved {
    color: var(--color-success);
  }

  [data-theme="dark"] .preview-stat-saved {
    color: var(--color-cyan);
  }

  .preview-note {
    grid-column: 1 / -1;
    color: var(--color-mute);
    margin: 0;
    padding-top: var(--space-xxs);
    font-style: italic;
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .preview-card {
      grid-template-columns: 56px 1fr;
      padding: var(--space-sm);
    }

    .preview-thumb {
      width: 56px;
      height: 56px;
    }

    .preview-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
</content>
</invoke>