---
/**
 * Logo — wordmark + monogram. Use everywhere the brand is shown.
 * The monogram is the "T·I" mark in a rounded square.
 */
interface Props {
  href?: string;
  /** Display the wordmark next to the monogram. */
  showWordmark?: boolean;
  /** Monogram edge length in px. */
  size?: 20 | 24 | 28 | 32;
  class?: string;
}

const {
  href = '/',
  showWordmark = true,
  size = 24,
  class: className = '',
} = Astro.props;
---

<a href={href} class:list={['logo', className]} aria-label="ToolBox Image — Home">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    class="logo-mark"
  >
    <rect x="3" y="3" width="18" height="18" rx="5" />
    <path d="M7.5 8.5h2.2l1.6 2.6 1.6-2.6h2.2v7h-2v-4.5L11.3 14l-1.8-2.5V15.5h-2z" />
  </svg>
  {showWordmark && <span class="logo-text text-body-sm-strong">ToolBox Image</span>}
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-ink);
    text-decoration: none;
    transition:
      opacity var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart);
    border-radius: var(--radius-sm);
    padding: 2px;
    margin: -2px;
  }

  .logo:hover {
    opacity: 1;
  }

  .logo-mark {
    flex-shrink: 0;
    transition: transform var(--dur-slow) var(--ease-spring);
  }

  .logo:hover .logo-mark {
    transform: rotate(-10deg) scale(1.06);
  }

  .logo-text {
    white-space: nowrap;
    letter-spacing: -0.01em;
    transition: color var(--dur-fast) var(--ease-out-quart);
  }

  .logo:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  @media (prefers-reduced-motion: reduce) {
    .logo, .logo-mark { transition: none; }
  }
</style>
</content>
</invoke>