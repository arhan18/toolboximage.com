const d = dataMap[variant];
const appSchema = softwareAppSchema({
  name: `ToolBox Image — ${d.label}`,
  description: d.description,
  url: `${SITE_URL}${d.slug}`,
});
const breadcrumb = breadcrumbSchema(d.breadcrumbs);
const faq = faqSchema(d.faqs);
const howTo = howToSchema(d.howToSteps);
const path = `/${lang === 'en' ? '' : lang + '/'}${d.slug}/`;
---

<section class="band band-canvas" id="seo-content">
  <div class="container stack stack-3xl">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="seo-breadcrumb">
      <ol class="seo-breadcrumb-list">
        {d.breadcrumbs.map((item) => (
          <li class="seo-breadcrumb-item">
            {item.href === path ? (
              <span aria-current="page">{item.name}</span>
            ) : (
              <a href={item.href}>{item.name}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Main SEO Content -->
    <Prose>
      <h2>{d.h1}</h2>
      {d.overview.map((p) => <p>{p}</p>)}

      <h3>Key features</h3>
      <ul>
        {d.features.map((f) => <li><strong>{f}</strong></li>)}
      </ul>

      <h3>How to {d.label.toLowerCase()} — step by step</h3>
      <ol>
        {d.howToSteps.map((s, i) => (
          <li><strong>{s.name}:</strong> {s.text}</li>
        ))}
      </ol>

      <h3>Common use cases</h3>
      <p>
        Whether you are a photographer, web developer, e-commerce manager, or social media
        creator, optimizing images before publishing saves bandwidth, improves page load times,
        and ensures compatibility with platform-specific requirements. Our browser-based
        compressor works with all major image formats and processes everything locally for
        maximum privacy.
      </p>
      <p>
        Need to convert images between formats? Try our <a href={`${base}tools/converter/`}>Image Converter</a>.
        To resize images for any platform, use the <a href={`${base}tools/resizer/`}>Image Resizer</a>.
        For rotation and flipping, check the <a href={`${base}tools/rotator/`}>Image Rotator</a>.
      </p>
    </Prose>

    <!-- FAQ -->
    <section class="seo-faq">
      <SectionHeader eyebrow={d.label}>
        <h2 class="text-display-lg">Frequently Asked Questions</h2>
      </SectionHeader>
      <FAQ items={d.faqs} />
    </section>

    <!-- Related Tools -->
    <aside class="seo-related">
      <SectionHeader eyebrow="Related Tools">
        <h2 class="text-display-lg">More Image Tools</h2>
      </SectionHeader>
      <div class="seo-related-grid">
        <a href={`${base}compressor/`} class="seo-related-card">
          <strong>Image Compressor</strong>
          <span>Compress all image formats</span>
        </a>
        <a href={`${base}tools/converter/`} class="seo-related-card">
          <strong>Image Converter</strong>
          <span>Convert between image formats</span>
        </a>
        <a href={`${base}tools/resizer/`} class="seo-related-card">
          <strong>Image Resizer</strong>
          <span>Resize images for any platform</span>
        </a>
        <a href={`${base}tools/rotator/`} class="seo-related-card">
          <strong>Rotate Image</strong>
          <span>Rotate and flip images</span>
        </a>
        <a href={`${base}bulk-image-compressor/`} class="seo-related-card">
          <strong>Bulk Compressor</strong>
          <span>Compress hundreds at once</span>
        </a>
      </div>
    </aside>
  </div>
</section>

<!-- JSON-LD Structured Data -->
<Fragment set:html={renderJsonLd(faq, breadcrumb, appSchema, howTo as Record<string, unknown>)} />

<style>
  .band { position: relative; padding: var(--space-5xl) 0; }
  .band-canvas { background-color: var(--color-canvas); }
  .container { max-width: 720px; margin: 0 auto; padding: 0 var(--space-lg); }

  .seo-breadcrumb { margin-bottom: 0; }
  .seo-breadcrumb-list {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-xs);
    list-style: none; margin: 0; padding: 0;
    font-size: var(--text-body-sm); color: var(--color-mute);
  }
  .seo-breadcrumb-item + .seo-breadcrumb-item::before {
    content: '/'; margin-right: var(--space-xs); color: var(--color-hairline-strong);
  }
  .seo-breadcrumb-item a { color: var(--color-link); text-decoration: none; }
  .seo-breadcrumb-item a:hover { text-decoration: underline; }
  .seo-breadcrumb-item [aria-current="page"] { color: var(--color-body); }

  .seo-faq { display: flex; flex-direction: column; gap: var(--space-lg); }

  .seo-related { display: flex; flex-direction: column; gap: var(--space-lg); }
  .seo-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  .seo-related-card {
    display: flex; flex-direction: column; gap: var(--space-xs);
    padding: var(--space-lg);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: transform var(--dur-base) var(--ease-out-quart), box-shadow var(--dur-base) var(--ease-out-quart);
  }
  .seo-related-card:hover {
    transform: translateY(-2px); box-shadow: var(--shadow-2);
  }
  .seo-related-card strong { color: var(--color-ink); font-size: var(--text-body-md); }
  .seo-related-card span { color: var(--color-body); font-size: var(--text-body-sm); }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
    .seo-related-grid { grid-template-columns: 1fr; }
  }
</style>
