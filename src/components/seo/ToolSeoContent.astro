---
/**
 * ToolSeoContent — SEO content section with overview, features,
 * step-by-step guide, use cases, FAQ, and JSON-LD structured data
 * (FAQ, Breadcrumb, SoftwareApplication, HowTo).
 * Renders below the interactive tool on tool pages.
 */
import Prose from '../shared/Prose.astro';
import SectionHeader from '../shared/SectionHeader.astro';
import FAQ from '../shared/FAQ.astro';
import {
  SITE_URL, faqSchema, breadcrumbSchema,
  softwareAppSchema, howToSchema, renderJsonLd,
} from '../../lib/seo';
import { useTranslations, type LangCode } from '../../i18n';

interface Props {
  toolId: 'converter' | 'resizer' | 'rotator' | 'cropper' | 'watermark' | 'metadata' | 'passport' | 'heic-converter' | 'signature' | 'image-to-pdf';
  lang?: string;
}

const { toolId, lang = 'en' } = Astro.props;
const _ = useTranslations(lang as LangCode);

const isConverter = toolId === 'converter';
const isResizer = toolId === 'resizer';
const isRotator = toolId === 'rotator';
const isCropper = toolId === 'cropper';
const isWatermark = toolId === 'watermark';
const isMetadata = toolId === 'metadata';
const isPassport = toolId === 'passport';
const isHeicConverter = toolId === 'heic-converter';
const isSignature = toolId === 'signature';
const isImageToPdf = toolId === 'image-to-pdf';

const toolName = isConverter ? 'Image Converter' : isResizer ? 'Image Resizer' : isRotator ? 'Rotate Image' : isCropper ? 'Image Cropper' : isWatermark ? 'Image Watermark' : isMetadata ? 'Image Metadata Viewer' : isPassport ? 'Passport Photo Maker' : isHeicConverter ? 'HEIC Converter' : isSignature ? 'Signature Resizer' : 'Image to PDF';
const toolSlug = isConverter ? 'tools/converter' : isResizer ? 'tools/resizer' : isRotator ? 'tools/rotator' : isCropper ? 'tools/cropper' : isWatermark ? 'tools/watermark' : isMetadata ? 'tools/metadata' : isPassport ? 'tools/passport' : isHeicConverter ? 'tools/heic-converter' : isSignature ? 'tools/signature' : 'tools/image-to-pdf';
const toolPath = `/${lang === 'en' ? '' : lang + '/'}${toolSlug}/`;

const breadcrumbItems = [
  { name: 'Home', href: `/${lang === 'en' ? '' : lang + '/'}` },
  { name: 'Image Tools', href: `/${lang === 'en' ? '' : lang + '/'}image-tools/` },
  { name: toolName, href: toolPath },
];

const appSchema = softwareAppSchema({
  name: `ToolBox Image ${toolName}`,
  description: isConverter
    ? 'Free online image converter — convert PNG, JPG, WebP, and AVIF images instantly in your browser. No uploads, no sign-up, unlimited.'
    : isResizer
    ? 'Free online image resizer — resize images for social media, web, and print. Social media presets, multiple resize modes, no uploads.'
    : isRotator
    ? 'Free online image rotator — rotate and flip images in your browser. 90° CW/CCW, 180°, custom angles, horizontal and vertical flip. No uploads.'
    : isCropper
    ? 'Free online image cropper — crop images with preset aspect ratios or freeform selection. Square, 4:5, 16:9, and custom crops. No uploads.'
    : isWatermark
    ? 'Free online image watermark tool — add text watermarks to images with custom opacity, position, font, and styling. No uploads, no sign-up.'
    : isMetadata
    ? 'Free online image metadata viewer — view EXIF, GPS, and camera metadata. Strip private data before sharing. No uploads, no sign-up.'
    : isHeicConverter
    ? 'Free online HEIC converter — convert Apple HEIC/HEIF photos to JPEG, PNG, or WebP instantly in your browser. No uploads, no sign-up, unlimited.'
    : isSignature
    ? 'Free online signature resizer — resize your signature image for email, documents, and digital forms. Preset sizes, custom dimensions, white or transparent background. No uploads, no sign-up.'
    : isImageToPdf
    ? 'Free online image to PDF converter — combine JPG, PNG, WebP, and more into a single PDF. Reorder pages, choose page size, orientation, margins. No uploads, no sign-up.'
    : 'Free online passport photo maker — create passport and ID photos with correct dimensions and background color. Print-ready layout. No uploads, no sign-up.',
  url: `${SITE_URL}${toolSlug}`,
});

const howTo = isCropper
  ? {
      name: 'How to Crop an Image Online',
      description: 'A step-by-step guide to cropping images using ToolBox Image Cropper.',
      steps: [
        { name: 'Upload your image', text: 'Click the upload area or drag and drop an image file. Supports JPG, PNG, WebP, and AVIF.' },
        { name: 'Choose aspect ratio', text: 'Select a preset aspect ratio — Free, 1:1 Square, 4:5 Portrait, 16:9 Landscape, 3:2, or 4:3 — for the crop area.' },
        { name: 'Adjust crop area', text: 'Drag the crop window to reposition it. Drag the corner and edge handles to resize it. Use arrow keys for pixel-precise positioning.' },
        { name: 'Apply crop', text: 'Click the Apply Crop button to crop your image. The result preview shows the exact output dimensions.' },
        { name: 'Download', text: 'Choose your output format and click download to save your cropped image. All processing stays on your device.' },
      ],
    }
  : isConverter
  ? {
      name: 'How to Convert an Image Online',
      description: 'A step-by-step guide to converting images using ToolBox Image Converter.',
      steps: [
        { name: 'Upload your image', text: 'Click the upload area or drag and drop an image file. Supports JPG, PNG, WebP, and AVIF.' },
        { name: 'Choose target format', text: 'Select your desired output format — JPEG, PNG, WebP, or AVIF — from the format buttons.' },
        { name: 'Adjust quality', text: 'Use the quality slider to control file size vs. image quality. Higher values produce better-looking images.' },
        { name: 'Preview the result', text: 'See a side-by-side comparison of your original and converted image with file size details.' },
        { name: 'Download', text: 'Click the download button to save your converted image. All processing stays on your device.' },
      ],
    }
  : isResizer
  ? {
      name: 'How to Resize an Image Online',
      description: 'A step-by-step guide to resizing images using ToolBox Image Resizer.',
      steps: [
        { name: 'Upload your image', text: 'Click the upload area or drag and drop any image file.' },
        { name: 'Set dimensions', text: 'Enter custom width and height, or pick a social media preset like Instagram or Facebook.' },
        { name: 'Choose resize mode', text: 'Select Fit (maintains aspect ratio with padding), Fill (crops to fill), or Stretch (distorts to fit).' },
        { name: 'Select output format', text: 'Choose JPEG, PNG, or WebP as your output format for the resized image.' },
        { name: 'Download', text: 'Preview the result and download your resized image. All processing is done locally.' },
      ],
    }
      : isMetadata
      ? {
      name: 'How to View and Strip Image Metadata Online',
      description: 'A step-by-step guide to viewing and removing EXIF metadata from images using ToolBox Image Metadata Viewer.',
      steps: [
        { name: 'Upload your image', text: 'Click the upload area or drag and drop a JPEG or TIFF image file. These formats contain the most comprehensive EXIF metadata.' },
        { name: 'View metadata', text: 'The tool automatically extracts and displays all available metadata — camera settings, GPS location, file information, and image details.' },
        { name: 'Review camera info', text: 'Check the Camera Info section for make, model, focal length, aperture, shutter speed, ISO, date taken, and flash settings.' },
        { name: 'Check GPS location', text: 'If your image contains GPS coordinates, they will be displayed with latitude, longitude, and altitude values.' },
        { name: 'Strip and download', text: 'Click Strip Metadata to remove all EXIF data, then download the cleaned image. Your original image is never modified.' },
      ],
    }
      : isPassport
      ? {
      name: 'How to Make a Passport Photo Online Free',
      description: 'A step-by-step guide to creating passport size photos at home using ToolBox Image free online Passport Photo Maker.',
      steps: [
        { name: 'Upload your portrait', text: 'Click the upload area or drag and drop a well-lit, front-facing portrait. A smartphone photo against a plain white wall works best for creating a passport size photo.' },
        { name: 'Select your country preset', text: 'Choose your country or document type from the size presets — US Passport (2×2 in, 600×600 px), UK/EU/India Passport (35×45 mm, 413×531 px), Canada Passport (50×70 mm, 591×827 px), and more.' },
        { name: 'Choose background color', text: 'Select a background color — White (most passports), Blue (visa/ID), Gray, or Red — that matches your document requirements.' },
        { name: 'Frame head and shoulders', text: 'Drag the crop window to frame your head and shoulders within the official proportions. The aspect ratio is locked to your selected country preset. Use arrow keys for pixel-precise fine positioning.' },
        { name: 'Generate and download', text: 'Click Generate Passport Photo to render the image at exact government dimensions at 300 DPI. Download the single digital photo for online submission or the printable 4×6 inch print layout with multiple copies and cut guides.' },
      ],
    }
      : isHeicConverter
      ? {
      name: 'How to Convert HEIC to JPG Online',
      description: 'A step-by-step guide to converting HEIC/HEIF photos to JPEG, PNG, or WebP using ToolBox Image HEIC Converter.',
      steps: [
        { name: 'Upload your HEIC photo', text: 'Click the upload area or drag and drop an HEIC/HEIF file from your iPhone or iPad. These photos are saved in Apple\'s HEIC format by default on iOS devices running iOS 11 and later.' },
        { name: 'Choose output format', text: 'Select your desired output format — JPEG for universal compatibility, PNG for lossless quality with transparency, or WebP for the smallest file size.' },
        { name: 'Adjust quality', text: 'Use the quality slider to control file size vs. image quality. Higher values (92-100%) produce better-looking images. Lower values (60-80%) create smaller files suitable for web use.' },
        { name: 'Preview the result', text: 'See a side-by-side comparison of your original HEIC photo and the converted output with file size information. The HEIC decoder runs in your browser using WebAssembly.' },
        { name: 'Download', text: 'Click the download button to save your converted image. Your original HEIC file is never uploaded — all processing stays on your device.' },
      ],
    }
      : isWatermark
      ? {
      name: 'How to Add a Watermark to an Image Online',
      description: 'A step-by-step guide to adding text watermarks to images using ToolBox Image Watermark.',
      steps: [
        { name: 'Upload your image', text: 'Click the upload area or drag and drop any image file. Supports JPG, PNG, WebP, and AVIF.' },
        { name: 'Enter watermark text', text: 'Type the text you want to overlay on your image. You can use your brand name, copyright notice, or any custom text.' },
        { name: 'Customize appearance', text: 'Adjust the font size, text color, opacity, rotation angle, and font family to match your brand style.' },
        { name: 'Choose position', text: 'Select a position — Top Left, Top Right, Center, Bottom Left, Bottom Right, or Tile across the entire image.' },
        { name: 'Apply and download', text: 'Click Apply Watermark to preview the result, then download your watermarked image. All processing stays on your device.' },
      ],
    }
      : isImageToPdf
      ? {
      name: 'How to Convert Images to PDF Online',
      description: 'A step-by-step guide to converting images to PDF using ToolBox Image to PDF converter.',
      steps: [
        { name: 'Upload your images', text: 'Click the upload area or drag and drop your image files. Supports JPG, PNG, WebP, AVIF, GIF, BMP, and TIFF. You can upload up to 50 images at once.' },
        { name: 'Arrange the order', text: 'Use the up and down arrow buttons on each thumbnail to reorder your images. The PDF pages will appear in the order shown.' },
        { name: 'Choose page settings', text: 'Select page size (Fit to Image, A4, or Letter), orientation (Auto, Portrait, or Landscape), margins (None, Small, or Normal), and image fit (Contain or Cover).' },
        { name: 'Preview the result', text: 'The PDF is generated automatically as you add and arrange images. Review the file name and size information.' },
        { name: 'Download your PDF', text: 'Click the download button to save your PDF. All processing stays on your device — no uploads, no servers.' },
      ],
    }
      : isSignature
      ? {
      name: 'How to Resize a Signature Image Online',
      description: 'A step-by-step guide to resizing signature images for email, documents, and digital forms using ToolBox Image Signature Resizer.',
      steps: [
        { name: 'Upload your signature', text: 'Click the upload area or drag and drop a scanned or photographed signature image. Works with JPG, PNG, WebP, AVIF, and GIF files.' },
        { name: 'Choose a preset size', text: 'Select from preset signature sizes — Email Signature (300×80), Document (400×150), Small (200×60), Standard (350×110), or Large (500×180). Each preset is optimized for its specific use case.' },
        { name: 'Set custom dimensions', text: 'If a preset doesn\'t fit your needs, choose Custom and enter exact width and height values. The aspect ratio lock toggle preserves your signature\'s proportions.' },
        { name: 'Choose background', text: 'Select White for documents and email signatures that need a clean background, or Transparent for overlaying your signature on different-colored documents.' },
        { name: 'Download', text: 'Click the download button to save your resized signature as a PNG file. All processing stays on your device — no uploads, no servers.' },
      ],
    }
      : {
      name: 'How to Rotate an Image Online',
      description: 'A step-by-step guide to rotating and flipping images using ToolBox Image Rotator.',
      steps: [
        { name: 'Upload your image', text: 'Click the upload area or drag and drop any image file. Supports JPG, PNG, WebP, and AVIF.' },
        { name: 'Choose rotation', text: 'Select a preset angle — 90° CW, 90° CCW, or 180° — or enter a custom angle in degrees.' },
        { name: 'Flip if needed', text: 'Use the Flip H (horizontal) or Flip V (vertical) buttons to mirror the image.' },
        { name: 'Preview the result', text: 'See a live preview of the rotated image with updated dimensions and file size.' },
        { name: 'Download', text: 'Click the download button to save your rotated image. All processing stays on your device.' },
      ],
    };

let heicFaqItems: { q: string; a: string }[] = [];
if (isHeicConverter) {
  heicFaqItems = [
    { q: 'What is HEIC format and why do I need to convert it?', a: 'HEIC (High Efficiency Image Container) is Apple\'s default photo format since iOS 11. It uses HEVC (High Efficiency Video Coding) compression to create files about half the size of JPEGs at the same quality. The downside is that HEIC has limited support on Windows, Android, and many web platforms, so converting HEIC to JPG or PNG is often necessary for sharing and uploading.' },
    { q: 'Is it free to convert HEIC to JPG online?', a: 'Yes, ToolBox Image HEIC Converter is completely free. There are no sign-up requirements, no usage limits, no watermarks, and no hidden charges. You can convert as many HEIC photos as you want, as often as you need.' },
    { q: 'Are my HEIC photos uploaded to a server during conversion?', a: 'No. All conversion happens locally in your browser using a WebAssembly build of the libheif library. Your HEIC files never leave your device. You can verify this by opening your browser\'s Network tab — there are zero outbound requests during conversion.' },
    { q: 'What output formats does the HEIC converter support?', a: 'The converter supports three output formats: JPEG (best for universal compatibility, social media, and email), PNG (lossless format ideal for screenshots and images requiring transparency), and WebP (Google\'s modern format that offers superior compression for web use).' },
    { q: 'Can I convert multiple HEIC photos at once?', a: 'Yes, the tool supports batch conversion of up to 50 HEIC/HEIF files at once. Each file is decoded independently and you can download the converted results individually.' },
    { q: 'What is the difference between HEIC and HEIF?', a: 'HEIF (High Efficiency Image File Format) is the container format standard (ISO/IEC 23008-12). HEIC is Apple\'s specific implementation of HEIF that uses HEVC/H.265 compression. HEIF is the container; HEIC is Apple\'s version of it. Some Android devices also produce .heif files using a different codec.' },
    { q: 'Why can\'t I open HEIC photos on my Windows or Android device?', a: 'HEIC uses the HEVC (H.265) video codec for compression, which requires a license for decoding. Apple includes this support natively, but Windows requires a paid ($0.99) HEVC extension from the Microsoft Store, and most Android devices don\'t include HEIC decoding support out of the box. Converting to JPEG solves this compatibility issue.' },
    { q: 'Does converting HEIC to JPEG lose quality?', a: 'JPEG is a lossy format, so some quality loss occurs during the conversion from HEIC. However, at higher quality settings (92% or above), the difference is visually imperceptible. The HEIC file itself was already compressed using HEVC, so the conversion adds JPEG compression on top of that.' },
  ];
}

const faqItems = isConverter
  ? [
      { q: _('converter.faq.q1'), a: _('converter.faq.a1') },
      { q: _('converter.faq.q2'), a: _('converter.faq.a2') },
      { q: _('converter.faq.q3'), a: _('converter.faq.a3') },
      { q: _('converter.faq.q4'), a: _('converter.faq.a4') },
      { q: _('converter.faq.q5'), a: _('converter.faq.a5') },
    ]
  : isResizer
  ? [
      { q: _('resizer.faq.q1'), a: _('resizer.faq.a1') },
      { q: _('resizer.faq.q2'), a: _('resizer.faq.a2') },
      { q: _('resizer.faq.q3'), a: _('resizer.faq.a3') },
      { q: _('resizer.faq.q4'), a: _('resizer.faq.a4') },
      { q: _('resizer.faq.q5'), a: _('resizer.faq.a5') },
    ]
  : isCropper
  ? [
      { q: _('cropper.faq.q1'), a: _('cropper.faq.a1') },
      { q: _('cropper.faq.q2'), a: _('cropper.faq.a2') },
      { q: _('cropper.faq.q3'), a: _('cropper.faq.a3') },
      { q: _('cropper.faq.q4'), a: _('cropper.faq.a4') },
      { q: _('cropper.faq.q5'), a: _('cropper.faq.a5') },
      { q: _('cropper.faq.q6'), a: _('cropper.faq.a6') },
      { q: _('cropper.faq.q7'), a: _('cropper.faq.a7') },
    ]
  : isPassport
  ? [
      { q: _('passport.faq.q1'), a: _('passport.faq.a1') },
      { q: _('passport.faq.q2'), a: _('passport.faq.a2') },
      { q: _('passport.faq.q3'), a: _('passport.faq.a3') },
      { q: _('passport.faq.q4'), a: _('passport.faq.a4') },
      { q: _('passport.faq.q5'), a: _('passport.faq.a5') },
      { q: _('passport.faq.q6'), a: _('passport.faq.a6') },
      { q: _('passport.faq.q7'), a: _('passport.faq.a7') },
    ]
  : isMetadata
  ? [
      { q: _('metadata.faq.q1'), a: _('metadata.faq.a1') },
      { q: _('metadata.faq.q2'), a: _('metadata.faq.a2') },
      { q: _('metadata.faq.q3'), a: _('metadata.faq.a3') },
      { q: _('metadata.faq.q4'), a: _('metadata.faq.a4') },
      { q: _('metadata.faq.q5'), a: _('metadata.faq.a5') },
    ]
  : isWatermark
  ? [
      { q: _('watermark.faq.q1'), a: _('watermark.faq.a1') },
      { q: _('watermark.faq.q2'), a: _('watermark.faq.a2') },
      { q: _('watermark.faq.q3'), a: _('watermark.faq.a3') },
      { q: _('watermark.faq.q4'), a: _('watermark.faq.a4') },
      { q: _('watermark.faq.q5'), a: _('watermark.faq.a5') },
    ]
  : isHeicConverter
  ? heicFaqItems
  : isSignature
  ? [
      { q: 'What is the best signature size for email signatures?', a: 'The standard email signature image size is 300-400 pixels wide by 80-150 pixels tall. ToolBox Image Signature Resizer includes a dedicated Email Signature preset (300×80) that works perfectly with most email clients including Gmail, Outlook, Apple Mail, and Yahoo Mail. For wider email layouts, use the Standard preset (350×110).' },
      { q: 'Can I resize a signature image without losing quality?', a: 'Yes, resizing maintains image clarity when you scale down from a larger scanned signature. For best results, upload a high-resolution scan or photo of your signature and scale it down to your desired size. The Signature Resizer uses the HTML5 Canvas API for precise pixel-based resizing.' },
      { q: 'What file format should I use for my digital signature?', a: 'PNG is the recommended format for signature images because it supports transparency and preserves crisp edges. ToolBox Image Signature Resizer outputs PNG files by default. Use the Transparent background option when you need to overlay your signature on different-colored documents or forms.' },
      { q: 'Is it safe to upload my signature image online?', a: 'ToolBox Image Signature Resizer processes everything locally in your browser. Your signature image never leaves your device — there are no server uploads, no data storage, and no third-party processing. You can verify this by checking the Network tab in your browser\'s developer tools.' },
    ]
  : isImageToPdf
  ? [
      { q: 'Can I combine multiple images into one PDF?', a: 'Yes, ToolBox Image to PDF lets you combine up to 50 images into a single PDF document. Upload all your images, arrange them in the desired order using the up/down arrow buttons, and download a single PDF with each image on its own page.' },
      { q: 'What image formats can I convert to PDF?', a: 'The tool supports JPG, PNG, WebP, AVIF, GIF, BMP, and TIFF formats. All images are converted to PNG internally before embedding in the PDF, which ensures compatibility regardless of the source format.' },
      { q: 'Is it free to convert images to PDF online?', a: 'Yes, ToolBox Image to PDF is completely free. There are no sign-up requirements, no usage limits, no watermarks, and no hidden charges. You can convert as many images as you want, as often as you need.' },
      { q: 'Are my images uploaded to a server during PDF conversion?', a: 'No. All conversion happens locally in your browser using pdf-lib, a PDF generation library that runs entirely in JavaScript. Your images never leave your device. You can verify this by opening your browser\'s Network tab — there are zero outbound requests during PDF generation.' },
    ]
  : [
      { q: _('rotator.faq.q1'), a: _('rotator.faq.a1') },
      { q: _('rotator.faq.q2'), a: _('rotator.faq.a2') },
      { q: _('rotator.faq.q3'), a: _('rotator.faq.a3') },
      { q: _('rotator.faq.q4'), a: _('rotator.faq.a4') },
      { q: _('rotator.faq.q5'), a: _('rotator.faq.a5') },
    ];

const breadcrumb = breadcrumbSchema(breadcrumbItems);
const faq = faqSchema(faqItems);
const howToLd = howToSchema(howTo.steps);
---

<section class="band band-canvas" id="seo-content">
  <div class="container stack stack-3xl">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="seo-breadcrumb">
      <ol class="seo-breadcrumb-list">
        {breadcrumbItems.map((item) => (
          <li class="seo-breadcrumb-item">
            {item.href === toolPath ? (
              <span aria-current="page">{item.name}</span>
            ) : (
              <a href={item.href}>{item.name}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Main SEO Content -->
    <Prose>
      {isConverter && <>
        <h2>Free Online Image Converter — Convert PNG, JPG, WebP & AVIF</h2>
        <p>
          ToolBox Image Converter is a fast, private, browser-based tool for converting images
          between the most popular web formats. Whether you need to convert PNG to JPG,
          JPG to WebP, WebP to PNG, or any other combination of JPEG, PNG, WebP, and AVIF,
          this free online image converter handles it instantly — with no uploads, no sign-up,
          and no file size limits.
        </p>
        <p>
          Unlike online image converters that send your files to a remote server, ToolBox Image
          Converter processes everything locally using the HTML5 Canvas API. Your images stay on
          your device, making this one of the most private image conversion tools available.
          The converter supports lossy and lossless formats, a quality slider for fine-grained
          control, and instant side-by-side previews so you can compare before and after.
        </p>

        <h3>Supported Image Format Conversions</h3>
        <p>
          ToolBox Image Converter supports all combinations of the four most common image formats:
        </p>
        <ul>
          <li><strong>JPEG (JPG):</strong> Best for photographs and complex images. Converts to WebP, PNG, and AVIF.</li>
          <li><strong>PNG:</strong> Best for graphics, screenshots, and images requiring transparency. Converts to JPEG, WebP, and AVIF.</li>
          <li><strong>WebP:</strong> Google's modern format with superior compression. Converts to JPEG, PNG, and AVIF.</li>
          <li><strong>AVIF:</strong> The next-generation format with the best compression ratios. Converts to JPEG, PNG, and WebP.</li>
        </ul>

        <h3>Why Use ToolBox Image Converter?</h3>
        <p>
          Most image conversion tools either upload your files to a server (compromising privacy)
          or require software installation. ToolBox Image Converter is different:
        </p>
        <ul>
          <li><strong>100% Private:</strong> No uploads, no servers, no tracking. All conversion happens in your browser.</li>
          <li><strong>No File Size Limits:</strong> Convert images of any size — the limitation is your device's memory, not our tool.</li>
          <li><strong>Quality Control:</strong> Fine-tune output quality with a precise slider (1-100%) for the perfect balance of size and clarity.</li>
          <li><strong>Instant Preview:</strong> See your original and converted image side by side with exact file size information.</li>
          <li><strong>Free Forever:</strong> No sign-up, no paywall, no credit card. Unlimited conversions.</li>
        </ul>

        <h3>How to Convert Images Online</h3>
        <p>Converting images with ToolBox Image is simple and takes just a few seconds:</p>
        <ol>
          <li><strong>Upload</strong> — Click the upload area or drag and drop an image file onto this page.</li>
          <li><strong>Select Format</strong> — Choose your target output format (JPEG, PNG, WebP, or AVIF).</li>
          <li><strong>Adjust Quality</strong> — Move the quality slider to control file size. Higher = better quality, lower = smaller file.</li>
          <li><strong>Preview</strong> — See the original and converted image side by side with file size details.</li>
          <li><strong>Download</strong> — Click download to save your converted image. Your original file is never modified.</li>
        </ol>

        <h3>Common Use Cases</h3>
        <ul>
          <li><strong>Convert HEIC to JPEG:</strong> iPhone and iOS devices capture photos in HEIC format. Convert them to JPEG for wider compatibility on Windows, Android, and web platforms.</li>
