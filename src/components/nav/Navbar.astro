---
import Logo from '../brand/Logo.astro';
import ThemeToggle from '../theme/ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const links = [
  { href: '/compressor', label: 'Compressor' },
];
---

<header class="nav-bar">
  <nav class="nav-inner" aria-label="Main navigation">
    <Logo />

    <div class="nav-links">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['nav-link text-body-sm', { active: currentPath === l.href }]}
        >
          {l.label}
        </a>
      ))}
    </div>

    <div class="nav-actions">
      <ThemeToggle size="sm" />
    </div>
  </nav>
</header>

<style>
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    display: flex;
    align-items: center;
    padding: 0 var(--space-lg);
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    backdrop-filter: saturate(180%) blur(8px);
  }

  [data-theme="dark"] .nav-bar {
    background-color: color-mix(in srgb, var(--color-canvas) 80%, transparent);
  }

  .nav-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    color: var(--color-body);
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .nav-link.active {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  @media (max-width: 600px) {
    .nav-bar {
      padding: 0 var(--space-md);
    }

    .nav-links {
      display: none;
    }
  }
</style>