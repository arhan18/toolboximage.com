---
import Logo from '../brand/Logo.astro';
import ThemeToggle from '../theme/ThemeToggle.astro';
import { tools } from '../../lib/tools';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const stripSlash = (s: string) => s.length > 1 && s.endsWith('/') ? s.slice(0, -1) : s;

const isToolsActive = () => {
  const cp = stripSlash(currentPath);
  return cp.startsWith('/image-tools') || cp.startsWith('/compressor') || cp.startsWith('/compress-') || cp.startsWith('/tools/');
};

const isActive = (href: string) => {
  const cp = stripSlash(currentPath);
  const h = stripSlash(href);
  return cp === h || (h !== '/' && cp.startsWith(h + '/'));
};

const comingSoonLinks = tools
  .filter((t) => t.status === 'coming-soon')
  .map((t) => ({ href: t.path, label: t.shortName ?? t.name }));

const plannedLinks = tools
  .filter((t) => t.status === 'planned')
  .map((t) => ({ href: t.path, label: t.shortName ?? t.name }));
---

<header class="nav-bar">
  <div class="nav-progress" data-nav-progress></div>
  <nav class="nav-inner" aria-label="Main navigation">
    <Logo />

    <div class="nav-links">
      <div class="nav-dropdown">
        <button
          type="button"
          class:list={['nav-link nav-dropdown-trigger text-body-sm', { active: isToolsActive() }]}
          aria-expanded="false"
          aria-controls="tools-dropdown"
          data-tools-trigger
        >
          Tools
          <svg class="dropdown-arrow" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <div class="nav-dropdown-panel" id="tools-dropdown" data-tools-dropdown hidden>
          <div class="dropdown-inner">
            <a
              href="/image-tools/"
              class:list={['dropdown-link dropdown-link-all text-body-sm-strong', { active: isActive('/image-tools/') }]}
              aria-current={isActive('/image-tools/') ? 'page' : undefined}
              data-astro-prefetch="hover"
            >
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="7" height="7"/>
                <rect x="14" y="3" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/>
                <rect x="14" y="14" width="7" height="7"/>
              </svg>
              All Image Tools
            </a>

            <div class="dropdown-group">
              <a
                href="/image-compressor/"
                class:list={['dropdown-group-label text-caption-mono dropdown-group-link', { active: isActive('/image-compressor/') }]}
                aria-current={isActive('/image-compressor/') ? 'page' : undefined}
                data-astro-prefetch="hover"
              >
                Image Compressor
              </a>
              <div class="dropdown-links">
                <a
                  href="/image-compressor/"
                  class:list={['dropdown-link text-body-sm', { active: isActive('/image-compressor/') }]}
                  aria-current={isActive('/image-compressor/') ? 'page' : undefined}
                  data-astro-prefetch="hover"
                >
                  Image Compressor
                </a>
                <a
                  href="/compress-jpeg/"
                  class:list={['dropdown-link text-body-sm', { active: isActive('/compress-jpeg/') }]}
                  aria-current={isActive('/compress-jpeg/') ? 'page' : undefined}
                  data-astro-prefetch="hover"
                >
                  Compress JPEG
                </a>
                <a
                  href="/compress-png/"
                  class:list={['dropdown-link text-body-sm', { active: isActive('/compress-png/') }]}
                  aria-current={isActive('/compress-png/') ? 'page' : undefined}
                  data-astro-prefetch="hover"
                >
                  Compress PNG
                </a>
                <a
                  href="/compress-webp/"
                  class:list={['dropdown-link text-body-sm', { active: isActive('/compress-webp/') }]}
                  aria-current={isActive('/compress-webp/') ? 'page' : undefined}
                  data-astro-prefetch="hover"
                >
                  Compress WebP
                </a>
                <a
                  href="/compress-avif/"
                  class:list={['dropdown-link text-body-sm', { active: isActive('/compress-avif/') }]}
                  aria-current={isActive('/compress-avif/') ? 'page' : undefined}
                  data-astro-prefetch="hover"
                >
                  Compress AVIF
                </a>
                <a
                  href="/bulk-image-compressor/"
                  class:list={['dropdown-link text-body-sm', { active: isActive('/bulk-image-compressor/') }]}
                  aria-current={isActive('/bulk-image-compressor/') ? 'page' : undefined}
                  data-astro-prefetch="hover"
                >
                  Bulk Compressor
                </a>
                <a
                  href="/image-compressor-100kb/"
                  class:list={['dropdown-link text-body-sm', { active: isActive('/image-compressor-100kb/') }]}
                  aria-current={isActive('/image-compressor-100kb/') ? 'page' : undefined}
                  data-astro-prefetch="hover"
                >
                  Compress to 100KB
                </a>
                <a
                  href="/image-compressor-for-discord/"
                  class:list={['dropdown-link text-body-sm', { active: isActive('/image-compressor-for-discord/') }]}
                  aria-current={isActive('/image-compressor-for-discord/') ? 'page' : undefined}
                  data-astro-prefetch="hover"
                >
                  Discord Compressor
                </a>
              </div>
            </div>

            <div class="dropdown-group">
              <span class="dropdown-group-label text-caption-mono">Coming Soon</span>
              <div class="dropdown-links">
                {comingSoonLinks.map((l) => (
                  <a
                    href={l.href}
                    class:list={['dropdown-link text-body-sm', { active: isActive(l.href) }]}
                    aria-current={isActive(l.href) ? 'page' : undefined}
                    data-astro-prefetch="hover"
                  >
                    {l.label}
                  </a>
                ))}
              </div>
            </div>

            <div class="dropdown-group">
              <span class="dropdown-group-label text-caption-mono">Planned</span>
              <div class="dropdown-links">
                {plannedLinks.map((l) => (
                  <a
                    href={l.href}
                    class:list={['dropdown-link text-body-sm', { active: isActive(l.href) }]}
                    aria-current={isActive(l.href) ? 'page' : undefined}
                    data-astro-prefetch="hover"
                  >
                    {l.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <a
        href="/blog/"
        class:list={['nav-link text-body-sm', { active: isActive('/blog/') }]}
        aria-current={isActive('/blog/') ? 'page' : undefined}
        data-astro-prefetch="hover"
      >
        Blog
      </a>
      <a
        href="/faq/"
        class:list={['nav-link text-body-sm', { active: isActive('/faq/') }]}
        aria-current={isActive('/faq/') ? 'page' : undefined}
        data-astro-prefetch="hover"
      >
        FAQ
      </a>
      <a
        href="/about/"
        class:list={['nav-link text-body-sm', { active: isActive('/about/') }]}
        aria-current={isActive('/about/') ? 'page' : undefined}
        data-astro-prefetch="hover"
      >
        About
      </a>
    </div>

    <div class="nav-actions">
      <a href="/contact/" class="nav-link nav-link-cta text-body-sm-strong" data-astro-prefetch="hover">
        Contact
      </a>
      <ThemeToggle />
      <button type="button" class="nav-hamburger" aria-label="Toggle navigation menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </nav>
</header>

<script>
  const nav = document.querySelector<HTMLElement>('.nav-bar');
  if (nav) {
    // Navigation progress bar.
    const progress = nav.querySelector<HTMLElement>('[data-nav-progress]');
    if (progress) {
      let navTimer = 0;
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest<HTMLAnchorElement>('a[href]');
        if (link && link.href && link.href.startsWith(location.origin + '/') && link.href !== location.href) {
          progress.classList.remove('nav-progress-done');
          progress.style.width = '0%';
          requestAnimationFrame(() => {
            progress.style.width = '60%';
          });
          clearTimeout(navTimer);
          navTimer = window.setTimeout(() => {
            progress.style.width = '100%';
          }, 300);
        }
      });
      window.addEventListener('pageshow', () => {
        progress.style.width = '100%';
        progress.classList.add('nav-progress-done');
      });
    }

    // Scroll shadow.
    let ticking = false;
    const updateScroll = () => {
      nav.dataset.scrolled = window.scrollY > 8 ? 'true' : '';
    };
    document.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { updateScroll(); ticking = false; });
        ticking = true;
      }
    });
    updateScroll();

    // Tools dropdown toggle.
    const trigger = nav.querySelector<HTMLButtonElement>('[data-tools-trigger]');
    const dropdown = nav.querySelector<HTMLElement>('[data-tools-dropdown]');
    if (trigger && dropdown) {
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', String(!open));
        dropdown.hidden = open;
      });

      document.addEventListener('click', (e) => {
        if (!nav.contains(e.target as Node)) {
          trigger.setAttribute('aria-expanded', 'false');
          dropdown.hidden = true;
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && trigger.getAttribute('aria-expanded') === 'true') {
          trigger.setAttribute('aria-expanded', 'false');
          dropdown.hidden = true;
          trigger.focus();
        }
      });

      dropdown.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a');
        if (link) {
          trigger.setAttribute('aria-expanded', 'false');
          dropdown.hidden = true;
        }
      });
    }

    // Mobile hamburger toggle.
    const hamburger = nav.querySelector<HTMLButtonElement>('.nav-hamburger');
    const navLinks = nav.querySelector<HTMLElement>('.nav-links');
    if (hamburger && navLinks) {
      hamburger.addEventListener('click', () => {
        const open = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!open));
        navLinks.dataset.open = String(!open);
      });
      navLinks.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a');
        if (link) {
          hamburger.setAttribute('aria-expanded', 'false');
          navLinks.dataset.open = 'false';
        }
      });
    }
  }
</script>

<style>
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    display: flex;
    align-items: center;
    padding: 0 var(--space-lg);
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    transition:
      border-color var(--dur-fast) var(--ease-out-quart),
      box-shadow var(--dur-fast) var(--ease-out-quart);
  }

  [data-theme="dark"] .nav-bar {
    background-color: color-mix(in srgb, var(--color-canvas) 80%, transparent);
  }

  .nav-bar[data-scrolled="true"] {
    box-shadow: var(--shadow-2);
    border-bottom-color: var(--color-hairline-strong);
  }

  .nav-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xxs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    color: var(--color-body);
    text-decoration: none;
    position: relative;
    transition:
      color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .nav-link::before {
    content: '';
    position: absolute;
    inset: auto var(--space-sm) calc(var(--space-xs) - 2px) var(--space-sm);
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--dur-base) var(--ease-out-quart);
  }

  .nav-link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .nav-link:hover::before {
    transform: scaleX(0.6);
  }

  .nav-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
    border-radius: var(--radius-full);
  }

  .nav-link.active,
  .nav-link[aria-current="page"] {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .nav-link.active::before,
  .nav-link[aria-current="page"]::before {
    transform: scaleX(0.6);
  }

  .nav-link-cta {
    color: var(--color-link);
    padding-left: var(--space-md);
    padding-right: var(--space-md);
  }

  .nav-link-cta:hover {
    background-color: color-mix(in srgb, var(--color-link) 10%, transparent);
    color: var(--color-link-deep);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  /* ── Tools dropdown ──────────────────────────────────── */

  .nav-dropdown {
    position: static;
  }

  .nav-dropdown-trigger {
    cursor: pointer;
    background: none;
    border: none;
    font: inherit;
  }

  .dropdown-arrow {
    transition: transform var(--dur-base) var(--ease-out-quart);
  }

  .nav-dropdown-trigger[aria-expanded="true"] .dropdown-arrow {
    transform: rotate(180deg);
  }

  .nav-dropdown-panel {
    position: absolute;
    top: 64px;
    left: 0;
    right: 0;
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    box-shadow: var(--shadow-3);
    padding: var(--space-lg) 0;
    z-index: 99;
  }

  .dropdown-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .dropdown-link-all {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    color: var(--color-link);
    text-decoration: none;
    width: fit-content;
    transition:
      color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .dropdown-link-all:hover {
    background-color: color-mix(in srgb, var(--color-link) 10%, transparent);
    color: var(--color-link-deep);
  }

  .dropdown-link-all.active,
  .dropdown-link-all[aria-current="page"] {
    color: var(--color-link-deep);
    background-color: color-mix(in srgb, var(--color-link) 12%, transparent);
  }

  .dropdown-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .dropdown-group-label {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .dropdown-group-link {
    text-decoration: none;
    width: fit-content;
    padding: var(--space-xxs) var(--space-sm);
    border-radius: var(--radius-full);
    transition:
      color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .dropdown-group-link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .dropdown-group-link.active,
  .dropdown-group-link[aria-current="page"] {
    color: var(--color-link);
    background-color: color-mix(in srgb, var(--color-link) 10%, transparent);
  }

  .dropdown-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xxs);
  }

  .dropdown-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-xxs) var(--space-sm);
    border-radius: var(--radius-full);
    color: var(--color-body);
    text-decoration: none;
    white-space: nowrap;
    transition:
      color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .dropdown-link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .dropdown-link.active,
  .dropdown-link[aria-current="page"] {
    color: var(--color-link);
    background-color: color-mix(in srgb, var(--color-link) 10%, transparent);
  }

  .nav-hamburger {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--space-xxs);
    background: transparent;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    cursor: pointer;
    padding: 10px;
    transition: border-color var(--dur-fast) var(--ease-out-quart);
  }

  .nav-hamburger:hover {
    border-color: var(--color-hairline-strong);
  }

  .nav-hamburger:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-ink);
    border-radius: 1px;
    transition: transform var(--dur-base) var(--ease-out-quart);
  }

  @media (max-width: 768px) {
    .nav-bar { padding: 0 var(--space-md); }
    .nav-links { display: none; }
    .nav-links[data-open="true"] {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background-color: var(--color-canvas);
      border-bottom: 1px solid var(--color-hairline);
      box-shadow: var(--shadow-3);
      padding: var(--space-sm);
      gap: var(--space-xs);
      z-index: 99;
    }
    .nav-links[data-open="true"] .nav-link {
      width: 100%;
      justify-content: center;
      padding: var(--space-sm) var(--space-md);
    }
    .nav-hamburger { display: flex; }

    .nav-dropdown-panel {
      position: static;
      box-shadow: none;
      border-bottom: none;
      padding: var(--space-sm) 0;
    }

    .dropdown-inner {
      padding: 0;
      gap: var(--space-sm);
    }

    .dropdown-group {
      gap: var(--space-xxs);
    }

    .dropdown-links {
      flex-wrap: wrap;
    }
  }

  .nav-progress {
    position: absolute;
    bottom: -1px;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-link), var(--color-violet));
    width: 0%;
    z-index: 101;
    transition: width 4s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .nav-progress-done {
    transition: width 0.2s ease;
    width: 100% !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link, .nav-link::before,
    .hamburger-line,
    .dropdown-arrow { transition: none; }
    .nav-progress { display: none; }
  }
</style>
</content>
</invoke>