---
import Logo from '../brand/Logo.astro';
import ThemeToggle from '../theme/ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

// Single top-level nav for now. As more tools ship, the link groups can
// split into dropdowns/menus — keeping it flat for clarity.
const links = [
  { href: '/compressor/', label: 'Compressor' },
  { href: '/blog/', label: 'Blog' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/about/', label: 'About' },
];

const stripSlash = (s: string) => s.length > 1 && s.endsWith('/') ? s.slice(0, -1) : s;
const isActive = (href: string) => {
  const cp = stripSlash(currentPath);
  const h = stripSlash(href);
  return cp === h || (h !== '/' && cp.startsWith(h + '/'));
};
---

<header class="nav-bar">
  <div class="nav-progress" data-nav-progress></div>
  <nav class="nav-inner" aria-label="Main navigation">
    <Logo />

    <div class="nav-links">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['nav-link text-body-sm', { active: isActive(l.href) }]}
          aria-current={isActive(l.href) ? 'page' : undefined}
          data-astro-prefetch="hover"
        >
          {l.label}
        </a>
      ))}
    </div>

    <div class="nav-actions">
      <a href="/contact/" class="nav-link nav-link-cta text-body-sm-strong" data-astro-prefetch="hover">
        Contact
      </a>
      <ThemeToggle />
      <button type="button" class="nav-hamburger" aria-label="Toggle navigation menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </nav>
</header>

<script>
  const nav = document.querySelector<HTMLElement>('.nav-bar');
  if (nav) {
    // Navigation progress bar.
    const progress = nav.querySelector<HTMLElement>('[data-nav-progress]');
    if (progress) {
      let navTimer = 0;
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest<HTMLAnchorElement>('a[href]');
        if (link && link.href && link.href.startsWith(location.origin + '/') && link.href !== location.href) {
          progress.classList.remove('nav-progress-done');
          progress.style.width = '0%';
          requestAnimationFrame(() => {
            progress.style.width = '60%';
          });
          clearTimeout(navTimer);
          navTimer = window.setTimeout(() => {
            progress.style.width = '100%';
          }, 300);
        }
      });
      window.addEventListener('pageshow', () => {
        progress.style.width = '100%';
        progress.classList.add('nav-progress-done');
      });
    }

    // Scroll shadow.
    let ticking = false;
    const updateScroll = () => {
      nav.dataset.scrolled = window.scrollY > 8 ? 'true' : '';
    };
    document.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { updateScroll(); ticking = false; });
        ticking = true;
      }
    });
    updateScroll();

    // Mobile hamburger toggle.
    const hamburger = nav.querySelector<HTMLButtonElement>('.nav-hamburger');
    const navLinks = nav.querySelector<HTMLElement>('.nav-links');
    if (hamburger && navLinks) {
      hamburger.addEventListener('click', () => {
        const open = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!open));
        navLinks.dataset.open = String(!open);
      });
      // Close menu on link click (SPA-style hash nav or same-page).
      navLinks.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a');
        if (link) {
          hamburger.setAttribute('aria-expanded', 'false');
          navLinks.dataset.open = 'false';
        }
      });
    }
  }
</script>

<style>
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    display: flex;
    align-items: center;
    padding: 0 var(--space-lg);
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    transition:
      border-color var(--dur-fast) var(--ease-out-quart),
      box-shadow var(--dur-fast) var(--ease-out-quart);
  }

  [data-theme="dark"] .nav-bar {
    background-color: color-mix(in srgb, var(--color-canvas) 80%, transparent);
  }

  /* Subtle shadow on scroll. */
  .nav-bar[data-scrolled="true"] {
    box-shadow: var(--shadow-2);
    border-bottom-color: var(--color-hairline-strong);
  }

  .nav-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    color: var(--color-body);
    text-decoration: none;
    position: relative;
    transition:
      color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  .nav-link::before {
    content: '';
    position: absolute;
    inset: auto var(--space-sm) calc(var(--space-xs) - 2px) var(--space-sm);
    height: 1px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--dur-base) var(--ease-out-quart);
  }

  .nav-link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .nav-link:hover::before {
    transform: scaleX(0.6);
  }

  .nav-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
    border-radius: var(--radius-full);
  }

  .nav-link.active,
  .nav-link[aria-current="page"] {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .nav-link.active::before,
  .nav-link[aria-current="page"]::before {
    transform: scaleX(0.6);
  }

  .nav-link-cta {
    color: var(--color-link);
    padding-left: var(--space-md);
    padding-right: var(--space-md);
  }

  .nav-link-cta:hover {
    background-color: color-mix(in srgb, var(--color-link) 10%, transparent);
    color: var(--color-link-deep);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav-hamburger {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--space-xxs);
    background: transparent;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    cursor: pointer;
    padding: 10px;
    transition: border-color var(--dur-fast) var(--ease-out-quart);
  }

  .nav-hamburger:hover {
    border-color: var(--color-hairline-strong);
  }

  .nav-hamburger:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-ink);
    border-radius: 1px;
    transition: transform var(--dur-base) var(--ease-out-quart);
  }

  @media (max-width: 768px) {
    .nav-bar { padding: 0 var(--space-md); }
    .nav-links { display: none; }
    .nav-links[data-open="true"] {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background-color: var(--color-canvas);
      border-bottom: 1px solid var(--color-hairline);
      box-shadow: var(--shadow-3);
      padding: var(--space-sm);
      gap: var(--space-xs);
      z-index: 99;
    }
    .nav-links[data-open="true"] .nav-link {
      width: 100%;
      justify-content: center;
      padding: var(--space-sm) var(--space-md);
    }
    .nav-hamburger { display: flex; }
  }

  .nav-progress {
    position: absolute;
    bottom: -1px;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-link), var(--color-violet));
    width: 0%;
    z-index: 101;
    transition: width 4s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .nav-progress-done {
    transition: width 0.2s ease;
    width: 100% !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link, .nav-link::before,
    .hamburger-line { transition: none; }
    .nav-progress { display: none; }
  }
</style>
</content>
</invoke>