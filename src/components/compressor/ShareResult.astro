---
/**
 * ShareResult — social sharing links that appear after compression.
 * Pre-fills text about the tool so users can share with one click.
 */

const shareText = 'Compressed images with ToolBox Image — free, private, runs in my browser. No uploads needed.';
const url = 'https://toolboximage.com/compressor/';
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(url)}`;
const redditUrl = `https://reddit.com/submit?url=${encodeURIComponent(url)}&title=${encodeURIComponent(shareText)}`;
const mailtoUrl = `mailto:?subject=${encodeURIComponent('ToolBox Image — free image compressor')}&body=${encodeURIComponent(shareText + '\n\n' + url)}`;
---

<div class="share-result" data-share-result hidden>
  <hr class="share-divider" />
  <p class="share-label">Like it? Share ToolBox Image</p>
  <div class="share-links">
    <a href={twitterUrl} target="_blank" rel="noopener noreferrer" class="share-link share-twitter" aria-label="Share on Twitter/X">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      X / Twitter
    </a>
    <a href={redditUrl} target="_blank" rel="noopener noreferrer" class="share-link share-reddit" aria-label="Share on Reddit">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.5 6.5a1.5 1.5 0 0 1 1.5 1.5c0 .45-.2.86-.5 1.15.3.65.5 1.35.5 2.1 0 3.1-3.15 5.6-7 5.6s-7-2.5-7-5.6c0-.75.2-1.45.5-2.1a1.5 1.5 0 0 1 .95-2.6c.45 0 .85.2 1.15.5a8.9 8.9 0 0 1 4.4-1.2l.85-3.95.05-.05a.5.5 0 0 1 .5-.35l2.75.55a1 1 0 0 1 .95.65 1 1 0 0 1-.5 1.3c-.55.25-1.2-.05-1.4-.6a1 1 0 0 1 .6-1.3l-2.1-.45-.7 3.25a9 9 0 0 1 4.3 1.15c.3-.3.7-.45 1.15-.45zM8.25 11.5a1.25 1.25 0 0 0 0 2.5 1.25 1.25 0 0 0 0-2.5zm7.5 0a1.25 1.25 0 0 0 0 2.5 1.25 1.25 0 0 0 0-2.5zm-6.6 4.55c.05-.05.1-.05.15 0 1 .85 2.3 1.35 3.7 1.35s2.7-.5 3.7-1.35c.05-.05.1-.05.15 0 .05.05.05.1 0 .15-1.05.9-2.45 1.45-3.85 1.45s-2.8-.55-3.85-1.45c-.05-.05-.05-.1 0-.15z"/></svg>
      Reddit
    </a>
    <a href={mailtoUrl} target="_blank" rel="noopener noreferrer" class="share-link share-email" aria-label="Share via Email">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      Email
    </a>
  </div>
</div>

<script>
  const shareEl = document.querySelector<HTMLElement>('[data-share-result]');
  if (shareEl) {
    const observer = new MutationObserver(() => {
      const summary = document.querySelector<HTMLElement>('[data-results-summary]');
      if (summary && !summary.hidden) {
        shareEl.hidden = false;
        observer.disconnect();
      }
    });
    observer.observe(document.body, { subtree: true, childList: true });
  }
</script>

<style>
  .share-result {
    margin-top: var(--space-xl);
    text-align: center;
  }

  .share-divider {
    border: 0;
    border-top: 1px solid var(--color-hairline);
    margin: 0 0 var(--space-md);
  }

  .share-label {
    font-size: var(--text-caption);
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-sm);
  }

  .share-links {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .share-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: var(--radius-md);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    text-decoration: none;
    border: 1px solid var(--color-hairline);
    background-color: var(--color-canvas);
    color: var(--color-ink);
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .share-link:hover {
    background-color: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }

  .share-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
    border-radius: var(--radius-xs);
  }
</style>
