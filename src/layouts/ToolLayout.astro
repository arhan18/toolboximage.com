---
import Layout from './Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import ToolHeader from '../components/tools/ToolHeader.astro';
import Breadcrumbs from '../components/shared/Breadcrumbs.astro';
import type { ToolConfig } from '../types';
import { softwareAppSchema, breadcrumbSchema } from '../lib/seo';
import { useTranslations, type LangCode } from '../i18n';

interface Props {
  tool: ToolConfig;
  lang?: LangCode;
}

const { tool, lang = 'en' } = Astro.props;
const _ = useTranslations(lang);

const schemas = tool.status === 'live'
  ? [
      softwareAppSchema({
        name: `ToolBox Image — ${tool.name}`,
        description: tool.longDescription ?? tool.description,
        url: `https://toolboximage.com${tool.path}`,
      }),
      breadcrumbSchema([
        { name: 'Home', href: '/' },
        { name: 'Image Tools', href: '/image-tools' },
        { name: tool.name, href: tool.path },
      ]),
    ]
  : [
      breadcrumbSchema([
        { name: 'Home', href: '/' },
        { name: 'Image Tools', href: '/image-tools' },
        { name: tool.name, href: tool.path },
      ]),
    ];
---

<Layout
  title={`${tool.name} — ToolBox Image`}
  description={tool.longDescription ?? tool.description}
  ogImage={`/og-${tool.id}.png`}
  noIndex={tool.status !== 'live'}
  lang={lang}
  {schemas}
>
  <AppShell>
    <article class="tool-page">
      <div class="container stack stack-xl">
        <Breadcrumbs items={[
          { name: _('nav.tools'), href: '/' },
          { name: _('nav.allTools'), href: '/image-tools' },
          { name: tool.name, href: tool.path },
        ]} />
        <ToolHeader {tool} lang={lang} />
        <slot name="tool-body" />
      </div>
    </article>
  </AppShell>
</Layout>

<style>
  .tool-page {
    padding-top: var(--space-4xl);
    padding-bottom: var(--space-6xl);
  }

  @media (max-width: 600px) {
    .tool-page {
      padding-top: var(--space-2xl);
      padding-bottom: var(--space-4xl);
    }
  }
</style>
