---
import '../styles/fonts.css';
import '../styles/global.css';
import { FOUC_GUARD_SCRIPT } from '../lib/theme';
import Toaster from '../components/ui/Toaster.astro';
import SeoHead from '../components/seo/SeoHead.astro';
import type { SeoMeta } from '../lib/seo';
import { SITE_URL, SITE_BASE_IMAGE } from '../lib/seo';

interface Props extends SeoMeta {
  lang?: string;
  dir?: 'ltr' | 'rtl';
  noThemeColor?: boolean;
  /** When true, skip default Organization+WebSite JSON-LD schemas. */
  noDefaultSchema?: boolean;
  /** Additional JSON-LD schemas. */
  schemas?: Record<string, unknown>[];
}

const {
  title = 'ToolBox Image — Fast, Private Image Tools',
  description = 'The fastest, cleanest, most modern privacy-first online image toolkit. Compress, resize, convert, and optimize images entirely in your browser.',
  canonical,
  ogImage = SITE_BASE_IMAGE,
  ogType,
  publishedTime,
  author,
  tags,
  noIndex = false,
  lang = 'en',
  dir = 'ltr',
  noThemeColor = false,
  noDefaultSchema = false,
  schemas,
} = Astro.props;
---

<!doctype html>
<html lang={lang} dir={dir} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Prevent FOUC: resolve theme before first paint -->
    <script is:inline set:html={FOUC_GUARD_SCRIPT} />

    <!-- SEO: meta + JSON-LD -->
    <SeoHead
      {title}
      {description}
      lang={lang}
      canonical={canonical ?? `${SITE_URL}${Astro.url.pathname}`}
      {ogImage}
      {ogType}
      {publishedTime}
      {author}
      {tags}
      {noIndex}
      schemas={schemas}
      includeDefaultSchema={!noDefaultSchema}
    />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ToolBox" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Preconnect for critical third-party origins -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- DNS prefetch for any future CDN resources -->
    <link rel="dns-prefetch" href="https://toolboximage.com" />

    <!-- Preload critical body font; others load on demand via font-display: swap -->
    <link rel="preload" href="/fonts/geist/Geist-Regular.woff2" as="font" type="font/woff2" crossorigin fetchpriority="high" />

    <!-- Theme color -->
    {!noThemeColor && (
      <>
        <meta name="theme-color" content="#171717" media="(prefers-color-scheme: light)" />
        <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
      </>
    )}

    <!-- Speculation Rules: instant prefetch for all same-site navigations -->
    <script type="speculationrules">
      {
        "prefetch": [{
          "source": "document",
          "where": { "href_matches": "/*" },
          "eagerness": "moderate"
        }]
      }
    </script>

    <!-- Analytics — add Umami/Plausible here when ready -->
    <!-- GA commented out until consent banner is added
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZSL7XR9EY5"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ZSL7XR9EY5');
    </script>
    -->
  </head>
  <body class="min-h-screen text-ink antialiased">
    <!-- Accessibility: skip to main content for keyboard users -->
    <a href="#main" class="skip-link">Skip to content</a>

    <slot />

    <Toaster />

    <!-- Re-apply theme on load (handles system theme changes during navigation) -->
    <script>
      import { initTheme, watchSystemTheme } from '../lib/theme';
      initTheme();
      watchSystemTheme(() => initTheme());
    </script>
  </body>
</html>
