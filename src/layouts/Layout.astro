---
import '../styles/fonts.css';
import '../styles/global.css';
import { FOUC_GUARD_SCRIPT } from '../lib/theme';
import Toaster from '../components/ui/Toaster.astro';
import SeoHead from '../components/seo/SeoHead.astro';
import type { SeoMeta } from '../lib/seo';
import { SITE_URL, SITE_BASE_IMAGE } from '../lib/seo';

interface Props extends SeoMeta {
  noThemeColor?: boolean;
  /** When true, skip default Organization+WebSite JSON-LD schemas. */
  noDefaultSchema?: boolean;
  /** Additional JSON-LD schemas. */
  schemas?: Record<string, unknown>[];
}

const {
  title = 'ToolBox Image — Fast, Private Image Tools',
  description = 'The fastest, cleanest, most modern privacy-first online image toolkit. Compress, resize, convert, and optimize images entirely in your browser.',
  canonical,
  ogImage = SITE_BASE_IMAGE,
  ogType,
  publishedTime,
  author,
  tags,
  noIndex = false,
  noThemeColor = false,
  noDefaultSchema = false,
  schemas,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Prevent FOUC: resolve theme before first paint -->
    <script is:inline set:html={FOUC_GUARD_SCRIPT} />

    <!-- SEO: meta + JSON-LD -->
    <SeoHead
      {title}
      {description}
      canonical={canonical ?? `${SITE_URL}${Astro.url.pathname}`}
      {ogImage}
      {ogType}
      {publishedTime}
      {author}
      {tags}
      {noIndex}
      schemas={schemas}
      includeDefaultSchema={!noDefaultSchema}
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preconnect for critical third-party origins -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- DNS prefetch for any future CDN resources -->
    <link rel="dns-prefetch" href="https://toolboximage.com" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/geist/Geist-SemiBold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist/Geist-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist/Geist-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/geist-mono/GeistMono-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Prefetch the compressor page (highest-traffic route) -->
    <link rel="prefetch" href="/compressor/" />

    <!-- Theme color -->
    {!noThemeColor && (
      <>
        <meta name="theme-color" content="#171717" media="(prefers-color-scheme: light)" />
        <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
      </>
    )}

    <!-- Performance: hint the browser to pre-render the compressor page on idle -->
    <link rel="prerender" href="/compressor/" />
  </head>
  <body class="min-h-screen text-ink antialiased">
    <!-- Accessibility: skip to main content for keyboard users -->
    <a href="#main" class="skip-link">Skip to content</a>

    <slot />

    <Toaster />

    <!-- Re-apply theme on load (handles system theme changes during navigation) -->
    <script>
      import { initTheme, watchSystemTheme } from '../lib/theme';
      initTheme();
      watchSystemTheme(() => initTheme());
    </script>
  </body>
</html>
