---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import IconBox from '../components/ui/IconBox.astro';
import Badge from '../components/ui/Badge.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import Reveal from '../components/shared/Reveal.astro';
import MeshGradient from '../components/shared/MeshGradient.astro';
import DropZone from '../components/shared/DropZone.astro';
import BeforeAfter from '../components/shared/BeforeAfter.astro';
import Prose from '../components/shared/Prose.astro';
import FAQ from '../components/shared/FAQ.astro';
import { softwareAppSchema, breadcrumbSchema, faqSchema } from '../lib/seo';

// ---------- Copy / data -----------------------------------------------------

const whyItems = [
  {
    title: 'Files never leave your device.',
    body:
      'Every transformation runs in your browser via WebAssembly and the native canvas. There is no server, so there is nothing to leak.',
    icon: 'shield',
  },
  {
    title: 'No sign-up. No accounts.',
    body:
      'Open the page and start compressing. We do not collect email addresses, do not fingerprint your device, and do not run third-party analytics.',
    icon: 'user',
  },
  {
    title: 'Open formats. Honest output.',
    body:
      'We process the same standards your tools already speak — JPG, PNG, WebP, AVIF, GIF, SVG — and tell you exactly what we did.',
    icon: 'eye',
  },
];

const features = [
  {
    title: 'Drag & drop.',
    body: 'Drop a folder of 500 photos. We will handle the queue.',
    icon: 'mouse',
  },
  {
    title: 'Paste from clipboard.',
    body: 'Screenshot, ⌘V, done. No intermediate file.',
    icon: 'clipboard',
  },
  {
    title: 'Batch processing.',
    body: 'Process hundreds of images in parallel on web workers.',
    icon: 'stack',
  },
  {
    title: 'Format conversion.',
    body: 'JPG → WebP, PNG → AVIF — pick any source, any target.',
    icon: 'swap',
  },
  {
    title: 'Quality controls.',
    body: 'Fine-tune quality, target size, or visual parity per image.',
    icon: 'sliders',
  },
  {
    title: 'Side-by-side preview.',
    body: 'Compare before and after at full resolution before you download.',
    icon: 'compare',
  },
];

const steps = [
  {
    n: '01',
    title: 'Drop or paste.',
    body:
      'Drop a file, click to browse, or paste from your clipboard. Anything image-shaped works.',
  },
  {
    n: '02',
    title: 'Pick a target.',
    body:
      'Choose a quality level, target size, or output format. Smart defaults handle the rest.',
  },
  {
    n: '03',
    title: 'Compare side-by-side.',
    body:
      'Drag the divider. If the result looks right, download. If not, dial it in and try again.',
  },
  {
    n: '04',
    title: 'Download or batch save.',
    body:
      'Grab individual files or save everything as a zip. Nothing was ever uploaded.',
  },
];

const upcoming = [
  {
    title: 'Image Resizer',
    body: 'Pixel-perfect resize with smart cropping and aspect-ratio lock.',
    icon: 'resize',
    status: 'Next',
  },
  {
    title: 'Image Converter',
    body: 'Convert between JPG, PNG, WebP, AVIF with one click.',
    icon: 'convert',
    status: 'Soon',
  },
  {
    title: 'Image Cropper',
    body: 'Drag-to-crop with safe-area guides for social platforms.',
    icon: 'crop',
    status: 'Soon',
  },
  {
    title: 'Watermark',
    body: 'Tile or corner watermarks with opacity, scale, and rotation controls.',
    icon: 'watermark',
    status: 'Planned',
  },
  {
    title: 'Background Remover',
    body: 'One-click subject isolation. WebGPU-accelerated.',
    icon: 'magic',
    status: 'Planned',
  },
  {
    title: 'EXIF Cleaner',
    body: 'Strip metadata before sharing — keep the pixels, lose the trail.',
    icon: 'shield',
    status: 'Planned',
  },
];

const faq = [
  {
    q: 'Are my images uploaded to a server?',
    a: 'No. Every step — decoding, resizing, recompressing, encoding — runs in your browser using WebAssembly and the native canvas. Your images never touch our servers, our CDN, or any third party.',
  },
  {
    q: 'What file formats are supported?',
    a: 'JPG, PNG, WebP, GIF, AVIF, and SVG. Output can be any of those as well, so you can convert between formats in the same pass.',
  },
  {
    q: 'How does the compression work?',
    a: 'We re-encode your images using modern codecs (mozJPEG, libwebp, libaom-avif) compiled to WebAssembly. You choose a target quality, target size, or "lossless" — and we pick the right encoder settings to hit it.',
  },
  {
    q: 'Is there a file size limit?',
    a: 'No hard limit on the server (there is no server). The practical limit is your device\'s available memory — most browsers handle 4K photos without breaking a sweat, and hundreds of small images can be batched in parallel.',
  },
  {
    q: 'Will the quality actually suffer?',
    a: 'At smart defaults, the visual difference is imperceptible at normal viewing distances — but the file is dramatically smaller. Drag the before/after slider on this page to see for yourself.',
  },
  {
    q: 'Do I need to create an account?',
    a: 'No. There is no sign-up, no email, no subscription. ToolBox Image is free and unlimited, supported by <a href="/support/" class="faq-link">optional donations</a> and the occasional gentle nudge.',
  },
];
---

<Layout
  title="Free Online Image Compressor — Best Image Compressor Online | ToolBox Image"
  description="Free online image compressor — compress JPG, PNG, WebP, and AVIF images instantly in your browser. No uploads. No limits. No sign-up. The best free image compressor online."
  ogImage="/og-image.png"
  ogType="website"
  schemas={[
    softwareAppSchema(),
    breadcrumbSchema([{ name: 'Home', href: '/' }, { name: 'Image Tools', href: '/image-tools' }]),
  ]}
>
  <AppShell>
    <!-- ============================================================
         HERO
         ============================================================ -->
    <section class="hero">
      <MeshGradient intensity="normal" />

      <div class="container hero-inner">
        <Reveal>
          <Badge eyebrow="Free Image Compressor" tone="info" class="hero-badge">
            Image Compressor is live
          </Badge>
        </Reveal>

        <Reveal delay={80}>
          <h1 class="text-display-xl hero-title">
            Image tools that respect your privacy.
          </h1>
        </Reveal>

        <Reveal delay={160}>
          <p class="text-body-lg hero-subtitle">
            Compress, resize, convert, and optimize images entirely in your
            browser. No uploads. No tracking. No compromise.
          </p>
        </Reveal>

        <Reveal delay={220}>
          <div class="hero-actions">
            <Button label="Try the Tools" href="/image-tools/" variant="primary" size="lg">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </Button>
            <Button label="Try the Compressor" href="/compressor/" variant="secondary" size="lg" />
          </div>
        </Reveal>

        <Reveal delay={280}>
          <nav class="hero-links" aria-label="More pages">
            <a href="/about/" class="hero-link">About</a>
            <span class="hero-link-sep" aria-hidden="true">·</span>
            <a href="/contact/" class="hero-link">Contact</a>
            <span class="hero-link-sep" aria-hidden="true">·</span>
            <a href="/legal/privacy/" class="hero-link">Privacy</a>
            <span class="hero-link-sep" aria-hidden="true">·</span>
            <a href="/legal/terms/" class="hero-link">Terms</a>
          </nav>
        </Reveal>

        <Reveal delay={300}>
          <div class="hero-search">
            <svg class="hero-search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="search" class="hero-search-input" data-tool-search placeholder="Search tools…" aria-label="Search tools" />
          </div>
        </Reveal>

        <Reveal delay={360} class="hero-drop">
          <DropZone />
        </Reveal>
      </div>
    </section>

    <!-- ============================================================
         TOOL PICKER OVERLAY
         ============================================================ -->
    <div class="tool-picker-overlay" data-tool-picker-overlay hidden role="dialog" aria-label="Choose a tool" aria-modal="true">
      <div class="tool-picker-backdrop" data-tool-picker-close></div>
      <div class="tool-picker stack stack-lg">
        <div class="tool-picker-heading">
          <p class="text-display-sm tool-picker-title">
            Your image is ready — where should we go?
          </p>
          <p class="text-body-sm tool-picker-sub">
            Choose a tool to continue with your uploaded file.
          </p>
        </div>
        <div class="tool-picker-grid">
          {[
            { href: '/compressor/', label: 'Image Compressor', desc: 'Compress any format', icon: 'compress' },
            { href: '/tools/rotator/', label: 'Rotate Image', desc: '90°, 180°, custom', icon: 'rotate' },
            { href: '/bulk-image-compressor/', label: 'Bulk Compressor', desc: 'Batch 200 files', icon: 'bulk' },
            { href: '/image-compressor-100kb/', label: '100 KB Target', desc: 'Exact file size', icon: 'target' },
            { href: '/image-compressor-for-discord/', label: 'Discord Limit', desc: 'Under 8 MB', icon: 'discord' },
            { href: '/compress-for-email/', label: 'Email Attachments', desc: 'Under 25 MB', icon: 'email' },
          ].map((tool) => (
            <a href={tool.href} class="tool-picker-card" data-tool-picker-link>
              <div class="tool-picker-card-icon" aria-hidden="true">
                {tool.icon === 'compress' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>}
                {tool.icon === 'rotate' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>}
                {tool.icon === 'jpeg' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 8h6"/><path d="M9 12h6"/><path d="M9 16h4"/></svg>}
                {tool.icon === 'png' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8l-6 6v14a2 2 0 0 0 2 2z"/><path d="M18 13v5"/><path d="M14 13v5"/><path d="M10 13v3a2 2 0 0 0 4 0"/></svg>}
                {tool.icon === 'webp' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h2l1.5-4 1.5 4h2"/><path d="M16 12h-2"/></svg>}
                {tool.icon === 'avif' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5"/><path d="M9 12h2l1-3 1 3h2"/><path d="M16 9v6"/></svg>}
                {tool.icon === 'bulk' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>}
                {tool.icon === 'target' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>}
                {tool.icon === 'discord' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="4"/><path d="M8 16V8l8 4-8 4z"/></svg>}
                {tool.icon === 'email' && <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>}
              </div>
              <p class="text-body-sm-strong tool-picker-card-label">{tool.label}</p>
              <p class="text-caption tool-picker-card-desc">{tool.desc}</p>
            </a>
          ))}
        </div>
        <button type="button" class="tool-picker-cancel" data-tool-picker-close>
          Cancel — remove files
        </button>
      </div>
    </div>

    <script>
      import { storeFiles } from '../lib/file-transfer';

      const overlay = document.querySelector<HTMLElement>('[data-tool-picker-overlay]');
      const closeBtns = document.querySelectorAll<HTMLElement>('[data-tool-picker-close]');
      const links = document.querySelectorAll<HTMLAnchorElement>('[data-tool-picker-link]');

      window.addEventListener('toolboximage:files', async (e) => {
        const detail = (e as CustomEvent<{ files: File[] }>).detail;
        if (!detail?.files?.length) return;
        await storeFiles(detail.files);
        if (overlay) overlay.hidden = false;
      });

      closeBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (overlay) overlay.hidden = true;
        });
      });

      links.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const href = link.getAttribute('href');
          if (href) window.location.href = href;
        });
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay && !overlay.hidden) {
          overlay.hidden = true;
        }
      });
    </script>

    <!-- ============================================================
         TOOLS — TABS + GRID
         ============================================================ -->
    <section class="band band-canvas home-tools">
      <div class="container stack stack-2xl">
        <Reveal>
          <div class="home-tools-header">
            <Badge eyebrow="Toolbox" tone="info">All tools</Badge>
            <a href="/image-tools/" class="home-tools-link">View all →</a>
          </div>
        </Reveal>

        <!-- Tab bar -->
        <Reveal delay={10}>
          <nav class="tools-tabs" role="tablist" aria-label="Tool categories">
            {['All', 'Optimize', 'Convert', 'Resize', 'Edit'].map((tab, i) => (
              <button
                type="button"
                class:list={['tools-tab', i === 0 && 'tools-tab-active']}
                role="tab"
                aria-selected={i === 0}
                data-tools-tab={tab}
              >{tab}</button>
            ))}
          </nav>
        </Reveal>

        <!-- Tool grid -->
        <div class="tools-grid" data-tool-grid>
          {[
            { href: '/compressor/', label: 'Image Compressor', desc: 'Batch image compressor with adjustable quality. 100% secure & offline.', cat: 'Optimize', status: 'Live' },
            { href: '/bulk-image-compressor/', label: 'Bulk Compressor', desc: 'Batch process up to 200 images in parallel.', cat: 'Optimize', status: 'Live' },
            { href: '/image-compressor-100kb/', label: 'Compress to 100 KB', desc: 'Compress images to exactly 100 KB or less.', cat: 'Optimize', status: 'Live' },
            { href: '/image-compressor-for-discord/', label: 'Discord Image Limit', desc: 'Compress images to stay under Discord\'s 8 MB limit.', cat: 'Optimize', status: 'Live' },
            { href: '/compress-for-email/', label: 'Email Image Size', desc: 'Shrink images for email attachments (under 25 MB).', cat: 'Optimize', status: 'Live' },
            { href: '/tools/rotator/', label: 'Rotate Image', desc: 'Rotate and flip images with precision controls.', cat: 'Edit', status: 'Live' },
            { href: '/tools/converter/', label: 'Format Converter', desc: 'Convert images between JPEG, PNG, WebP, AVIF & more.', cat: 'Convert', status: 'Soon' },
            { href: '/tools/resizer/', label: 'Image Resizer', desc: 'Resize images to exact dimensions or aspect ratios.', cat: 'Resize', status: 'Soon' },
            { href: '/tools/cropper/', label: 'Image Cropper', desc: 'Crop images with preset ratios or freeform selection.', cat: 'Resize', status: 'Soon' },
            { href: '/tools/flipper/', label: 'Image Flipper', desc: 'Flip images horizontally, vertically, or both.', cat: 'Edit', status: 'Soon' },
            { href: '/tools/heic-converter/', label: 'HEIC to JPEG', desc: 'Convert Apple HEIC/HEIF photos to JPEG or PNG.', cat: 'Convert', status: 'Soon' },
            { href: '/tools/background-remover/', label: 'Background Remover', desc: 'Remove image backgrounds automatically.', cat: 'Edit', status: 'Planned' },
            { href: '/tools/blur/', label: 'Blur Image', desc: 'Blur faces, license plates, or custom regions.', cat: 'Edit', status: 'Planned' },
          ].map((tool) => (
            <a
              href={tool.href}
              class:list={['tool-card', tool.status !== 'Live' && 'tool-card-dim']}
              data-tool-cat={tool.cat}
              data-tool-status={tool.status}
            >
              <span class="tool-card-badge">{tool.cat.toUpperCase()}</span>
              <p class="text-body-sm-strong tool-card-label">{tool.label}</p>
              <p class="text-caption tool-card-desc">{tool.desc}</p>
              <span class="tool-card-status">
                {tool.status === 'Live' ? 'Free' : tool.status === 'Soon' ? 'Coming soon' : 'Planned'}
              </span>
            </a>
          ))}
        </div>

        <!-- Pagination -->
        <div class="tools-pagination" data-tools-pagination>
          <span class="tools-pagination-count text-caption" data-tools-count></span>
          <nav class="tools-pagination-nav" aria-label="Tool pages">
            <button type="button" class="tools-page-btn" data-page-prev disabled>Previous</button>
            <div class="tools-page-numbers" data-page-numbers></div>
            <button type="button" class="tools-page-btn" data-page-next disabled>Next</button>
          </nav>
        </div>
      </div>
    </section>

    <script>
      const PER_PAGE = 9;
      const searchInput = document.querySelector<HTMLInputElement>('[data-tool-search]');
      const toolGrid = document.querySelector<HTMLElement>('[data-tool-grid]');
      const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tools-tab]');
      const countEl = document.querySelector<HTMLElement>('[data-tools-count]');
      const prevBtn = document.querySelector<HTMLButtonElement>('[data-page-prev]');
      const nextBtn = document.querySelector<HTMLButtonElement>('[data-page-next]');
      const pageNumbersEl = document.querySelector<HTMLElement>('[data-page-numbers]');

      let activeTab = 'All';
      let currentPage = 1;
      let filteredCards: HTMLAnchorElement[] = [];

      const getFiltered = (): HTMLAnchorElement[] => {
        if (!toolGrid) return [];
        const cards = Array.from(toolGrid.querySelectorAll<HTMLAnchorElement>('.tool-card'));
        const q = searchInput?.value.toLowerCase().trim() || '';

        return cards.filter((card) => {
          const cat = card.dataset.toolCat || '';
          const label = card.querySelector('.tool-card-label')?.textContent?.toLowerCase() || '';
          const matchCat = activeTab === 'All' || cat === activeTab;
          const words = q ? label.split(' ') : [];
          const matchSearch = !q || label.startsWith(q) || words.some((w) => w.startsWith(q));
          return matchCat && matchSearch;
        });
      };

      const renderPage = () => {
        const total = filteredCards.length;
        const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;

        const start = (currentPage - 1) * PER_PAGE;
        const end = Math.min(start + PER_PAGE, total);

        // Show/hide cards
        toolGrid?.querySelectorAll<HTMLAnchorElement>('.tool-card').forEach((card, i) => {
          const inPage = i >= start && i < end;
          const isFiltered = filteredCards.includes(card);
          card.style.display = isFiltered && inPage ? '' : 'none';
        });

        // Count text
        if (countEl) {
          if (total === 0) {
            countEl.textContent = 'No tools found';
          } else {
            countEl.textContent = `Showing ${start + 1}–${end} of ${total} tools`;
          }
        }

        // Prev/Next
        if (prevBtn) prevBtn.disabled = currentPage <= 1;
        if (nextBtn) nextBtn.disabled = currentPage >= totalPages;

        // Page numbers
        if (pageNumbersEl) {
          pageNumbersEl.innerHTML = '';
          for (let p = 1; p <= totalPages; p++) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = `tools-page-num${p === currentPage ? ' tools-page-num-active' : ''}`;
            btn.textContent = String(p);
            btn.addEventListener('click', () => { currentPage = p; renderPage(); });
            pageNumbersEl.appendChild(btn);
          }
        }
      };

      const updateTools = () => {
        currentPage = 1;
        filteredCards = getFiltered();
        renderPage();
      };

      // Tab clicks
      tabs.forEach((btn) => {
        btn.addEventListener('click', () => {
          tabs.forEach((b) => {
            b.classList.remove('tools-tab-active');
            b.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('tools-tab-active');
          btn.setAttribute('aria-selected', 'true');
          activeTab = btn.dataset.toolsTab || 'All';
          updateTools();
        });
      });

      // Search
      if (searchInput) {
        searchInput.addEventListener('input', updateTools);
      }

      // Prev/Next
      prevBtn?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderPage(); } });
      nextBtn?.addEventListener('click', () => { if (currentPage < Math.ceil(filteredCards.length / PER_PAGE)) { currentPage++; renderPage(); } });

      // Initial
      updateTools();
    </script>

    <!-- ============================================================
         WHY TOOLBOX IMAGE
         ============================================================ -->
    <section class="band band-soft" id="why">
      <div class="container stack stack-3xl">
        <SectionHeader eyebrow="Why ToolBox Image" leadMaxWidth="560px">
          <h2 class="text-display-lg">Privacy isn't a feature. It's the architecture.</h2>
          <p class="lead">
            Most "free" image tools earn their keep by uploading your files,
            training on them, or showing you ads. We earn it by being the
            fastest, cleanest, most private tool on the web.
          </p>
        </SectionHeader>

        <div class="why-grid">
          {whyItems.map((w, i) => (
            <Reveal delay={i * 80}>
              <Card>
                <IconBox tone="soft">
                  {w.icon === 'shield' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                      <path d="m9 12 2 2 4-4"/>
                    </svg>
                  )}
                  {w.icon === 'user' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                      <circle cx="12" cy="7" r="4"/>
                    </svg>
                  )}
                  {w.icon === 'eye' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/>
                      <circle cx="12" cy="12" r="3"/>
                    </svg>
                  )}
                </IconBox>
                <h3 class="text-display-sm">{w.title}</h3>
