---
import CompressorPageLayout from '../layouts/CompressorPageLayout.astro';
import Badge from '../components/ui/Badge.astro';
import Reveal from '../components/shared/Reveal.astro';
import FAQ from '../components/shared/FAQ.astro';
import { faqSchema } from '../lib/seo';

const faqs = [
  {
    q: 'How much can you compress a JPEG?',
    a: 'A typical JPEG can be reduced by 40-80% without visible quality loss. Our compressor uses Mozilla\'s mozJPEG encoder, which produces smaller files than standard JPEG at the same quality setting. In Maximum mode, reductions of 80-90% are common, though visual artefacts may become noticeable.',
  },
  {
    q: 'Does JPEG compression lose quality?',
    a: 'JPEG is a lossy format by design — every re-encode discards some data. That said, at quality settings above 80 the visual difference from the original is imperceptible at normal viewing sizes. Our side-by-side comparison slider lets you verify quality before downloading.',
  },
  {
    q: 'Can I compress a JPEG without losing quality?',
    a: 'You can use Lossless mode for JPEG, which re-encodes without recompressing the image data. This can still reduce file size by stripping metadata and optimizing Huffman tables, but the savings are smaller than lossy compression — typically 5-15%.',
  },
  {
    q: 'What is the best JPEG quality setting?',
    a: 'Quality 75-85 is the sweet spot for web use: excellent compression with no visible loss. Quality 50-60 is usable for thumbnails and backgrounds. Below 30, blocky artefacts become obvious. Our Auto mode starts at quality 80 as a safe default.',
  },
  {
    q: 'Can I batch compress JPEG files?',
    a: 'Yes. Drop an entire folder of JPEGs and the queue processes them in parallel using all available CPU cores. Up to 200 files at once, each up to 100 MB.',
  },
];
---

<CompressorPageLayout
  title="Compress JPEG Images Online — Free JPEG Compressor | ToolBox Image"
  description="Compress JPEG images online with mozJPEG. Free JPEG compressor — reduce file size without losing quality. No uploads, no limits, no sign-up. Drop and compress."
  canonical="https://toolboximage.com/compress-jpeg/"
  defaultFormat="jpeg"
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Compress JPEG', href: '/compress-jpeg' },
  ]}
  schemas={[faqSchema(faqs)]}
>
  <section slot="hero">
    <Reveal>
      <Badge eyebrow="JPEG Compressor" tone="info">Free</Badge>
    </Reveal>
    <Reveal delay={80}>
      <h1 class="text-display-xl cp-title">Compress JPEG images online.</h1>
    </Reveal>
    <Reveal delay={160}>
      <p class="text-body-lg cp-lead">
        Drop a JPEG — or five hundred — and let mozJPEG shrink them down.
        No uploads, no server, no sign-up. Your photos stay on your device.
      </p>
    </Reveal>
  </section>

  <section class="band band-canvas" slot="content">
    <div class="container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-md">JPEG compression powered by mozJPEG.</h2>
        <p class="text-body-md cp-body-text">
          JPEG is the most widely used image format on the web, and for good
          reason: it offers excellent compression for photographic content.
          The key to good JPEG compression lies in the encoder. Our compressor
          uses mozJPEG — the same encoder that powers Firefox — compiled to
          WebAssembly. MozJPEG produces files that are 5-15% smaller than
          standard libjpeg at the same quality setting, with fewer artefacts
          in gradient-heavy areas like skies and skin tones.
        </p>
        <p class="text-body-md cp-body-text">
          You have full control over the compression. Use the quality slider
          (1-100) for precise control, enable target-size mode to hit a
          specific file size in KB, or switch to lossless mode to strip
          metadata while preserving every pixel. The progressive JPEG option
          creates images that render gradually as they load — ideal for
          slow connections.
        </p>
        <h3 class="text-display-sm">Why compress JPEG images?</h3>
        <p class="text-body-md cp-body-text">
          JPEG compression is essential for web performance. A typical photo
          from a modern smartphone is 4-8 MB. Compressed for the web, the
          same photo can be 200-600 KB with no visible quality difference.
          That is a 90% reduction in bandwidth and load time. For websites
          with many images — portfolios, e-commerce stores, news sites —
          this translates directly to faster pages, lower hosting costs,
          and better search rankings.
        </p>
        <p class="text-body-md cp-body-text">
          Our compressor is preconfigured for JPEG output. The settings panel
          defaults to JPEG format so you can start compressing immediately.
          All the advanced options — resize, metadata removal, progressive
          encoding — are still available in the Custom panel.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="band band-soft" slot="faq">
    <div class="container container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-lg">Frequently asked questions</h2>
      </Reveal>
      <Reveal delay={80}>
        <FAQ items={faqs} tone="light" />
      </Reveal>
    </div>
  </section>
</CompressorPageLayout>

<style>
  .cp-title { margin: 0; max-width: 18ch; }
  .cp-lead { margin: 0; color: var(--color-body); max-width: 56ch; }

  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }
  .band-canvas { background-color: var(--color-canvas); }
  .band-soft { background-color: var(--color-canvas-soft); }

  .cp-body-text {
    color: var(--color-body);
    max-width: 68ch;
  }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
  }
</style>
