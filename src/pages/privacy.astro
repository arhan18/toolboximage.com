---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';

const sections = [
  {
    title: 'No uploads. Ever.',
    body: 'ToolBox Image runs entirely in your browser. Image data never leaves your device, never touches a server, and is never shared with third parties.',
  },
  {
    title: 'No tracking. No cookies.',
    body: 'We do not set tracking cookies, do not fingerprint your device, and do not use third-party analytics on this site. The only thing we store is your theme preference.',
  },
  {
    title: 'No accounts required.',
    body: 'There is nothing to sign up for. Every tool is free, unlimited, and works the moment you open the page.',
  },
  {
    title: 'Open by default.',
    body: 'Our compression engine is built on open standards (WebAssembly, Canvas, the browser\'s native decoders). You can verify this yourself in DevTools.',
  },
];
---

<Layout
  title="Privacy — ToolBox Image"
  description="ToolBox Image runs entirely in your browser. No uploads, no tracking, no accounts. Your images never leave your device."
>
  <AppShell>
    <section class="section">
      <div class="container-narrow stack stack-lg">
        <p class="text-caption-mono" style="color:var(--color-mute);text-transform:uppercase;letter-spacing:0.05em;">
          Privacy
        </p>
        <h1 class="text-display-xl">Your images stay on your device.</h1>
        <p class="text-body-lg" style="color:var(--color-body);">
          Privacy is not a feature we added. It is the architecture. Here is how
          and why.
        </p>
        <div class="stack stack-2xl" style="margin-top:var(--space-lg);">
          {sections.map((s) => (
            <article class="stack stack-sm">
              <h2 class="text-display-sm">{s.title}</h2>
              <p class="text-body-md" style="color:var(--color-body);">{s.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </AppShell>
</Layout>