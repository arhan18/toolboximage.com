---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import Button from '../components/ui/Button.astro';
---

<Layout
  title="404 — Page Not Found — ToolBox Image"
  description="This page does not exist. Head back to the homepage or try the Compressor."
  noIndex={true}
>
  <AppShell>
    <section class="not-found">
      <div class="container not-found-inner">
        <p class="text-caption-mono not-found-code">404</p>
        <h1 class="text-display-lg not-found-title">Page not found</h1>
        <p class="text-body-md not-found-desc">
          The page you are looking for does not exist or has been moved.
        </p>
        <div class="not-found-actions">
          <Button label="Go home" href="/" variant="primary" size="lg" />
          <Button label="Open Compressor" href="/compressor/" variant="secondary" size="lg" />
        </div>
      </div>
    </section>
  </AppShell>
</Layout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 64px);
    padding: var(--space-4xl) 0;
  }

  .not-found-inner {
    text-align: center;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .not-found-code {
    color: var(--color-mute);
    font-size: var(--text-display-xl);
    line-height: 1;
    margin: 0;
  }

  .not-found-title {
    margin: 0;
  }

  .not-found-desc {
    color: var(--color-body);
    margin: 0;
  }

  .not-found-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }
</style>
