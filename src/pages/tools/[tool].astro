---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolUpload from '../../components/tools/ToolUpload.astro';
import ToolSettingsPanel from '../../components/tools/ToolSettingsPanel.astro';
import ToolProgress from '../../components/tools/ToolProgress.astro';
import ToolResultsSummary from '../../components/tools/ToolResultsSummary.astro';
import ToolFooter from '../../components/tools/ToolFooter.astro';
import RotatorTool from '../../components/tools/RotatorTool.astro';
import ConverterTool from '../../components/tools/ConverterTool.astro';
import ResizerTool from '../../components/tools/ResizerTool.astro';
import ToolSeoContent from '../../components/seo/ToolSeoContent.astro';
import { tools, getTool } from '../../lib/tools';
import type { ToolId } from '../../types';

export function getStaticPaths() {
  return tools
    .filter((t) => t.id !== 'compressor')
    .map((t) => ({ params: { tool: t.id } }));
}

const { tool: toolSlug } = Astro.params;
const tool = getTool(toolSlug as ToolId);

if (!tool) {
  return Astro.redirect('/404');
}
---

<ToolLayout {tool} lang="en">
  <main slot="tool-body" class="tool-body">
    {tool.status !== 'live' ? (
      <article class="coming-soon">
        <div class="coming-soon-card stack stack-lg">
          <div class="coming-soon-preview">
            <div class="coming-soon-illustration" aria-hidden="true">
              <svg viewBox="0 0 80 80" width="80" height="80" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-hairline-strong);">
                <rect x="8" y="8" width="64" height="64" rx="8" />
                <circle cx="28" cy="30" r="6" />
                <path d="M56 28L38 52l-8-10-12 16h44z" />
              </svg>
            </div>
            <div class="coming-soon-info">
              <div class="coming-soon-stat">
                <span class="text-caption-mono coming-soon-stat-label">Input formats</span>
                <span class="text-body-sm">{tool.inputFormats?.map((f) => f.replace('image/', '').toUpperCase()).join(', ') ?? '—'}</span>
              </div>
              {tool.outputFormats ? (
                <div class="coming-soon-stat">
                  <span class="text-caption-mono coming-soon-stat-label">Output formats</span>
                  <span class="text-body-sm">{tool.outputFormats.join(', ')}</span>
                </div>
              ) : null}
              <div class="coming-soon-stat">
                <span class="text-caption-mono coming-soon-stat-label">Max files</span>
                <span class="text-body-sm">{tool.maxInputs ?? '—'}</span>
              </div>
              {tool.requiresWasm ? (
                <div class="coming-soon-note">
                  <span class="text-caption-mono">Requires WebAssembly</span>
                  <p class="text-body-sm">This tool needs a client-side Wasm module. We will ship it as soon as the model is ready.</p>
                </div>
              ) : null}
            </div>
          </div>
          <p class="text-body-md coming-soon-body">
            {tool.longDescription ?? tool.description}
          </p>
        </div>
      </article>
    ) : (
      <article class="workflow stack stack-lg">
        {tool.id === 'rotator' ? (
          <><RotatorTool /><ToolSeoContent toolId="rotator" lang="en" /></>
        ) : tool.id === 'converter' ? (
          <><ConverterTool /><ToolSeoContent toolId="converter" lang="en" /></>
        ) : tool.id === 'resizer' ? (
          <><ResizerTool /><ToolSeoContent toolId="resizer" lang="en" /></>
        ) : (
          <>
            <ToolUpload {tool} />
            <ToolSettingsPanel {tool}>
              <div slot="settings-controls">
                <p class="text-body-sm" style="color:var(--color-body);">Configure this tool once it is available.</p>
              </div>
            </ToolSettingsPanel>
            <ToolProgress toolId={tool.id} />
            <ToolResultsSummary {tool}>
              <div slot="results-content" data-tool-results-content>
                <p class="text-body-sm" style="color:var(--color-body);">Processing output will appear here.</p>
              </div>
            </ToolResultsSummary>
            <ToolFooter {tool} />
          </>
        )}
      </article>
    )}
  </main>
</ToolLayout>

<style>
  .tool-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  /* ── Coming soon card ─────────────────────────────────────── */
  .coming-soon {
    display: flex;
    justify-content: center;
  }

  .coming-soon-card {
    max-width: 540px;
    width: 100%;
    padding: var(--space-2xl);
    background-color: var(--color-canvas);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-2);
  }

  .coming-soon-preview {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xl);
    padding: var(--space-lg);
    background-color: var(--color-canvas-soft);
    border-radius: var(--radius-md);
  }

  .coming-soon-illustration {
    flex-shrink: 0;
  }

  .coming-soon-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .coming-soon-stat {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .coming-soon-stat-label {
    color: var(--color-mute);
    min-width: 100px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .coming-soon-note {
    margin-top: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-warning-soft);
    border-radius: var(--radius-sm);
  }

  .coming-soon-note .text-caption-mono {
    color: var(--color-warning-deep);
  }

  .coming-soon-note .text-body-sm {
    color: var(--color-body);
    margin: var(--space-xs) 0 0;
  }

  .coming-soon-body {
    color: var(--color-body);
  }

  /* ── Workflow shell ───────────────────────────────────────── */
  .workflow > * {
    min-width: 0;
  }

  /* ── Rotator controls ─────────────────────────────────────── */
  .rotator-controls {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .rotator-presets {
    border: none;
    margin: 0;
    padding: 0;
  }

  .rotator-label {
    color: var(--color-mute);
    margin: 0 0 var(--space-sm);
    display: block;
  }

  .rotator-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-xs);
  }

  .rotator-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: var(--space-sm) var(--space-xs);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    color: var(--color-ink);
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .rotator-btn:hover {
    background: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }

  .rotator-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  .rotator-btn[data-active="true"] {
    border-color: var(--color-link);
    background: color-mix(in srgb, var(--color-link) 10%, transparent);
  }

  .rotator-btn-label {
    font-size: 11px;
    line-height: 1;
    color: var(--color-body);
  }

  .rotator-custom {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .rotator-input {
    width: 80px;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    color: var(--color-ink);
    font-size: var(--text-body-sm);
    font-family: var(--font-mono);
    text-align: center;
  }

  .rotator-input:focus {
    outline: none;
    border-color: var(--color-link);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-link) 20%, transparent);
  }

  .rotator-unit {
    color: var(--color-mute);
  }

  /* ── Rotator live preview ──────────────────────────────────── */
  .rotator-preview-area {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-canvas);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-2);
  }

  .rotator-preview-fig {
    margin: 0;
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .rotator-preview-label {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .rotator-preview-frame {
    position: relative;
    width: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-conic-gradient(var(--color-hairline) 0% 25%, transparent 0% 50%) 0 0 / 16px 16px;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .rotator-preview-img {
    max-width: 100%;
    max-height: 320px;
    object-fit: contain;
    display: block;
  }

  .rotator-preview-size {
    margin: 0;
    color: var(--color-body);
  }

  .rotator-preview-arrow {
    flex-shrink: 0;
    color: var(--color-mute);
  }

  /* ── Rotator download ──────────────────────────────────────── */
  .rotator-download {
    background: var(--color-canvas);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-2);
    overflow: hidden;
  }

  .rotator-download-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-lg);
  }

  .rotator-download-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .rotator-download-label {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .rotator-download-info .text-body-sm-strong {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rotator-download .results-btn {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    height: 40px;
    padding: 0 var(--space-md);
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    cursor: pointer;
    font-family: inherit;
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    transition: background-color var(--dur-fast) var(--ease-out-quart), color var(--dur-fast) var(--ease-out-quart), transform var(--dur-fast) var(--ease-out-quart), box-shadow var(--dur-fast) var(--ease-out-quart);
    white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
  }

  .rotator-download .results-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-tight);
  }

  .rotator-download .results-btn:active:not(:disabled) {
    transform: scale(0.985);
  }

  .rotator-download .results-btn-primary {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .rotator-download .results-btn-primary:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px -6px rgb(0 0 0 / 0.28);
  }

  @media (max-width: 600px) {
    .rotator-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .rotator-preview-area {
      flex-direction: column;
    }
    .rotator-preview-arrow {
      transform: rotate(90deg);
    }
  }
</style>

<script>
  import { getTool } from '../../lib/tools';

  const el = document.querySelector<HTMLElement>('[data-tool-settings]');
  if (el && el.dataset.toolId === 'rotator') {
    const presetBtns = document.querySelectorAll<HTMLButtonElement>('[data-rotator-preset]');
    const customInput = document.querySelector<HTMLInputElement>('[data-rotator-custom]');
    const previewArea = document.querySelector<HTMLElement>('[data-rotator-preview]');
    const origImg = document.querySelector<HTMLImageElement>('[data-rotator-original-img]');
    const origSize = document.querySelector<HTMLElement>('[data-rotator-original-size]');
    const resultImg = document.querySelector<HTMLImageElement>('[data-rotator-result-img]');
    const resultSize = document.querySelector<HTMLElement>('[data-rotator-result-size]');
    const resultLabel = document.querySelector<HTMLElement>('[data-rotator-result-label]');
    const downloadSection = document.querySelector<HTMLElement>('[data-rotator-download]');
    const downloadBtn = document.querySelector<HTMLButtonElement>('[data-rotator-download-btn]');

    const downloadNameEl = document.querySelector<HTMLElement>('[data-rotator-download-name]');
    let currentFile: File | null = null;
    let originalImg: HTMLImageElement | null = null;
    let currentImg: HTMLImageElement | null = null;
    let currentBlobUrl: string | null = null;
    let transformCount = 0;

    const formatBytes = (bytes: number): string => {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    };

    const dataUrlToBlob = (dataUrl: string): Blob => {
      const parts = dataUrl.split(',');
      const mime = parts[0].match(/:(.*?);/)![1];
      const bytes = atob(parts[1]);
      const arr = new Uint8Array(bytes.length);
      for (let i = 0; i < bytes.length; i++) arr[i] = bytes.charCodeAt(i);
      return new Blob([arr], { type: mime });
    };

    const transformOne = (img: HTMLImageElement, transform: number): { blob: Blob; width: number; height: number } => {
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d')!;
      const w = img.width;
      const h = img.height;

      if (transform === -90) {
        canvas.width = w; canvas.height = h;
        ctx.translate(w, 0); ctx.scale(-1, 1);
        ctx.drawImage(img, 0, 0);
      } else if (transform === -180) {
        canvas.width = w; canvas.height = h;
        ctx.translate(0, h); ctx.scale(1, -1);
        ctx.drawImage(img, 0, 0);
      } else if (transform === 0) {
        canvas.width = w; canvas.height = h;
        ctx.drawImage(img, 0, 0);
      } else {
        const rad = (transform * Math.PI) / 180;
        const sin = Math.abs(Math.sin(rad));
        const cos = Math.abs(Math.cos(rad));
        canvas.width = Math.round(w * cos + h * sin);
        canvas.height = Math.round(w * sin + h * cos);
        ctx.translate(canvas.width / 2, canvas.height / 2);
        ctx.rotate(rad);
        ctx.drawImage(img, -w / 2, -h / 2);
      }
      return { blob: dataUrlToBlob(canvas.toDataURL('image/png')), width: canvas.width, height: canvas.height };
    };

    const loadBlob = (blob: Blob): Promise<HTMLImageElement> =>
      new Promise((resolve) => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.src = URL.createObjectURL(blob);
      });

    const applyAndShow = async (transform: number) => {
      if (!currentImg) return;

      // Apply transform to currentImg (which is the latest state)
      const result = transformOne(currentImg, transform);

      // Revoke old blob URL
      if (currentBlobUrl) URL.revokeObjectURL(currentBlobUrl);

      // Create new blob URL for preview + future transforms
      currentBlobUrl = URL.createObjectURL(result.blob);

      // Update preview
      if (resultImg) resultImg.src = currentBlobUrl;
      if (resultSize) resultSize.textContent = `${result.width} × ${result.height} · ${formatBytes(result.blob.size)}`;
      if (downloadSection) downloadSection.hidden = false;

      // Load result into currentImg for the next transform
      const nextImg = await loadBlob(result.blob);
      nextImg.width = result.width;
      nextImg.height = result.height;
      currentImg = nextImg;
      transformCount++;

      // Update label
      if (resultLabel) {
        const name = transform === -90 ? 'Flip H' : transform === -180 ? 'Flip V' : `Rotate ${transform}°`;
        resultLabel.textContent = `Step ${transformCount}: ${name}`;
      }

      // Update download info
      if (downloadNameEl && currentFile) {
        const ext = currentFile.name.split('.').pop() || 'jpg';
        downloadNameEl.textContent = currentFile.name.replace(/\.[^.]+$/, '') + '_edited.' + ext;
      }
    };

    // Preset clicks — apply transform to current state
    presetBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const deg = Number(btn.dataset.rotatorPreset);
        presetBtns.forEach((b) => b.dataset.active = String(b === btn));
        if (customInput) customInput.value = '0';
        applyAndShow(deg);
      });
    });

    if (customInput) {
      customInput.addEventListener('input', () => {
        presetBtns.forEach((b) => b.dataset.active = 'false');
        const deg = Number(customInput.value) || 0;
        applyAndShow(deg);
      });
    }

    // Download — saves current preview
    if (downloadBtn) {
      downloadBtn.addEventListener('click', () => {
        if (!currentFile || !currentBlobUrl) return;
        const ext = currentFile.name.split('.').pop() || 'jpg';
        const name = currentFile.name.replace(/\.[^.]+$/, '') + '_edited.' + ext;
        const a = document.createElement('a');
        a.href = currentBlobUrl;
        a.download = name;
        a.click();
      });
    }

    // Called when files arrive
    const onFilesReceived = async (files: File[]) => {
      if (!files.length) return;
      const file = files[0];
      currentFile = file;
      transformCount = 0;

      const origUrl = URL.createObjectURL(file);
      const img = new Image();
      await new Promise<void>((resolve, reject) => {
        img.onload = () => resolve();
        img.onerror = () => reject(new Error('Failed to load'));
        img.src = origUrl;
      });

      originalImg = img;
      currentImg = img;

      // Show original
      if (origImg) origImg.src = origUrl;
      if (origSize) origSize.textContent = `${img.width} × ${img.height} · ${formatBytes(file.size)}`;

      if (previewArea) previewArea.hidden = false;

      // Show preview = original
      if (resultImg) resultImg.src = origUrl;
      if (resultSize) resultSize.textContent = `${img.width} × ${img.height} · ${formatBytes(file.size)}`;
      if (resultLabel) resultLabel.textContent = 'Original';
      if (downloadSection) downloadSection.hidden = true;
    };

    // Listen for file selection
    window.addEventListener('toolboximage:files', async (e: Event) => {
      const detail = (e as CustomEvent).detail;
      if (detail?.files?.length) {
        onFilesReceived(detail.files);
      }
    });

    // Retrieve files from IndexedDB (homepage picker)
    (async () => {
      const { retrieveFiles } = await import('../../lib/file-transfer');
      const files = await retrieveFiles();
      if (files.length) {
        onFilesReceived(files);
      }
    })();
  }
</script>
