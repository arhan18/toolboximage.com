---
import CompressorPageLayout from '../layouts/CompressorPageLayout.astro';
import Badge from '../components/ui/Badge.astro';
import Reveal from '../components/shared/Reveal.astro';
import FAQ from '../components/shared/FAQ.astro';
import { faqSchema, howToSchema } from '../lib/seo';

const faqs = [
  {
    q: 'What is the Discord image upload limit?',
    a: 'Discord allows file uploads up to 8 MB for free users and 25 MB for Discord Nitro subscribers. Images larger than these limits are rejected. Our compressor helps you meet both limits with target-size mode.',
  },
  {
    q: 'What image format works best for Discord?',
    a: 'For screenshots with text, PNG is best because it preserves sharp edges. For photos and memes, JPEG or WebP give smaller files. Discord supports all common formats including PNG, JPEG, GIF, and WebP.',
  },
  {
    q: 'Can I compress multiple images for Discord at once?',
    a: 'Yes. Drop a folder of screenshots or images and the batch queue processes them all in parallel. Each one is compressed to stay under Discord\'s limits. Then drag them all from your download folder straight into a Discord channel.',
  },
  {
    q: 'Does Discord compress images I upload?',
    a: 'Yes, Discord re-encodes images to reduce file size. This can cause quality loss, especially for PNGs with text. Pre-compressing your images with optimal settings before uploading gives you more control over the final quality.',
  },
  {
    q: 'How do I set the right file size for Discord?',
    a: 'Use the target-size setting in the Custom panel — enter 8000 KB (8 MB) for free accounts or 25000 KB (25 MB) for Nitro. The encoder handles the rest, automatically finding the best quality that stays under the limit.',
  },
];

const howToSteps = [
  { name: 'Drop your screenshot or image', text: 'Drag any image file onto the upload area. PNG screenshots, JPEG photos, and WebP images are all supported.' },
  { name: 'Set the Discord target size', text: 'The compressor is preconfigured for 8 MB (free Discord). Adjust to 25 MB in Custom mode if you have Nitro.' },
  { name: 'Compress and preview', text: 'Each image is compressed to stay under the Discord limit. Use the comparison slider to verify text and detail clarity.' },
  { name: 'Drag to Discord', text: 'Download the compressed files and drag them straight into your Discord channel. No more "file too large" errors.' },
];
---

<CompressorPageLayout
  title="Image Compressor for Discord — Compress Images for Discord | ToolBox Image"
  description="Compress images for Discord's upload limits. Free online image compressor — batch compress screenshots, memes, and photos before sharing on Discord. No uploads."
  canonical="https://toolboximage.com/image-compressor-for-discord/"
  ogImage="/og-discord-compressor.png"
  defaultTargetSize={8000}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Image Tools', href: '/image-tools' },
    { name: 'Discord Compressor', href: '/image-compressor-for-discord' },
  ]}
  schemas={[faqSchema(faqs), howToSchema(howToSteps)]}
>
  <section slot="hero">
    <Reveal>
      <Badge eyebrow="Discord Compressor" tone="info">Free</Badge>
    </Reveal>
    <Reveal delay={80}>
      <h1 class="text-display-xl cp-title">Image compressor for Discord.</h1>
    </Reveal>
    <Reveal delay={160}>
      <p class="text-body-lg cp-lead">
        Discord limits uploads to 8 MB (free) or 25 MB (Nitro). Compress
        your screenshots, game clips, and memes before sharing — all in
        your browser, nothing uploaded to a server.
      </p>
    </Reveal>
  </section>

  <section class="band band-canvas" slot="content">
    <div class="container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-md">Never hit the Discord upload limit again.</h2>
        <p class="text-body-md cp-body-text">
          Discord's upload limit is generous — 8 MB for free users and
          25 MB for Nitro — but modern screenshots and high-resolution
          photos can easily exceed these limits. A single 4K screenshot from
          a modern game can be 15-20 MB as PNG. A photo from a 48 MP phone
          camera can be 10-15 MB as JPEG. Without compression, you end up
          converting to lower-resolution versions, losing detail just to
          share an image with friends.
        </p>
        <p class="text-body-md cp-body-text">
          Our compressor solves this with target-size mode. Set the target to
          8000 KB (free) or 25000 KB (Nitro), and the encoder automatically
          finds the optimal quality and resolution to stay under the limit.
          The result preserves far more detail than Discord's own server-side
          recompression, which applies aggressive settings to every uploaded
          image. By pre-compressing your images, you keep control over the
          quality — especially important for screenshots with text, where
          Discord's compression can introduce distracting artefacts.
        </p>
        <h3 class="text-display-sm">Batch compress your Discord screenshots.</h3>
        <p class="text-body-md cp-body-text">
          The compressor is preconfigured with a target of 8 MB for Discord
          free users. Drop an entire folder of screenshots, memes, or photos
          and the queue processes them in parallel. Each image is compressed
          to stay under the limit with maximum possible quality. Download
          them all as a ZIP and drag the entire batch into your Discord
          channel — no more "file too large" errors.
        </p>
        <p class="text-body-md cp-body-text">
          If you have Discord Nitro, adjust the target to 25000 KB in the
          Custom settings. The larger limit means you can preserve
          higher quality for important screenshots and photos. You can
          also convert between formats — for example, converting a large PNG
          screenshot to high-quality JPEG or WebP for significant size
          savings with minimal visual impact. For format-specific
          compression, see our
          <a href="/compress-jpeg/" class="cp-inline-link">JPEG compressor</a>,
          <a href="/compress-png/" class="cp-inline-link">PNG compressor</a>,
          <a href="/compress-webp/" class="cp-inline-link">WebP compressor</a>, and
          <a href="/compress-avif/" class="cp-inline-link">AVIF compressor</a>.
        </p>
        <h3 class="text-display-sm">Tips for Discord image sharing</h3>
        <p class="text-body-md cp-body-text">
          For game screenshots, use PNG for text-heavy UI (setting menus,
          chat windows) and JPEG for scenic in-game shots. WebP is a good
          middle ground — smaller than PNG with better quality than JPEG at
          the same size. If Discord's built-in compression degrades your
          images noticeably, pre-compress at a slightly higher quality and
          use the target-size mode to stay under the limit. The
          <a href="/bulk-image-compressor/" class="cp-inline-link">bulk compressor</a>
          is ideal for processing entire screenshot folders before uploading.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="band band-soft" slot="faq">
    <div class="container container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-lg">Frequently asked questions</h2>
      </Reveal>
      <Reveal delay={80}>
        <FAQ items={faqs} tone="light" />
      </Reveal>
    </div>
  </section>
</CompressorPageLayout>

<style>
  .cp-title { margin: 0; max-width: 18ch; }
  .cp-lead { margin: 0; color: var(--color-body); max-width: 56ch; }

  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }
  .band-canvas { background-color: var(--color-canvas); }
  .band-soft { background-color: var(--color-canvas-soft); }

  .cp-body-text {
    color: var(--color-body);
    max-width: 68ch;
  }

  .cp-inline-link {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-link) 35%, transparent);
    transition: color var(--dur-fast) var(--ease-out-quart), text-decoration-color var(--dur-fast) var(--ease-out-quart);
  }

  .cp-inline-link:hover {
    color: var(--color-link-deep);
    text-decoration-color: var(--color-link-deep);
  }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
  }
</style>
