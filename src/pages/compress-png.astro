---
import CompressorPageLayout from '../layouts/CompressorPageLayout.astro';
import Badge from '../components/ui/Badge.astro';
import Reveal from '../components/shared/Reveal.astro';
import FAQ from '../components/shared/FAQ.astro';
import { faqSchema } from '../lib/seo';

const faqs = [
  {
    q: 'Can you compress a PNG without losing quality?',
    a: 'Yes. PNG supports lossless compression, which reduces file size without changing a single pixel. Our compressor uses optimized filter strategies and deflate compression to shrink lossless PNGs by 10-40% with identical output.',
  },
  {
    q: 'Does PNG compression preserve transparency?',
    a: 'Absolutely. The alpha channel, gamma correction, and color profiles are all preserved during compression. Your transparent PNGs stay transparent with the exact same pixel values.',
  },
  {
    q: 'What is the difference between lossy and lossless PNG compression?',
    a: 'Lossless PNG compression re-encodes the image data more efficiently without changing any pixels — the output is mathematically identical to the input. Lossy PNG compression (quantization) reduces the number of distinct colours, which can dramatically shrink file size at the cost of some precision. This is useful for PNG photographs where the format choice adds overhead.',
  },
  {
    q: 'When should I use PNG instead of JPEG?',
    a: 'PNG is best for images with sharp edges, text, logos, screenshots, and graphics with transparency. JPEG excels at photographs and gradients. If your image has fewer than 256 colours, PNG will often be smaller than JPEG even before compression.',
  },
  {
    q: 'Can I batch compress PNG files?',
    a: 'Yes. Drop a folder of PNGs and the queue processes them in parallel. Up to 200 files at once with no individual size limit beyond your device memory.',
  },
];
---

<CompressorPageLayout
  title="Compress PNG Images Online — Free PNG Compressor | ToolBox Image"
  description="Compress PNG images online with lossless and lossy modes. Free PNG compressor — preserve transparency while reducing file size. No uploads, no limits."
  canonical="https://toolboximage.com/compress-png/"
  defaultFormat="png"
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Compress PNG', href: '/compress-png' },
  ]}
  schemas={[faqSchema(faqs)]}
>
  <section slot="hero">
    <Reveal>
      <Badge eyebrow="PNG Compressor" tone="info">Free</Badge>
    </Reveal>
    <Reveal delay={80}>
      <h1 class="text-display-xl cp-title">Compress PNG images online.</h1>
    </Reveal>
    <Reveal delay={160}>
      <p class="text-body-lg cp-lead">
        Shrink your PNGs without breaking transparency. Lossless mode
        preserves every pixel. Lossy mode slashes file sizes. Both keep
        your alpha channel intact.
      </p>
    </Reveal>
  </section>

  <section class="band band-canvas" slot="content">
    <div class="container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-md">PNG compression with full control.</h2>
        <p class="text-body-md cp-body-text">
          PNG is the go-to format for screenshots, logos, icons, and any
          image that needs crisp edges or transparency. The trade-off is
          file size — PNG files are typically larger than JPEG for
          photographic content. Our compressor gives you two paths to
          smaller PNGs: lossless and lossy.
        </p>
        <p class="text-body-md cp-body-text">
          Lossless mode re-encodes the PNG with optimized filter strategies
          (the per-row prediction method) and maximum deflate compression.
          Every pixel stays identical — only the file gets smaller. This is
          ideal for design assets where pixel-perfect fidelity matters. Lossy
          mode uses colour quantization to reduce the palette size, which can
          dramatically cut file size for photographs stored as PNG. The
          encoder intelligently reduces colour precision where it won't be
          noticed, preserving edges and gradients.
        </p>
        <h3 class="text-display-sm">When to use PNG compression.</h3>
        <p class="text-body-md cp-body-text">
          If you work with UI designs, screenshots, or images with text
          overlays, PNG is usually the right format. Compressing those PNGs
          before uploading them to a website or sharing them with a team
          saves bandwidth without sacrificing the sharpness that makes PNG
          valuable in the first place. For images that need transparency —
          logos, icons, product cutouts — PNG is irreplaceable, and our
          compressor keeps your alpha channel safe.
        </p>
        <p class="text-body-md cp-body-text">
          The compressor is preconfigured for PNG output, so you can start
          immediately. The Custom panel gives you access to all settings
          including quality, target file size, resize options, and metadata
          stripping.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="band band-soft" slot="faq">
    <div class="container container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-lg">Frequently asked questions</h2>
      </Reveal>
      <Reveal delay={80}>
        <FAQ items={faqs} tone="light" />
      </Reveal>
    </div>
  </section>
</CompressorPageLayout>

<style>
  .cp-title { margin: 0; max-width: 18ch; }
  .cp-lead { margin: 0; color: var(--color-body); max-width: 56ch; }

  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }
  .band-canvas { background-color: var(--color-canvas); }
  .band-soft { background-color: var(--color-canvas-soft); }

  .cp-body-text {
    color: var(--color-body);
    max-width: 68ch;
  }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
  }
</style>
