---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import CompressorTool from '../components/tools/CompressorTool.astro';
import { softwareAppSchema, breadcrumbSchema } from '../lib/seo';
---
<Layout
  title="Compress Images Online — Free Browser-Based Tool | ToolBox Image"
  description="Compress JPG, PNG, WebP, GIF, AVIF, SVG, and HEIC images without ever leaving your browser. Drop a folder of 500 photos — we'll handle the queue."
  ogImage="/og-image-compressor.png"
  schemas={[
    softwareAppSchema(),
    breadcrumbSchema([
      { name: 'Home', href: '/' },
      { name: 'Image Tools', href: '/image-tools' },
      { name: 'Compressor', href: '/compressor' },
    ]),
  ]}
>
  <AppShell hideFooter={true}>
    <CompressorTool />
  </AppShell>
</Layout>
