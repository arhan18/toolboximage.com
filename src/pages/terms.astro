---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';

const sections = [
  {
    title: 'Acceptance',
    body: 'By using ToolBox Image you agree to these terms. If you do not agree, please do not use the service.',
  },
  {
    title: 'License',
    body: 'ToolBox Image is provided free of charge for personal and commercial use. You retain full ownership of every file you process through the tools.',
  },
  {
    title: 'No warranty',
    body: 'The service is provided "as is" without warranty of any kind. We do our best to keep the tools accurate and reliable, but you are responsible for verifying that the output meets your needs.',
  },
  {
    title: 'Limitations',
    body: 'You agree not to use the service to violate any law, infringe on any third-party right, or attempt to disrupt the service for other users.',
  },
  {
    title: 'Changes',
    body: 'We may update these terms occasionally. Continued use of the service after changes constitutes acceptance of the new terms.',
  },
];
---

<Layout
  title="Terms — ToolBox Image"
  description="The terms of service for ToolBox Image — a free, browser-based image toolkit."
>
  <AppShell>
    <section class="section">
      <div class="container-narrow stack stack-lg">
        <p class="text-caption-mono" style="color:var(--color-mute);text-transform:uppercase;letter-spacing:0.05em;">
          Terms
        </p>
        <h1 class="text-display-xl">Terms of service.</h1>
        <p class="text-body-lg" style="color:var(--color-body);">
          Plain-English rules for using ToolBox Image.
        </p>
        <div class="stack stack-2xl" style="margin-top:var(--space-lg);">
          {sections.map((s, i) => (
            <article class="stack stack-sm">
              <h2 class="text-display-sm">
                <span class="text-caption-mono" style="color:var(--color-mute);margin-right:var(--space-xs);">
                  {String(i + 1).padStart(2, '0')}
                </span>
                {s.title}
              </h2>
              <p class="text-body-md" style="color:var(--color-body);">{s.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </AppShell>
</Layout>