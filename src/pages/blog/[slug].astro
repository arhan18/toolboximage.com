---
import Layout from '../../layouts/Layout.astro';
import AppShell from '../../components/layout/AppShell.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import Reveal from '../../components/shared/Reveal.astro';
import Prose from '../../components/shared/Prose.astro';
import BlogPostContent from '../../components/blog/BlogPostContent.astro';
import { posts, getAllTags, formatDate } from '../../lib/blog';
import { articleSchema, breadcrumbSchema } from '../../lib/seo';

export function getStaticPaths() {
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = posts.find((p) => p.slug === slug);
if (!post) {
  return Astro.redirect('/blog');
}

const categoryTone: Record<string, 'info' | 'success' | 'warning' | 'neutral'> = {
  guides: 'info',
  tutorials: 'warning',
  technology: 'neutral',
  privacy: 'success',
  general: 'neutral',
};

const related = posts
  .filter(
    (p) =>
      p.slug !== post.slug &&
      (p.category === post.category || p.tags.some((t) => post.tags.includes(t)))
  )
  .slice(0, 3);

const allTags = getAllTags();
---

<Layout
  title={`${post.title} — ToolBox Image`}
  description={post.description}
  ogType="article"
  ogImage="/og-image.png"
  publishedTime={post.date}
  author={post.author}
  tags={post.tags}
  schemas={[
    articleSchema({
      slug: post.slug,
      title: post.title,
      description: post.description,
      date: post.date,
      author: post.author,
      tags: post.tags,
      readMinutes: post.readMinutes,
    }),
    breadcrumbSchema([
      { name: 'Home', href: '/' },
      { name: 'Blog', href: '/blog' },
      { name: post.title, href: `/blog/${post.slug}` },
    ]),
  ]}
>
  <AppShell>
    <section class="post-hero">
      <div class="container container-narrow">
        <Reveal>
          <a href="/blog/" class="post-back text-body-sm">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            All posts
          </a>
        </Reveal>
        <Reveal delay={80}>
          <div class="post-meta">
            <Badge tone={categoryTone[post.category] || 'neutral'} eyebrow={post.category}>
              {formatDate(post.date)}
            </Badge>
            <span class="text-caption post-time">{post.readMinutes} min read</span>
          </div>
        </Reveal>
        <Reveal delay={140}>
          <h1 class="text-display-xl post-title">{post.title}</h1>
        </Reveal>
        <Reveal delay={200}>
          <p class="text-body-lg post-lead">{post.description}</p>
        </Reveal>
        <Reveal delay={240}>
          <p class="text-caption post-author">By {post.author}</p>
        </Reveal>
      </div>
    </section>

    <section class="band band-canvas">
      <div class="container post-layout">
        <div class="post-main">
          <Reveal>
            <Prose>
              <BlogPostContent slug={post.slug} lang="en" />
            </Prose>
          </Reveal>

          <!-- Tags -->
          {post.tags.length > 0 && (
            <Reveal delay={80}>
              <div class="post-tags">
                <span class="text-caption-mono post-tags-heading">Tags</span>
                <div class="post-tags-list">
                  {post.tags.map((tag) => (
                    <a href={`/blog/?tag=${tag}`} class="post-tag">#{tag}</a>
                  ))}
                </div>
              </div>
            </Reveal>
          )}

          <Reveal delay={120}>
            <div class="post-cta">
              <Button label="Try the Compressor" href="/compressor/" variant="primary" size="lg">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              </Button>
              <Button label="More posts" href="/blog/" variant="secondary" size="lg" />
            </div>
          </Reveal>
        </div>

        <!-- Sidebar -->
        <aside class="post-sidebar">
          <Reveal delay={100}>
            <div class="sidebar-card">
              <h3 class="text-caption-mono sidebar-heading">Related posts</h3>
              {related.length > 0 ? (
                <ul class="recent-list">
                  {related.map((rp) => (
                    <li>
                      <a href={`/blog/${rp.slug}/`} class="recent-link">
                        <span class="recent-title">{rp.title}</span>
                        <span class="text-caption recent-date">{formatDate(rp.date)}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-body-sm" style="color: var(--color-mute); margin: 0;">
                  No related posts yet.
                </p>
              )}
            </div>
          </Reveal>

          <Reveal delay={160}>
            <div class="sidebar-card">
              <h3 class="text-caption-mono sidebar-heading">Browse by tag</h3>
              <div class="tag-cloud">
                {allTags.slice(0, 20).map((tag) => (
                  <a href={`/blog/?tag=${tag}`} class="tag-link">#{tag}</a>
                ))}
              </div>
            </div>
          </Reveal>

          <Reveal delay={220}>
            <div class="sidebar-card sidebar-cta">
              <h3 class="text-caption-mono sidebar-heading">Try the Compressor</h3>
              <p class="text-body-sm">
                Compress images right in your browser — no uploads, no tracking, no limits.
              </p>
              <a href="/compressor/" class="sidebar-button">Start compressing</a>
            </div>
          </Reveal>
        </aside>
      </div>
    </section>
  </AppShell>
</Layout>

<style>
  .post-hero {
    padding: calc(var(--space-6xl) + var(--space-2xl)) 0 var(--space-4xl);
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
  }

  .post-back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-mute);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-lg);
    transition: color 0.15s ease, gap 0.2s ease;
  }

  .post-back:hover {
    color: var(--color-ink);
    gap: var(--space-sm);
  }

  .post-back:focus-visible {
    outline: none;
    color: var(--color-ink);
    box-shadow: var(--focus-ring-tight);
    border-radius: var(--radius-xs);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .post-time {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }

  .post-title {
    margin: 0;
    max-width: 24ch;
    text-wrap: balance;
  }

  .post-lead {
    margin: var(--space-md) 0 0;
    color: var(--color-body);
    max-width: 60ch;
  }

  .post-author {
    margin: var(--space-lg) 0 0;
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }

  .band-canvas { background-color: var(--color-canvas); }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-3xl);
    align-items: start;
  }

  .post-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* Tags */
  .post-tags {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-hairline);
    border-bottom: 1px solid var(--color-hairline);
  }

  .post-tags-heading {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .post-tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .post-tag {
    display: inline-flex;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    color: var(--color-body);
    text-decoration: none;
    border: 1px solid var(--color-hairline);
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart);
  }

  .post-tag:hover {
    border-color: var(--color-hairline-strong);
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .post-cta {
    padding-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* Sidebar */
  .post-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    position: sticky;
    top: var(--space-4xl);
  }

  .sidebar-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-lg);
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
  }

  .sidebar-heading {
    margin: 0;
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .recent-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    color: var(--color-ink);
    padding: var(--space-xs) 0;
    transition: color var(--dur-fast) var(--ease-out-quart);
  }

  .recent-link:hover {
    color: var(--color-link);
  }

  .recent-title {
    font-size: var(--font-size-sm);
    font-weight: var(--weight-medium);
    line-height: 1.3;
  }

  .recent-date {
    color: var(--color-mute);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag-link {
    display: inline-flex;
    padding: 2px var(--space-xs);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    color: var(--color-body);
    text-decoration: none;
    border: 1px solid var(--color-hairline);
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart);
  }

  .tag-link:hover {
    border-color: var(--color-hairline-strong);
    color: var(--color-ink);
  }

  .sidebar-cta p {
    color: var(--color-body);
    margin: 0;
  }

  .sidebar-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-sm) var(--space-lg);
    background-color: var(--color-link);
    color: white;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--weight-semibold);
    transition: opacity var(--dur-fast) var(--ease-out-quart);
  }

  .sidebar-button:hover {
    opacity: 0.85;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-back { transition: none; }
  }

  @media (max-width: 800px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      position: static;
      order: 2;
    }

    .post-main {
      order: 1;
    }
  }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
    .post-hero { padding: var(--space-4xl) 0 var(--space-3xl); }
  }
</style>
