---
import Layout from '../../layouts/Layout.astro';
import AppShell from '../../components/layout/AppShell.astro';
import { breadcrumbSchema } from '../../lib/seo';
import Badge from '../../components/ui/Badge.astro';
import Reveal from '../../components/shared/Reveal.astro';
import EmptyState from '../../components/shared/EmptyState.astro';
import { posts, getAllCategories, getAllTags, getFeaturedPosts, formatDate } from '../../lib/blog';

const category = Astro.url.searchParams.get('category') || 'all';
const activeTag = Astro.url.searchParams.get('tag') || '';

const allCategories = getAllCategories();
const allTags = getAllTags();
const featured = getFeaturedPosts();

let filtered = category === 'all' ? posts : posts.filter((p) => p.category === category);
if (activeTag) {
  filtered = filtered.filter((p) => p.tags.includes(activeTag));
}

const categoryLabels: Record<string, string> = {
  all: 'All Posts',
  guides: 'Guides',
  tutorials: 'Tutorials',
  technology: 'Technology',
  privacy: 'Privacy',
  general: 'General',
};

const categoryTone: Record<string, string> = {
  guides: 'info',
  tutorials: 'warning',
  technology: 'neutral',
  privacy: 'success',
  general: 'neutral',
};
---

<Layout
  title="Blog — ToolBox Image"
  description="Guides, tutorials, and deep-dives on image compression, privacy-first tools, and web performance."
  schemas={[
    breadcrumbSchema([
      { name: 'Home', href: '/' },
      { name: 'Blog', href: '/blog' },
    ]),
  ]}
>
  <AppShell>
    <section class="blog-hero">
      <div class="container container-narrow">
        <Reveal>
          <Badge eyebrow="Blog" tone="info">Resources</Badge>
        </Reveal>
        <Reveal delay={80}>
          <h1 class="text-display-xl blog-title">Guides, tutorials & ideas.</h1>
        </Reveal>
        <Reveal delay={140}>
          <p class="text-body-lg blog-lead">
            Image compression deep-dives, privacy-first engineering, and
            practical guides to getting the most out of your images.
          </p>
        </Reveal>
      </div>
    </section>

    <section class="band band-canvas">
      <div class="container blog-layout">
        <div class="blog-main">
          <!-- Category tabs -->
          <Reveal>
            <nav class="category-tabs" aria-label="Filter by category">
              {allCategories.map((cat) => {
                const isActive = category === cat;
                const count = cat === 'all' ? posts.length : posts.filter((p) => p.category === cat).length;
                return (
                  <a
                    href={activeTag ? `/blog/?category=${cat}&tag=${activeTag}` : `/blog/?category=${cat}`}
                    class:list={['category-tab', isActive && 'category-tab-active']}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {categoryLabels[cat] || cat}
                    <span class="category-count">{count}</span>
                  </a>
                );
              })}
            </nav>
          </Reveal>

          <!-- Active tag indicator -->
          {activeTag && (
            <Reveal delay={40}>
              <div class="active-filter">
                <span class="text-caption">Filtered by tag:</span>
                <Badge tone="info">#{activeTag}</Badge>
                <a href={category === 'all' ? '/blog/' : `/blog/?category=${category}`} class="clear-filter text-body-sm">
                  Clear
                </a>
              </div>
            </Reveal>
          )}

          <!-- Featured posts (only show on 'all' with no tag filter) -->
          {category === 'all' && !activeTag && featured.length > 0 && (
            <section class="featured-section">
              <Reveal delay={60}>
                <h2 class="text-display-xs featured-heading">Featured</h2>
              </Reveal>
              <div class="featured-grid">
                {featured.map((post, i) => (
                  <Reveal delay={80 + i * 60}>
                    <a href={`/blog/${post.slug}/`} class="featured-card">
                      <div class="featured-card-body">
                        <div class="blog-card-meta">
                          <Badge tone={categoryTone[post.category]} eyebrow={post.category}>
                            {formatDate(post.date)}
                          </Badge>
                          <span class="text-caption blog-card-time">{post.readMinutes} min read</span>
                        </div>
                        <h3 class="text-display-sm featured-card-title">{post.title}</h3>
                        <p class="text-body-sm featured-card-desc">{post.description}</p>
                        <div class="featured-tags">
                          {post.tags.slice(0, 3).map((tag) => (
                            <span class="tag-pill">#{tag}</span>
                          ))}
                        </div>
                      </div>
                    </a>
                  </Reveal>
                ))}
              </div>
            </section>
          )}

          <!-- Post list -->
          <div class="blog-list-wrap">
            {filtered.length === 0 ? (
              <EmptyState
                eyebrow="No posts"
                title="Nothing here yet."
                description="Try a different category or tag."
              />
            ) : (
              filtered.map((post, i) => (
                <Reveal delay={i * 40}>
                  <a href={`/blog/${post.slug}/`} class="blog-card">
                    <div class="blog-card-meta">
                      <Badge tone={categoryTone[post.category]} eyebrow={post.category}>
                        {formatDate(post.date)}
                      </Badge>
                      <span class="text-caption blog-card-time">{post.readMinutes} min read</span>
                    </div>
                    <h2 class="text-display-sm blog-card-title">{post.title}</h2>
                    <p class="text-body-sm blog-card-desc">
                      {post.description}
                    </p>
                    <div class="blog-card-tags">
                      {post.tags.slice(0, 3).map((tag) => (
                        <span class="tag-pill">#{tag}</span>
                      ))}
                    </div>
                    <span class="text-body-sm-strong blog-card-cta">
                      Read more
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                      </svg>
                    </span>
                  </a>
                </Reveal>
              ))
            )}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="blog-sidebar">
          <Reveal delay={100}>
            <div class="sidebar-card">
              <h3 class="text-caption-mono sidebar-heading">Browse by tag</h3>
              <div class="tag-cloud">
                {allTags.map((tag) => {
                  const count = posts.filter((p) => p.tags.includes(tag)).length;
                  const isActiveTag = activeTag === tag;
                  return (
                    <a
                      href={category === 'all' ? `/blog/?tag=${tag}` : `/blog/?category=${category}&tag=${tag}`}
                      class:list={['tag-link', isActiveTag && 'tag-link-active']}
                    >
                      #{tag}
                      <span class="tag-count">{count}</span>
                    </a>
                  );
                })}
              </div>
            </div>
          </Reveal>

          <Reveal delay={160}>
            <div class="sidebar-card">
              <h3 class="text-caption-mono sidebar-heading">Recent posts</h3>
              <ul class="recent-list">
                {posts.slice(0, 5).map((post) => (
                  <li>
                    <a href={`/blog/${post.slug}/`} class="recent-link">
                      <span class="recent-title">{post.title}</span>
                      <span class="text-caption recent-date">{formatDate(post.date)}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </Reveal>

          <Reveal delay={220}>
            <div class="sidebar-card sidebar-cta">
              <h3 class="text-caption-mono sidebar-heading">Try the Compressor</h3>
              <p class="text-body-sm">
                Compress images right in your browser — no uploads, no tracking, no limits.
              </p>
              <a href="/compressor/" class="sidebar-button">Start compressing</a>
            </div>
          </Reveal>
        </aside>
      </div>
    </section>
  </AppShell>
</Layout>

<style>
  .blog-hero {
    padding: calc(var(--space-6xl) + var(--space-2xl)) 0 var(--space-3xl);
    background-color: var(--color-canvas);
  }

  .blog-title { margin: var(--space-md) 0 0; max-width: 18ch; text-wrap: balance; }
  .blog-lead { margin: var(--space-md) 0 0; color: var(--color-body); max-width: 56ch; }

  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }

  .band-canvas { background-color: var(--color-canvas); }

  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-3xl);
    align-items: start;
  }

  .blog-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    min-width: 0;
  }

  /* Category tabs */
  .category-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-hairline);
  }

  .category-tab {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-hairline);
    background-color: var(--color-canvas-soft);
    color: var(--color-body);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--font-size-xs);
    font-weight: var(--weight-medium);
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart);
  }

  .category-tab:hover {
    border-color: var(--color-hairline-strong);
    color: var(--color-ink);
  }

  .category-tab-active {
    background-color: var(--color-link-bg-soft);
    border-color: transparent;
    color: var(--color-link-deep);
  }

  [data-theme="dark"] .category-tab-active {
    color: var(--color-link);
  }

  .category-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: var(--radius-full);
    background-color: var(--color-canvas);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    line-height: 1;
  }

  .category-tab-active .category-count {
    background-color: var(--color-canvas-soft);
  }

  /* Active filter indicator */
  .active-filter {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-canvas-soft);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-hairline);
  }

  .clear-filter {
    color: var(--color-link);
    text-decoration: none;
    margin-left: auto;
  }

  .clear-filter:hover {
    text-decoration: underline;
  }

  /* Featured section */
  .featured-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .featured-heading {
    margin: 0;
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    background: linear-gradient(
      135deg,
      var(--color-canvas-soft) 0%,
      var(--color-canvas) 100%
    );
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-ink);
    transition:
      border-color var(--dur-base) var(--ease-out-quart),
      transform var(--dur-base) var(--ease-out-quart),
      box-shadow var(--dur-base) var(--ease-out-quart);
  }

  .featured-card:hover {
    border-color: var(--color-hairline-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-3);
  }

  .featured-card:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-color: var(--color-link);
  }

  .featured-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    height: 100%;
  }

  .featured-card-title {
    margin: 0;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .featured-card-desc {
    margin: 0;
    color: var(--color-body);
    text-wrap: pretty;
    flex: 1;
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
  }

  /* Tag pills */
  .tag-pill {
    font-size: var(--font-size-xs);
    color: var(--color-mute);
    font-weight: var(--weight-medium);
  }

  /* Post list */
  .blog-list-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-xl);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-ink);
    transition:
      border-color var(--dur-base) var(--ease-out-quart),
      transform var(--dur-base) var(--ease-out-quart),
      box-shadow var(--dur-base) var(--ease-out-quart),
      background-color var(--dur-base) var(--ease-out-quart);
  }

  .blog-card:hover {
    border-color: var(--color-hairline-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-3);
  }

  .blog-card:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-color: var(--color-link);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-mute);
  }

  .blog-card-time {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--weight-medium);
    font-variant-numeric: tabular-nums;
  }

  .blog-card-title {
    margin: 0;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .blog-card-desc {
    margin: 0;
    color: var(--color-body);
    text-wrap: pretty;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
  }

  .blog-card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-link);
    margin-top: var(--space-xs);
    transition: gap var(--dur-base) var(--ease-out-quart);
  }

  .blog-card:hover .blog-card-cta {
    gap: var(--space-sm);
  }

  /* Sidebar */
  .blog-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    position: sticky;
    top: var(--space-4xl);
  }

  .sidebar-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-lg);
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
  }

  .sidebar-heading {
    margin: 0;
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px var(--space-xs);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    color: var(--color-body);
    text-decoration: none;
    border: 1px solid var(--color-hairline);
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart);
  }

  .tag-link:hover {
    border-color: var(--color-hairline-strong);
    color: var(--color-ink);
  }

  .tag-link-active {
    background-color: var(--color-link-bg-soft);
    border-color: transparent;
    color: var(--color-link-deep);
  }

  [data-theme="dark"] .tag-link-active {
    color: var(--color-link);
  }

  .tag-count {
    font-size: 10px;
    color: var(--color-mute);
  }

  .recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .recent-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    color: var(--color-ink);
    padding: var(--space-xs) 0;
    transition: color var(--dur-fast) var(--ease-out-quart);
  }

  .recent-link:hover {
    color: var(--color-link);
  }

  .recent-title {
    font-size: var(--font-size-sm);
    font-weight: var(--weight-medium);
    line-height: 1.3;
  }

  .recent-date {
    color: var(--color-mute);
  }

  .sidebar-cta p {
    color: var(--color-body);
    margin: 0;
  }

  .sidebar-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-sm) var(--space-lg);
    background-color: var(--color-link);
    color: white;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--weight-semibold);
    transition: opacity var(--dur-fast) var(--ease-out-quart);
  }

  .sidebar-button:hover {
    opacity: 0.85;
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-card, .blog-card-cta, .featured-card { transition: none; }
  }

  @media (max-width: 800px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }

    .blog-sidebar {
      position: static;
      order: 2;
    }

    .blog-main {
      order: 1;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
    .blog-hero { padding: var(--space-4xl) 0 var(--space-2xl); }
    .blog-card { padding: var(--space-lg); }
    .featured-card { padding: var(--space-lg); }
  }
</style>
