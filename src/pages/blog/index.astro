---
import Layout from '../../layouts/Layout.astro';
import AppShell from '../../components/layout/AppShell.astro';
import BlogIndexPage from '../../components/blog/BlogIndexPage.astro';
import { breadcrumbSchema } from '../../lib/seo';

const category = Astro.url.searchParams.get('category') || 'all';
const activeTag = Astro.url.searchParams.get('tag') || '';
---

<Layout
  title="Blog — ToolBox Image"
  description="Guides, tutorials, and deep-dives on image compression, privacy-first tools, and web performance."
  schemas={[
    breadcrumbSchema([
      { name: 'Home', href: '/' },
      { name: 'Blog', href: '/blog' },
    ]),
  ]}
>
  <AppShell>
    <BlogIndexPage lang="en" category={category} activeTag={activeTag} />
  </AppShell>
</Layout>
