---
import Layout from '../../layouts/Layout.astro';
import AppShell from '../../components/layout/AppShell.astro';
import Badge from '../../components/ui/Badge.astro';
import PageHeader from '../../components/shared/PageHeader.astro';
import Reveal from '../../components/shared/Reveal.astro';
import { posts, formatDate } from '../../lib/blog';

const toneByTag: Record<string, 'info' | 'success' | 'warning'> = {
  engineering: 'info',
  design: 'warning',
  announcement: 'success',
};
---

<Layout
  title="Blog — ToolBox Image"
  description="Notes on privacy, performance, and the craft of building browser-native tools."
>
  <AppShell>
    <section class="blog-hero">
      <div class="container container-narrow">
        <Reveal>
          <Badge eyebrow="Blog" tone="info">Notes</Badge>
        </Reveal>
        <Reveal delay={80}>
          <h1 class="text-display-xl blog-title">Notes on craft.</h1>
        </Reveal>
        <Reveal delay={140}>
          <p class="text-body-lg blog-lead">
            Engineering deep-dives, design decisions, and the occasional
            announcement. No growth-hacking — just the work.
          </p>
        </Reveal>
      </div>
    </section>

    <section class="band band-canvas">
      <div class="container container-narrow blog-list-wrap">
        {posts.map((post, i) => (
          <Reveal delay={i * 60}>
            <a href={`/blog/${post.slug}`} class="blog-card">
              <div class="blog-card-meta">
                <Badge tone={toneByTag[post.tag]} eyebrow={post.tag}>
                  {post.date ? formatDate(post.date) : ''}
                </Badge>
                <span class="text-caption blog-card-time">{post.readMinutes} min read</span>
              </div>
              <h2 class="text-display-sm blog-card-title">{post.title}</h2>
              <p class="text-body-sm" style="color:var(--color-body);">
                {post.description}
              </p>
              <span class="text-body-sm-strong blog-card-cta">
                Read more
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </a>
          </Reveal>
        ))}
      </div>
    </section>
  </AppShell>
</Layout>

<style>
  .blog-hero {
    padding: calc(var(--space-6xl) + var(--space-2xl)) 0 var(--space-3xl);
    background-color: var(--color-canvas);
  }

  .blog-title { margin: var(--space-md) 0 0; max-width: 18ch; }
  .blog-lead { margin: var(--space-md) 0 0; color: var(--color-body); max-width: 56ch; }

  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }

  .band-canvas { background-color: var(--color-canvas); }

  .blog-list-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-xl);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-ink);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .blog-card:hover {
    border-color: var(--color-hairline-strong);
    transform: translateY(-1px);
    box-shadow: var(--shadow-3);
  }

  .blog-card:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-mute);
  }

  .blog-card-time {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .blog-card-title {
    margin: 0;
  }

  .blog-card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-link);
    margin-top: var(--space-xs);
    transition: gap 0.2s ease;
  }

  .blog-card:hover .blog-card-cta {
    gap: var(--space-sm);
  }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
    .blog-hero { padding: var(--space-4xl) 0 var(--space-2xl); }
    .blog-card { padding: var(--space-lg); }
  }
</style>
