---
import CompressorPageLayout from '../layouts/CompressorPageLayout.astro';
import Badge from '../components/ui/Badge.astro';
import Reveal from '../components/shared/Reveal.astro';
import FAQ from '../components/shared/FAQ.astro';
import { faqSchema } from '../lib/seo';

const faqs = [
  {
    q: 'Is AVIF better than WebP?',
    a: 'AVIF typically achieves 30-50% better compression than WebP at the same quality level, especially for photographic content. It uses the AV1 codec from the Alliance for Open Media — the same codec used by Netflix and YouTube. The trade-off is slower encoding, which our parallel queue handles by processing images simultaneously.',
  },
  {
    q: 'What browsers support AVIF?',
    a: 'AVIF is supported by Chrome (85+), Firefox (93+), Safari (16.1+), and Edge (121+). Coverage is over 92% of global browser usage. For the remaining users, you can use a JPEG or WebP fallback.',
  },
  {
    q: 'Does AVIF support transparency?',
    a: 'Yes. AVIF supports full alpha channel transparency, HDR (PQ and HLG), wide colour gamut (P3, Rec.2020), 10-bit and 12-bit depth, and lossless compression. It is the most feature-rich image format available.',
  },
  {
    q: 'Is AVIF good for photography?',
    a: 'AVIF excels at photography. The AV1 codec handles gradients, textures, and fine detail much more efficiently than JPEG or WebP. A 10 MB JPEG can often be reduced to 1-2 MB as AVIF with no visible quality difference.',
  },
  {
    q: 'Can I batch compress images to AVIF?',
    a: 'Yes. Drop any supported image format and set the output to AVIF. The queue processes files in parallel. AVIF encoding is slower than JPEG or WebP, so parallel processing helps maintain throughput.',
  },
];
---

<CompressorPageLayout
  title="Compress AVIF Images Online — Free AVIF Compressor | ToolBox Image"
  description="Compress AVIF images online with the AV1 codec. Free AVIF compressor — smaller files than WebP with better quality. Browser-based, private, unlimited."
  canonical="https://toolboximage.com/compress-avif/"
  defaultFormat="avif"
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Compress AVIF', href: '/compress-avif' },
  ]}
  schemas={[faqSchema(faqs)]}
>
  <section slot="hero">
    <Reveal>
      <Badge eyebrow="AVIF Compressor" tone="info">Free</Badge>
    </Reveal>
    <Reveal delay={80}>
      <h1 class="text-display-xl cp-title">Compress AVIF images online.</h1>
    </Reveal>
    <Reveal delay={160}>
      <p class="text-body-lg cp-lead">
        AVIF is the most efficient image format on the web — 50% smaller
        than JPEG at the same quality. Our libaom-based compressor lets
        you create production-ready AVIF files entirely in your browser.
      </p>
    </Reveal>
  </section>

  <section class="band band-canvas" slot="content">
    <div class="container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-md">AVIF compression with the AV1 codec.</h2>
        <p class="text-body-md cp-body-text">
          AVIF (AV1 Image File Format) represents the state of the art in
          image compression. Built on the AV1 video codec from the Alliance
          for Open Media, AVIF delivers compression efficiency that
          significantly outperforms JPEG, PNG, and WebP — typically 50%
          smaller than JPEG and 30% smaller than WebP at equivalent visual
          quality.
        </p>
        <p class="text-body-md cp-body-text">
          Our compressor uses libaom — the reference AV1 encoder — compiled
          to WebAssembly. You can adjust quality (1-100) and speed preset.
          The speed setting trades encoding time for compression density:
          slower speeds produce smaller files but take longer to encode. This
          is particularly useful for batch jobs where you can let the queue
          run while you work. AVIF also supports HDR, wide colour gamut,
          lossless compression, and full alpha transparency — making it
          suitable for virtually any use case.
        </p>
        <h3 class="text-display-sm">Why choose AVIF compression?</h3>
        <p class="text-body-md cp-body-text">
          If you are building for the modern web, AVIF is the format that
          future-proofs your images. The compression gains translate directly
          to faster page loads, lower CDN bills, and better Core Web Vitals
          scores. For photographers and designers, AVIF's support for HDR
          and wide colour gamut means your images look better on modern
          displays while taking up less space.
        </p>
        <p class="text-body-md cp-body-text">
          The compressor is preconfigured for AVIF output with optimal
          quality settings. Use the Custom panel to tune the quality and
          speed presets, set a target file size, or enable resize.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="band band-soft" slot="faq">
    <div class="container container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-lg">Frequently asked questions</h2>
      </Reveal>
      <Reveal delay={80}>
        <FAQ items={faqs} tone="light" />
      </Reveal>
    </div>
  </section>
</CompressorPageLayout>

<style>
  .cp-title { margin: 0; max-width: 18ch; }
  .cp-lead { margin: 0; color: var(--color-body); max-width: 56ch; }

  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }
  .band-canvas { background-color: var(--color-canvas); }
  .band-soft { background-color: var(--color-canvas-soft); }

  .cp-body-text {
    color: var(--color-body);
    max-width: 68ch;
  }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
  }
</style>
