---
import CompressorPageLayout from '../layouts/CompressorPageLayout.astro';
import Badge from '../components/ui/Badge.astro';
import Reveal from '../components/shared/Reveal.astro';
import FAQ from '../components/shared/FAQ.astro';
import { faqSchema } from '../lib/seo';

const faqs = [
  {
    q: 'Is WebP better than JPEG?',
    a: 'WebP typically produces files 25-35% smaller than JPEG at the same quality level, with fewer artefacts in gradient areas. It also supports transparency (alpha channel) and animation — features JPEG cannot offer. Browser support is near-universal, making WebP a safe choice for modern websites.',
  },
  {
    q: 'Does WebP support transparency?',
    a: 'Yes. WebP has full alpha channel support, similar to PNG. Our compressor preserves transparency while independently optimizing the colour and alpha planes for maximum compression.',
  },
  {
    q: 'What is the difference between lossy and lossless WebP?',
    a: 'Lossy WebP uses a block-based predictive coding scheme similar to VP8 video compression. It produces much smaller files but can show artefacts at low quality. Lossless WebP uses a completely different algorithm based on spatial prediction and colour cache — it achieves excellent compression for graphics and screenshots without any quality loss.',
  },
  {
    q: 'Can I convert JPEG to WebP?',
    a: 'Yes. Drop a JPEG and set the output format to WebP. The compressor re-encodes from the source into WebP using libwebp. This typically saves an additional 25-35% compared to the original JPEG.',
  },
  {
    q: 'Is WebP supported by all browsers?',
    a: 'WebP is supported by Chrome, Firefox, Safari (since 14+), Edge, and Opera. That covers over 97% of global browser usage. For the remaining 3%, you can serve a JPEG fallback or use our SVG output.',
  },
];
---

<CompressorPageLayout
  title="Compress WebP Images Online — Free WebP Compressor | ToolBox Image"
  description="Compress WebP images online with libwebp. Free WebP compressor — lossy and lossless modes, alpha channel support, batch processing. No uploads."
  canonical="https://toolboximage.com/compress-webp/"
  defaultFormat="webp"
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Compress WebP', href: '/compress-webp' },
  ]}
  schemas={[faqSchema(faqs)]}
>
  <section slot="hero">
    <Reveal>
      <Badge eyebrow="WebP Compressor" tone="info">Free</Badge>
    </Reveal>
    <Reveal delay={80}>
      <h1 class="text-display-xl cp-title">Compress WebP images online.</h1>
    </Reveal>
    <Reveal delay={160}>
      <p class="text-body-lg cp-lead">
        WebP already delivers smaller files than JPEG and PNG — but you
        can still squeeze more out. Our libwebp-based compressor gives you
        full control over quality, method, and file size.
      </p>
    </Reveal>
  </section>

  <section class="band band-canvas" slot="content">
    <div class="container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-md">WebP compression powered by libwebp.</h2>
        <p class="text-body-md cp-body-text">
          WebP is Google's modern image format designed to replace JPEG, PNG,
          and GIF with a single format that offers superior compression across
          the board. A WebP image is typically 25-35% smaller than an
          equivalent JPEG and 26% smaller than PNG — all while supporting
          transparency and animation.
        </p>
        <p class="text-body-md cp-body-text">
          Our compressor uses Google's libwebp encoder compiled to
          WebAssembly. You get fine-grained control over compression: adjust
          quality (1-100), choose between lossy and lossless modes, set the
          compression method (0-6, where higher means smaller but slower),
          and enable alpha channel optimisation. The compression method
          setting is particularly useful — method 4 is a good balance of
          speed and density, while method 6 squeezes out every last byte at
          the cost of encoding time.
        </p>
        <h3 class="text-display-sm">Why use WebP compression?</h3>
        <p class="text-body-md cp-body-text">
          WebP is already one of the most efficient image formats available.
          Re-compressing existing WebP images might seem unnecessary, but
          many tools save WebP with suboptimal settings — high quality
          settings that produce files larger than needed, or low method
          values that leave compression gains on the table. Our compressor
          lets you re-encode WebP files with optimal settings for your use
          case, whether that is maximum quality for a hero image or maximum
          compression for thumbnails.
        </p>
        <p class="text-body-md cp-body-text">
          The compressor is preconfigured for WebP output. Switch to Custom
          mode to fine-tune every parameter, set a target file size, or
          resize before encoding.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="band band-soft" slot="faq">
    <div class="container container-narrow stack stack-lg">
      <Reveal>
        <h2 class="text-display-lg">Frequently asked questions</h2>
      </Reveal>
      <Reveal delay={80}>
        <FAQ items={faqs} tone="light" />
      </Reveal>
    </div>
  </section>
</CompressorPageLayout>

<style>
  .cp-title { margin: 0; max-width: 18ch; }
  .cp-lead { margin: 0; color: var(--color-body); max-width: 56ch; }

  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }
  .band-canvas { background-color: var(--color-canvas); }
  .band-soft { background-color: var(--color-canvas-soft); }

  .cp-body-text {
    color: var(--color-body);
    max-width: 68ch;
  }

  @media (max-width: 600px) {
    .band { padding: var(--space-4xl) 0; }
  }
</style>
