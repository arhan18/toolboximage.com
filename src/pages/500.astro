---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import Button from '../components/ui/Button.astro';
---

<Layout
  title="500 — Server Error — ToolBox Image"
  description="Something went wrong on our end. Please try again later."
  noIndex={true}
>
  <AppShell>
    <section class="error-page">
      <div class="container error-page-inner">
        <p class="text-caption-mono error-page-code">500</p>
        <h1 class="text-display-lg error-page-title">Server error</h1>
        <p class="text-body-md error-page-desc">
          Something went wrong on our end. Please try again later.
        </p>
        <div class="error-page-actions">
          <Button label="Go home" href="/" variant="primary" size="lg" />
          <Button label="Contact us" href="/contact/" variant="secondary" size="lg" />
        </div>
      </div>
    </section>
  </AppShell>
</Layout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 64px);
    padding: var(--space-4xl) 0;
  }

  .error-page-inner {
    text-align: center;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .error-page-code {
    color: var(--color-mute);
    font-size: var(--text-display-xl);
    line-height: 1;
    margin: 0;
  }

  .error-page-title {
    margin: 0;
  }

  .error-page-desc {
    color: var(--color-body);
    margin: 0;
  }

  .error-page-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }
</style>
