---
import Layout from '../../layouts/Layout.astro';
import AppShell from '../../components/layout/AppShell.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Reveal from '../../components/shared/Reveal.astro';
import FAQ from '../../components/shared/FAQ.astro';
import SectionHeader from '../../components/shared/SectionHeader.astro';
import BlogIndexPage from '../../components/blog/BlogIndexPage.astro';
import BlogPostPage from '../../components/blog/BlogPostPage.astro';
import CompressorTool from '../../components/tools/CompressorTool.astro';
import RotatorTool from '../../components/tools/RotatorTool.astro';
import ConverterTool from '../../components/tools/ConverterTool.astro';
import ResizerTool from '../../components/tools/ResizerTool.astro';
import ToolSeoContent from '../../components/seo/ToolSeoContent.astro';
import CompressorSeoContent from '../../components/seo/CompressorSeoContent.astro';
import { tools } from '../../lib/tools';
import { useTranslations, LANG_CODES, type LangCode, dirFromLang } from '../../i18n';
import { getPost } from '../../lib/blog';

export async function getStaticPaths() {
  const langs = LANG_CODES.filter((l) => l !== 'en');
  const slugs = [
    'compressor', 'bulk-image-compressor', 'image-compressor-100kb',
    'image-compressor-for-discord', 'compress-for-email',
    'compress-jpeg', 'compress-png', 'compress-webp', 'compress-avif',
    'compress-for-instagram', 'compress-for-whatsapp',
    'compress-gif', 'compress-for-web', 'compress-for-ecommerce',
    'image-compressor', 'jpeg-vs-png-compression',
    'image-tools', 'blog', 'blog/heic-to-jpg-guide',
    'blog/social-media-image-sizes', 'blog/image-compression-ecommerce',
    'blog/privacy-first-image-tools', 'blog/optimize-images-wordpress',
    'blog/remove-exif-data-online',     'blog/webp-vs-avif-comparison',
    'blog/reduce-image-size-without-losing-quality', 'blog/why-client-side',
    'blog/how-to-convert-images-online', 'blog/how-to-resize-images-for-social-media',
    'blog/image-compression-basics', 'blog/designing-the-compressor',
    'blog/introducing-toolboximage', 'blog/choose-image-format',
    'blog/batch-compression-guide', 'blog/image-size-limits-social-email',
    'blog/compress-to-exact-file-size', 'blog/png-vs-webp-vs-avif',
    'faq', 'about', 'contact', 'support', 'troubleshooting',
    'legal/privacy', 'legal/terms',
    'tools/rotator', 'tools/converter', 'tools/resizer',
    'tools/cropper', 'tools/flipper', 'tools/heic-converter',
    'tools/background-remover', 'tools/blur', 'tools/format-viewer', 'tools/metadata', 'tools/watermark-remover',
  ];
  const paths: { params: { lang: string; slug: string } }[] = [];
  for (const lang of langs) {
    for (const slug of slugs) {
      paths.push({ params: { lang, slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const langCode: LangCode = (lang as LangCode) || 'en';
const _ = useTranslations(langCode);
const isEn = langCode === 'en';

function titleCase(s: string): string {
  return s.split(/[-/]/).map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

function pageTitle(slug: string): string {
  const parts = slug.split('/');
  const last = parts[parts.length - 1];
  const map: Record<string, string> = {
    compressor: _('nav.compressor'),
    'bulk-image-compressor': _('tools.bulk'),
    'image-compressor-100kb': _('tools.target'),
    'image-compressor-for-discord': _('tools.discord'),
    'compress-for-email': _('tools.email'),
    'compress-jpeg': _('nav.compressJpeg'),
    'compress-png': _('nav.compressPng'),
    'compress-webp': _('nav.compressWebp'),
    'compress-avif': _('nav.compressAvif'),
    'compress-for-instagram': _('tools.instagram'),
    'compress-for-whatsapp': _('tools.whatsapp'),
    'compress-gif': 'Compress GIF',
    'compress-for-web': 'Web Image Optimizer',
    'compress-for-ecommerce': 'Ecommerce Compressor',
    'image-compressor': 'Image Compressor',
    'jpeg-vs-png-compression': 'JPEG vs PNG Comparison',
    'image-tools': _('nav.allTools'),
    blog: _('nav.blog'),
    faq: _('nav.faq'),
    about: _('nav.about'),
    contact: _('nav.contact'),
    support: _('footer.support'),
    troubleshooting: _('nav.troubleshooting'),
    'legal/privacy': _('footer.privacy'),
    'legal/terms': _('footer.terms'),
    rotator: 'Rotate Image',
    converter: 'Format Converter',
    resizer: 'Image Resizer',
    cropper: 'Image Cropper',
    flipper: 'Image Flipper',
    'heic-converter': 'HEIC to JPEG',
    'background-remover': 'Background Remover',
    blur: 'Blur Image',
    'format-viewer': 'Format Viewer',
    metadata: 'Metadata Viewer',
  };
  return map[slug] || map[last] || titleCase(last);
}

function pageDesc(slug: string): string {
  const map: Record<string, string> = {
    compressor: _('tools.compressorDesc'),
    faq: _('page.desc.faq'),
    about: _('page.desc.about'),
    contact: _('page.desc.contact'),
    troubleshooting: _('page.desc.troubleshooting'),
  };
  return map[slug] || `ToolBox Image — ${pageTitle(slug)}`;
}

const compressTools = [
  { href: '/compressor/', label: 'Image Compressor', desc: 'Compress any image format in your browser.' },
  { href: '/bulk-image-compressor/', label: 'Bulk Compressor', desc: 'Batch compress hundreds of images.' },
  { href: '/image-compressor-100kb/', label: 'Compress to 100KB', desc: 'Hit exact file size targets.' },
  { href: '/image-compressor-for-discord/', label: 'Discord Compressor', desc: 'Compress for Discord limits.' },
  { href: '/compress-for-email/', label: 'Email Compressor', desc: 'Compress for email attachments.' },
  { href: '/compress-for-whatsapp/', label: 'WhatsApp Compressor', desc: 'Optimize images for WhatsApp.' },
  { href: '/compress-for-instagram/', label: 'Instagram Compressor', desc: 'Resize and compress for Instagram.' },
  { href: '/jpeg-vs-png-compression/', label: 'JPEG vs PNG', desc: 'Compare image formats.' },
];
function getAllTools(_lang: string) {
  const dynamic = tools.filter((t) => t.id !== 'compressor').map((t) => ({
    href: t.path, label: t.name, desc: t.description, icon: t.icon,
    status: t.status === 'live' ? 'Live' as const : 'Soon' as const,
  }));
  return [...compressTools, ...dynamic];
}
function getToolsByCategory(cat: string, _lang: string) {
  return tools.filter((t) => t.id !== 'compressor' && t.category === cat).map((t) => ({
    href: t.path, label: t.name, desc: t.description,
    status: t.status === 'live' ? 'Live' as const : 'Soon' as const,
  }));
}

const isCompressorPage = slug === 'compressor' || slug === 'bulk-image-compressor' || slug === 'image-compressor-100kb' || slug === 'image-compressor-for-discord' || slug === 'compress-for-email' || slug === 'compress-jpeg' || slug === 'compress-png' || slug === 'compress-webp' || slug === 'compress-avif' || slug === 'compress-for-instagram' || slug === 'compress-for-whatsapp' || slug === 'compress-gif' || slug === 'compress-for-web' || slug === 'compress-for-ecommerce';
const isRotatorPage = slug === 'tools/rotator';
const isConverterPage = slug === 'tools/converter';
const isResizerPage = slug === 'tools/resizer';
const isLiveTool = isCompressorPage || isRotatorPage || isConverterPage || isResizerPage;
const isBlogSlug = slug?.startsWith('blog/');
const isBlogIndex = slug === 'blog';
const isFaq = slug === 'faq';

const faqItems = [
  { q: _('faq.q1'), a: _('faq.a1') },
  { q: _('faq.q2'), a: _('faq.a2') },
  { q: _('faq.q3'), a: _('faq.a3') },
  { q: _('faq.q4'), a: _('faq.a4') },
  { q: _('faq.q5'), a: _('faq.a5') },
  { q: _('faq.q6'), a: _('faq.a6') },
];
---

<Layout
  title={`${pageTitle(slug || '')} | ToolBox Image`}
  description={pageDesc(slug || '')}
  lang={langCode}
  dir={dirFromLang(langCode)}
  ogImage="/og-image.png"
  ogType="website"
>
  <AppShell>
    {isFaq ? (
      <section class="band band-canvas" id="faq-page">
        <div class="container faq-container stack stack-3xl" style="padding-top: var(--space-5xl);">
          <SectionHeader eyebrow={_('faq.title')} leadMaxWidth="560px">
            <h2 class="text-display-lg">{_('faq.title')}</h2>
          </SectionHeader>
          <FAQ items={faqItems} />
        </div>
      </section>
    ) : slug === 'about' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 720px; margin: 0 auto;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{_('nav.about')}</h1>
          <p class="text-body-lg" style="color: var(--color-body); line-height: 1.7;">
            {_('page.about.text')}
          </p>
          <div class="cta-actions" style="margin-top: var(--space-xl)">
            <Button label={_('hero.cta')} href="/compressor/" variant="primary" size="lg" />
          </div>
        </div>
      </section>
    ) : slug === 'contact' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 640px;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{_('nav.contact')}</h1>
          <p class="text-body-lg" style="color: var(--color-body);">
            {_('page.contact.text')}
          </p>
          <p class="text-display-sm" style="margin-top: var(--space-md);">
            <a href="mailto:toolboximageofficial@gmail.com" style="color: var(--color-link);">toolboximageofficial@gmail.com</a>
          </p>
        </div>
      </section>
    ) : slug === 'support' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 640px;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{_('footer.support')}</h1>
          <p class="text-body-lg" style="color: var(--color-body);">
            {_('page.support.text')}
          </p>
          <div style="margin-top: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm);">
            <a href="https://paypal.me/arhanahmadkhan" class="text-body-lg" style="color: var(--color-link);">PayPal.Me/arhanahmadkhan</a>
            <p class="text-body-sm" style="color: var(--color-body);">UPI: 8115033956@ptyes</p>
          </div>
        </div>
      </section>
    ) : slug === 'troubleshooting' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 720px; margin: 0 auto;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{_('nav.troubleshooting')}</h1>
          <p class="text-body-lg" style="color: var(--color-body); line-height: 1.7;">
            {_('troubleshooting.text')}
          </p>
          <div class="troubleshooting-issues" style="margin-top: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-lg);">
            {['format', 'corrupt', 'large', 'download', 'browser', 'quality'].map((key, i) => (
              <details class="troubleshooting-item">
                <summary class="troubleshooting-question text-body-md-strong" style="cursor: pointer; color: var(--color-ink);">
                  {_(`troubleshooting.${key}.title`)}
                </summary>
                <p class="text-body-sm" style="color: var(--color-body); margin-top: var(--space-sm); padding-left: var(--space-lg);">
                  {_(`troubleshooting.${key}.text`)}
                </p>
              </details>
            ))}
          </div>
          <div class="cta-actions" style="margin-top: var(--space-xl)">
            <Button label={_('nav.contact')} href={`/${lang}/contact/`} variant="primary" size="lg" />
          </div>
        </div>
      </section>
    ) : slug === 'legal/privacy' || slug === 'legal/terms' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 720px;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{pageTitle(slug || '')}</h1>
          <p class="text-body-lg" style="color: var(--color-body);">
            {_('page.legal.available')}
          </p>
          <a href={`/${slug}`} class="text-body-lg" style="color: var(--color-link); display: inline-block; margin-top: var(--space-md);">
            {_('page.legal.cta')} →
          </a>
        </div>
      </section>
    ) : isBlogIndex ? (
      <BlogIndexPage lang={langCode} />
    ) : isBlogSlug ? (
      (() => {
        const slugPart = slug!.replace('blog/', '');
        const post = getPost(slugPart);
        if (!post) {
          return <section class="band band-canvas">
            <div class="container" style="padding-top: var(--space-5xl); max-width: 640px; text-align: center;">
              <h1 class="text-display-lg" style="margin-bottom: var(--space-md);">{_('page.blog.title')}</h1>
              <p class="text-body-lg" style="color: var(--color-body);">{_('page.other.available')}</p>
              <Button label={_('page.other.cta')} href={`/blog/${slugPart}/`} variant="primary" size="lg" />
            </div>
          </section>;
        }
        return <BlogPostPage post={post} lang={langCode} />;
      })()
    ) : slug === 'image-tools' ? (
      <section class="band hero-band">
        <div class="container stack stack-lg">
          <Reveal>
            <Badge eyebrow="ToolBox Image" tone="info">{_('page.imageTools.title')}</Badge>
          </Reveal>
          <Reveal delay={80}>
            <h1 class="text-display-xl page-title">{_('page.imageTools.title')}</h1>
          </Reveal>
          <Reveal delay={160}>
            <p class="text-body-lg page-lead">{_('page.imageTools.desc')}</p>
          </Reveal>
        </div>
      </section>
      <section class="band band-canvas">
        <div class="container stack stack-3xl">
          <nav class="tabs" role="tablist" aria-label="Tool categories">
            {['all', 'compress', 'transform', 'convert', 'analyze'].map((cat) => (
              <button type="button" class="tab" role="tab" aria-selected={cat === 'all'} data-tab={cat}>
                {cat.charAt(0).toUpperCase() + cat.slice(1)}
              </button>
            ))}
          </nav>
          <div class="tab-panel" data-panel="all">
            <div class="tools-grid">
              {getAllTools(langCode).map((tool, i) => (
                <Reveal delay={i * 30}>
                  <a href={tool.href} class:list={['tool-card', tool.status === 'Soon' && 'tool-card-coming']}>
                    <Badge eyebrow={tool.status === 'Live' ? 'Free' : _('tools.soon')} tone={tool.status === 'Live' ? 'info' : 'warning'}>{tool.label}</Badge>
                    <p class="text-body-sm tool-desc">{tool.desc}</p>
                  </a>
                </Reveal>
              ))}
            </div>
          </div>
          {['compress', 'transform', 'convert', 'analyze'].map((cat) => (
            <div class="tab-panel" data-panel={cat} hidden>
              <div class="tools-grid">
                {getToolsByCategory(cat, langCode).map((tool, i) => (
                  <Reveal delay={i * 30}>
                    <a href={tool.href} class:list={['tool-card', tool.status === 'Soon' && 'tool-card-coming']}>
                      <Badge eyebrow={tool.status === 'Live' ? 'Free' : _('tools.soon')} tone={tool.status === 'Live' ? 'info' : 'warning'}>{tool.label}</Badge>
                      <p class="text-body-sm tool-desc">{tool.desc}</p>
                    </a>
                  </Reveal>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    ) : isLiveTool ? (
      isCompressorPage ? <><CompressorTool lang={langCode} /><CompressorSeoContent variant={slug} lang={langCode} /></> : isRotatorPage ? <RotatorTool lang={langCode} /> : isConverterPage ? <><ConverterTool lang={langCode} /><ToolSeoContent toolId="converter" lang={langCode} /></> : isResizerPage ? <><ResizerTool lang={langCode} /><ToolSeoContent toolId="resizer" lang={langCode} /></> : null
    ) : (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 640px; text-align: center;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-md);">{pageTitle(slug || '')}</h1>
          <p class="text-body-lg" style="color: var(--color-body); margin-bottom: var(--space-lg);">
            {_('page.other.available')}
          </p>
          <Button label={_('page.other.cta')} href={`/${slug}`} variant="primary" size="lg" />
        </div>
      </section>
    )}
  </AppShell>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.tab;
      tabs.forEach((t) => t.ariaSelected = String(t.dataset.tab === id));
      panels.forEach((p) => p.hidden = p.dataset.panel !== id);
    });
  });
</script>

<style>
  .faq-container { max-width: 760px; margin: 0 auto; }
  .band { position: relative; padding: var(--space-5xl) 0; }
  .band-canvas { background-color: var(--color-canvas); }
  .cta-actions { display: flex; gap: var(--space-sm); flex-wrap: wrap; }

  .hero-band {
    padding: calc(var(--space-6xl) + var(--space-2xl)) 0 var(--space-lg);
    background-color: var(--color-canvas);
  }
  .page-title { margin: 0; max-width: 16ch; }
  .page-lead { margin: 0; color: var(--color-body); max-width: 56ch; }

  .tabs {
    display: flex; gap: 2px; padding: 4px;
    background-color: var(--color-canvas-soft);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-hairline);
    width: fit-content; overflow-x: auto;
  }
  .tab {
    padding: var(--space-xs) var(--space-lg); border: none;
    border-radius: var(--radius-md); background: transparent;
    color: var(--color-body); font-size: var(--text-body-sm);
    font-weight: var(--weight-medium); cursor: pointer; white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tab:hover {
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-ink) 5%, transparent);
  }
  .tab[aria-selected="true"] {
    background: var(--color-canvas); color: var(--color-ink);
    box-shadow: var(--shadow-1);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  .tool-card {
    display: flex; flex-direction: column; gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md); text-decoration: none;
    transition: transform var(--dur-base) var(--ease-out-quart), box-shadow var(--dur-base) var(--ease-out-quart), border-color var(--dur-base) var(--ease-out-quart);
  }
  .tool-card:hover {
    transform: translateY(-2px); box-shadow: var(--shadow-2);
    border-color: var(--color-hairline-strong);
  }
  .tool-card-coming { opacity: 0.7; }
  .tool-card-coming:hover { opacity: 1; }
  .tool-desc { margin: 0; color: var(--color-body); }

  @media (max-width: 1023px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .hero-band { padding: var(--space-4xl) 0 var(--space-md); }
    .band { padding: var(--space-4xl) 0; }
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>
