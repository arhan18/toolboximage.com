---
import Layout from '../../layouts/Layout.astro';
import AppShell from '../../components/layout/AppShell.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Reveal from '../../components/shared/Reveal.astro';
import FAQ from '../../components/shared/FAQ.astro';
import SectionHeader from '../../components/shared/SectionHeader.astro';
import BlogIndexPage from '../../components/blog/BlogIndexPage.astro';
import BlogPostPage from '../../components/blog/BlogPostPage.astro';
import CompressorTool from '../../components/tools/CompressorTool.astro';
import RotatorTool from '../../components/tools/RotatorTool.astro';
import ConverterTool from '../../components/tools/ConverterTool.astro';
import ResizerTool from '../../components/tools/ResizerTool.astro';
import CropperTool from '../../components/tools/CropperTool.astro';
import WatermarkTool from '../../components/tools/WatermarkTool.astro';
import MetadataTool from '../../components/tools/MetadataTool.astro';
import PassportTool from '../../components/tools/PassportTool.astro';
import HeicConverterTool from '../../components/tools/HeicConverterTool.astro';
import SignatureTool from '../../components/tools/SignatureTool.astro';
import ToolSeoContent from '../../components/seo/ToolSeoContent.astro';
import CompressorSeoContent from '../../components/seo/CompressorSeoContent.astro';
import { tools } from '../../lib/tools';
import { softwareAppSchema, breadcrumbSchema, faqSchema, articleSchema } from '../../lib/seo';
import { useTranslations, LANG_CODES, type LangCode, dirFromLang } from '../../i18n';
import { getPost, getTranslatedTitle, getTranslatedDescription, getTranslatedTags } from '../../lib/blog';
import { getAllTools, getCompressTools, getToolsByCategory } from '../../lib/tools-dir';

export async function getStaticPaths() {
  const langs = LANG_CODES.filter((l) => l !== 'en');
  const slugs = [
    'compressor', 'bulk-image-compressor', 'image-compressor-100kb',
    'image-compressor-for-discord', 'compress-for-email',
    'compress-jpeg', 'compress-png', 'compress-webp', 'compress-avif',
    'compress-for-instagram', 'compress-for-whatsapp',
    'compress-gif', 'compress-for-web', 'compress-for-ecommerce',
    'image-compressor', 'jpeg-vs-png-compression',
    'image-tools', 'blog', 'blog/heic-to-jpg-guide',
    'blog/social-media-image-sizes', 'blog/image-compression-ecommerce',
    'blog/privacy-first-image-tools', 'blog/optimize-images-wordpress',
    'blog/remove-exif-data-online',     'blog/webp-vs-avif-comparison',
    'blog/reduce-image-size-without-losing-quality', 'blog/why-client-side',
    'blog/how-to-convert-images-online', 'blog/how-to-resize-images-for-social-media',
    'blog/image-compression-basics', 'blog/designing-the-compressor',
    'blog/introducing-toolboximage', 'blog/choose-image-format',
    'blog/batch-compression-guide', 'blog/image-size-limits-social-email',
    'blog/compress-to-exact-file-size', 'blog/png-vs-webp-vs-avif', 'blog/crop-image-online',
    'faq', 'about', 'contact', 'support', 'troubleshooting',
    'legal/privacy', 'legal/terms',
    'tools/rotator', 'tools/converter', 'tools/resizer',
    'tools/cropper', 'tools/watermark', 'tools/passport', 'tools/flipper', 'tools/heic-converter', 'tools/signature',
    'tools/background-remover', 'tools/blur', 'tools/format-viewer', 'tools/metadata', 'tools/watermark-remover',
  ];
  const paths: { params: { lang: string; slug: string } }[] = [];
  for (const lang of langs) {
    for (const slug of slugs) {
      paths.push({ params: { lang, slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const langCode: LangCode = (lang as LangCode) || 'en';
const _ = useTranslations(langCode);
const isEn = langCode === 'en';

function titleCase(s: string): string {
  return s.split(/[-/]/).map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

function pageTitle(slug: string): string {
  const parts = slug.split('/');
  const last = parts[parts.length - 1];
  const map: Record<string, string> = {
    compressor: _('nav.compressor'),
    'bulk-image-compressor': _('tools.bulk'),
    'image-compressor-100kb': _('tools.target'),
    'image-compressor-for-discord': _('tools.discord'),
    'compress-for-email': _('tools.email'),
    'compress-jpeg': _('nav.compressJpeg'),
    'compress-png': _('nav.compressPng'),
    'compress-webp': _('nav.compressWebp'),
    'compress-avif': _('nav.compressAvif'),
    'compress-for-instagram': _('tools.instagram'),
    'compress-for-whatsapp': _('tools.whatsapp'),
    'compress-gif': _('tools.compressGif'),
    'compress-for-web': _('tools.compressForWeb'),
    'compress-for-ecommerce': _('tools.compressForEcommerce'),
    'image-compressor': _('tools.imageCompressor'),
    'jpeg-vs-png-compression': _('tools.jpegVsPng'),
    'image-tools': _('nav.allTools'),
    blog: _('nav.blog'),
    faq: _('nav.faq'),
    about: _('nav.about'),
    contact: _('nav.contact'),
    support: _('footer.support'),
    troubleshooting: _('nav.troubleshooting'),
    'legal/privacy': _('footer.privacy'),
    'legal/terms': _('footer.terms'),
    rotator: _('tools.rotator'),
    converter: _('tools.converter'),
    resizer: _('tools.resizer'),
    cropper: _('tools.cropper'),
    flipper: _('tools.flipper'),
    'heic-converter': _('tools.heicConverter'),
    'background-remover': _('tools.backgroundRemover'),
    blur: _('tools.blur'),
    'format-viewer': _('tools.formatViewer'),
    metadata: _('tools.metadata'),
    passport: _('tools.passport'),
  };
  return map[slug] || map[last] || titleCase(last);
}

function pageDesc(slug: string): string {
  const slugToKey: Record<string, string> = {
    compressor: 'tools.compressorDesc',
    'image-tools': 'page.desc.imageTools',
    'bulk-image-compressor': 'tools.bulkDesc',
    'image-compressor-100kb': 'tools.targetDesc',
    'image-compressor-for-discord': 'tools.discordDesc',
    'compress-for-email': 'tools.emailDesc',
    'compress-for-whatsapp': 'tools.whatsappDesc',
    'compress-for-instagram': 'tools.instagramDesc',
    'compress-jpeg': 'tools.jpegDesc',
    'compress-png': 'tools.pngDesc',
    'compress-webp': 'tools.webpDesc',
    'compress-avif': 'tools.avifDesc',
    'compress-gif': 'tools.compressGifDesc',
    'compress-for-web': 'tools.compressForWebDesc',
    'compress-for-ecommerce': 'tools.compressForEcommerceDesc',
    'image-compressor': 'tools.imageCompressorDesc',
    rotator: 'page.desc.rotator',
    converter: 'page.desc.converter',
    resizer: 'page.desc.resizer',
    cropper: 'page.desc.cropper',
    passport: 'page.desc.passport',
    'tools/heic-converter': 'page.desc.heicConverter',
    'tools/signature': 'page.desc.signature',
    support: 'page.desc.support',
    faq: 'page.desc.faq',
    about: 'page.desc.about',
    contact: 'page.desc.contact',
    troubleshooting: 'page.desc.troubleshooting',
  };
  const key = slugToKey[slug];
  if (key) return _(key);
  const legalMap: Record<string, string> = {
    'legal/privacy': 'page.desc.privacy',
    'legal/terms': 'page.desc.terms',
  };
  if (legalMap[slug]) return _(legalMap[slug]);
  return `ToolBox Image — ${pageTitle(slug)}`;
}

const compressTools = [
  { href: '/compressor/', label: _('tools.compressor'), desc: _('tools.compressorDesc') },
  { href: '/bulk-image-compressor/', label: _('tools.bulk'), desc: _('tools.bulkDesc') },
  { href: '/image-compressor-100kb/', label: _('tools.target'), desc: _('tools.targetDesc') },
  { href: '/image-compressor-for-discord/', label: _('tools.discord'), desc: _('tools.discordDesc') },
  { href: '/compress-for-email/', label: _('tools.email'), desc: _('tools.emailDesc') },
  { href: '/compress-for-whatsapp/', label: _('tools.whatsapp'), desc: _('tools.whatsappDesc') },
  { href: '/compress-for-instagram/', label: _('tools.instagram'), desc: _('tools.instagramDesc') },
  { href: '/compress-jpeg/', label: _('nav.compressJpeg'), desc: _('tools.jpegDesc') },
  { href: '/compress-png/', label: _('nav.compressPng'), desc: _('tools.pngDesc') },
  { href: '/compress-webp/', label: _('nav.compressWebp'), desc: _('tools.webpDesc') },
  { href: '/compress-avif/', label: _('nav.compressAvif'), desc: _('tools.avifDesc') },
  { href: '/compress-gif/', label: _('tools.compressGif'), desc: _('tools.compressGifDesc') },
  { href: '/compress-for-web/', label: _('tools.compressForWeb'), desc: _('tools.compressForWebDesc') },
  { href: '/compress-for-ecommerce/', label: _('tools.compressForEcommerce'), desc: _('tools.compressForEcommerceDesc') },
  { href: '/image-compressor/', label: _('tools.imageCompressor'), desc: _('tools.imageCompressorDesc') },
];
const toolKeyFromId: Record<string, string> = {
  converter: 'tools.converter', resizer: 'tools.resizer', cropper: 'tools.cropper', rotator: 'tools.rotator',
  watermark: 'tools.watermark', flipper: 'tools.flipper', 'heic-converter': 'tools.heicConverter', 'background-remover': 'tools.backgroundRemover',
  blur: 'tools.blur', 'format-viewer': 'tools.formatViewer', metadata: 'tools.metadata', 'watermark-remover': 'tools.watermarkRemover',
  passport: 'tools.passport',
  signature: 'tools.signature',
};
const toolDescFromId: Record<string, string> = {
  converter: 'tools.converterDesc', resizer: 'tools.resizerDesc', cropper: 'tools.cropperDesc', rotator: 'tools.rotatorDesc',
  watermark: 'tools.watermarkDesc', flipper: 'tools.flipperDesc', 'heic-converter': 'tools.heicConverterDesc', 'background-remover': 'tools.backgroundRemoverDesc',
  blur: 'tools.blurDesc', 'format-viewer': 'tools.formatViewerDesc', metadata: 'tools.metadataDesc', 'watermark-remover': 'tools.watermarkRemoverDesc',
  passport: 'tools.passportDesc',
  signature: 'tools.signatureDesc',
};
const getName = (id: string) => _(toolKeyFromId[id] || `tools.${id}`);
const getDesc = (id: string) => _(toolDescFromId[id] || `${toolKeyFromId[id] || `tools.${id}`}Desc`);

const isCompressorPage = slug === 'compressor' || slug === 'bulk-image-compressor' || slug === 'image-compressor-100kb' || slug === 'image-compressor-for-discord' || slug === 'compress-for-email' || slug === 'compress-jpeg' || slug === 'compress-png' || slug === 'compress-webp' || slug === 'compress-avif' || slug === 'compress-for-instagram' || slug === 'compress-for-whatsapp' || slug === 'compress-gif' || slug === 'compress-for-web' || slug === 'compress-for-ecommerce' || slug === 'image-compressor';
const isRotatorPage = slug === 'tools/rotator';
const isConverterPage = slug === 'tools/converter';
const isResizerPage = slug === 'tools/resizer';
const isCropperPage = slug === 'tools/cropper';
const isWatermarkPage = slug === 'tools/watermark';
const isMetadataPage = slug === 'tools/metadata';
const isPassportPage = slug === 'tools/passport';
const isHeicConverterPage = slug === 'tools/heic-converter';
const isSignaturePage = slug === 'tools/signature';
const isLiveTool = isCompressorPage || isRotatorPage || isConverterPage || isResizerPage || isCropperPage || isWatermarkPage || isMetadataPage || isPassportPage || isHeicConverterPage || isSignaturePage;
const isBlogSlug = slug?.startsWith('blog/');
const isBlogIndex = slug === 'blog';
const isFaq = slug === 'faq';
const nonLiveToolSlugs = ['tools/flipper', 'tools/background-remover', 'tools/blur', 'tools/format-viewer', 'tools/watermark-remover'];
const isNonLiveTool = nonLiveToolSlugs.includes(slug);
const isLegalStub = slug === 'legal/privacy' || slug === 'legal/terms';

const imageToolsBreadcrumbs = [
  { name: 'Home', href: `/${lang === 'en' ? '' : lang + '/'}` },
  { name: _('page.imageTools.title'), href: `/${lang === 'en' ? '' : lang + '/'}image-tools/` },
];

const faqBreadcrumbs = [
  { name: 'Home', href: `/${lang === 'en' ? '' : lang + '/'}` },
  { name: _('nav.faq'), href: `/${lang === 'en' ? '' : lang + '/'}faq/` },
];

const ogImageMap: Record<string, string> = {
  compressor: '/og-image-compressor.png',
  'bulk-image-compressor': '/og-bulk-compressor.png',
  'image-compressor-100kb': '/og-100kb-compressor.png',
  'image-compressor-for-discord': '/og-discord-compressor.png',
  'compress-jpeg': '/og-compress-jpeg.png',
  'compress-png': '/og-compress-png.png',
  'compress-webp': '/og-compress-webp.png',
  'compress-avif': '/og-compress-avif.png',
  'compress-for-email': '/og-compress-email.png',
  'compress-for-whatsapp': '/og-compress-whatsapp.png',
  'compress-for-instagram': '/og-compress-instagram.png',
  'image-tools': '/og-image-tools.png',
  'tools/rotator': '/og-rotator.png',
  'tools/converter': '/og-converter.png',
  'tools/resizer': '/og-resizer.png',
  'tools/cropper': '/og-cropper.png',
  'tools/watermark': '/og-watermark.png',
  'tools/metadata': '/og-metadata.png',
  'tools/passport': '/og-passport.png',
  'image-compressor': '/og-image-compressor.png',
  'compress-gif': '/og-image.png',
  'compress-for-web': '/og-image.png',
  'compress-for-ecommerce': '/og-image.png',
};
const pageOgImage = ogImageMap[slug] || '/og-image.png';

const blogSlugPart = slug?.startsWith('blog/') ? slug.replace('blog/', '') : null;
const blogPost = blogSlugPart ? getPost(blogSlugPart) : null;
const blogTitle = blogPost ? getTranslatedTitle(blogPost.slug, langCode) : null;
const blogDesc = blogPost ? getTranslatedDescription(blogPost.slug, langCode) : null;
const blogTags = blogPost ? getTranslatedTags(blogPost.slug, langCode) : null;

const faqItems = [
  { q: _('faq.q1'), a: _('faq.a1') },
  { q: _('faq.q2'), a: _('faq.a2') },
  { q: _('faq.q3'), a: _('faq.a3') },
  { q: _('faq.q4'), a: _('faq.a4') },
  { q: _('faq.q5'), a: _('faq.a5') },
  { q: _('faq.q6'), a: _('faq.a6') },
  { q: _('faq.q7'), a: _('faq.a7') },
  { q: _('faq.q8'), a: _('faq.a8') },
];
---

<Layout
  title={blogTitle ? `${blogTitle} | ToolBox Image` : `${pageTitle(slug || '')} | ToolBox Image`}
  description={blogDesc ?? pageDesc(slug || '')}
  lang={langCode}
  dir={dirFromLang(langCode)}
  ogImage={pageOgImage}
  ogType={blogPost ? 'article' : 'website'}
  publishedTime={blogPost?.date}
  author={blogPost?.author}
  tags={blogTags ?? undefined}
  noIndex={isNonLiveTool || isLegalStub}
  schemas={blogPost ? [articleSchema({ slug: blogPost.slug, title: blogTitle!, description: blogDesc!, date: blogPost.date, author: blogPost.author }), breadcrumbSchema([{ name: 'Home', href: `/${lang === 'en' ? '' : lang + '/'}` }, { name: _('nav.blog'), href: `/${lang === 'en' ? '' : lang + '/'}blog/` }, { name: blogTitle!, href: `/${lang === 'en' ? '' : lang + '/'}${slug}/` }])] : slug === 'image-tools' ? [softwareAppSchema(), breadcrumbSchema(imageToolsBreadcrumbs)] : isFaq ? [faqSchema(faqItems), breadcrumbSchema(faqBreadcrumbs)] : undefined}
>
  <AppShell>
    {isFaq ? (
      <section class="band band-canvas" id="faq-page">
        <div class="container faq-container stack stack-3xl" style="padding-top: var(--space-5xl);">
          <SectionHeader eyebrow={_('faq.title')} leadMaxWidth="560px">
            <h2 class="text-display-lg">{_('faq.title')}</h2>
          </SectionHeader>
          <FAQ items={faqItems} />
        </div>
      </section>
    ) : slug === 'about' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 720px; margin: 0 auto;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{_('nav.about')}</h1>
          <p class="text-body-lg" style="color: var(--color-body); line-height: 1.7;">
            {_('page.about.text')}
          </p>
          <div class="cta-actions" style="margin-top: var(--space-xl)">
            <Button label={_('hero.cta')} href="/compressor/" variant="primary" size="lg" />
          </div>
        </div>
      </section>
    ) : slug === 'contact' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 640px;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{_('nav.contact')}</h1>
          <p class="text-body-lg" style="color: var(--color-body);">
            {_('page.contact.text')}
          </p>
          <p class="text-display-sm" style="margin-top: var(--space-md);">
            <a href="mailto:toolboximageofficial@gmail.com" style="color: var(--color-link);">toolboximageofficial@gmail.com</a>
          </p>
        </div>
      </section>
    ) : slug === 'support' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 640px;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{_('footer.support')}</h1>
          <p class="text-body-lg" style="color: var(--color-body);">
            {_('page.support.text')}
          </p>
          <div style="margin-top: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm);">
            <a href="https://paypal.me/arhanahmadkhan" class="text-body-lg" style="color: var(--color-link);">PayPal.Me/arhanahmadkhan</a>
            <p class="text-body-sm" style="color: var(--color-body);">UPI: 8115033956@ptyes</p>
          </div>
        </div>
      </section>
    ) : slug === 'troubleshooting' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 720px; margin: 0 auto;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{_('nav.troubleshooting')}</h1>
          <p class="text-body-lg" style="color: var(--color-body); line-height: 1.7;">
            {_('troubleshooting.text')}
          </p>
          <div class="troubleshooting-issues" style="margin-top: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-lg);">
            {['format', 'corrupt', 'large', 'download', 'browser', 'quality'].map((key, i) => (
              <details class="troubleshooting-item">
                <summary class="troubleshooting-question text-body-md-strong" style="cursor: pointer; color: var(--color-ink);">
                  {_(`troubleshooting.${key}.title`)}
                </summary>
                <p class="text-body-sm" style="color: var(--color-body); margin-top: var(--space-sm); padding-left: var(--space-lg);">
                  {_(`troubleshooting.${key}.text`)}
                </p>
              </details>
            ))}
          </div>
          <div class="cta-actions" style="margin-top: var(--space-xl)">
            <Button label={_('nav.contact')} href={`/${lang}/contact/`} variant="primary" size="lg" />
          </div>
        </div>
      </section>
    ) : slug === 'legal/privacy' || slug === 'legal/terms' ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 720px;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-lg);">{pageTitle(slug || '')}</h1>
          <p class="text-body-lg" style="color: var(--color-body);">
            {_('page.legal.available')}
          </p>
          <a href={`/${slug}`} class="text-body-lg" style="color: var(--color-link); display: inline-block; margin-top: var(--space-md);">
            {_('page.legal.cta')} →
          </a>
        </div>
      </section>
    ) : isBlogIndex ? (
      <BlogIndexPage lang={langCode} />
    ) : isBlogSlug ? (
      (() => {
        const slugPart = slug!.replace('blog/', '');
        const post = getPost(slugPart);
        if (!post) {
          return <section class="band band-canvas">
            <div class="container" style="padding-top: var(--space-5xl); max-width: 640px; text-align: center;">
              <h1 class="text-display-lg" style="margin-bottom: var(--space-md);">{_('page.blog.title')}</h1>
              <p class="text-body-lg" style="color: var(--color-body);">{_('page.other.available')}</p>
              <Button label={_('page.other.cta')} href={`/blog/${slugPart}/`} variant="primary" size="lg" />
            </div>
          </section>;
        }
        return <BlogPostPage post={post} lang={langCode} />;
      })()
    ) : slug === 'image-tools' ? (
      <section class="band hero-band">
        <div class="container stack stack-lg">
          <Reveal>
            <Badge eyebrow="ToolBox Image" tone="info">{_('page.imageTools.title')}</Badge>
          </Reveal>
          <Reveal delay={80}>
            <h1 class="text-display-xl page-title">{_('page.imageTools.title')}</h1>
          </Reveal>
          <Reveal delay={160}>
            <p class="text-body-lg page-lead">{_('page.imageTools.desc')}</p>
          </Reveal>
        </div>
      </section>
      <section class="band band-canvas">
        <div class="container stack stack-3xl">
          <nav class="tabs" role="tablist" aria-label="Tool categories">
            {['all', 'compress', 'transform', 'convert', 'analyze'].map((cat) => (
              <button type="button" class="tab" role="tab" aria-selected={cat === 'all'} data-tab={cat}>
                {_(`tabs.${cat}`)}
              </button>
            ))}
          </nav>
          <div class="tab-panel" data-panel="all">
            <div class="tools-grid">
              {getAllTools(compressTools, tools, getName, getDesc).map((tool, i) => (
                <Reveal delay={i * 30}>
                  <a href={tool.href} class:list={['tool-card', tool.status !== 'Live' && 'tool-card-coming']}>
                    <Badge eyebrow={tool.status === 'Live' ? 'Free' : tool.status === 'Planned' ? _('nav.planned') : _('tools.soon')} tone={tool.status === 'Live' ? 'info' : 'warning'}>{tool.label}</Badge>
                    <p class="text-body-sm tool-desc">{tool.desc}</p>
                  </a>
                </Reveal>
              ))}
            </div>
          </div>
          <div class="tab-panel" data-panel="compress" hidden>
            <div class="tools-grid">
              {getCompressTools(compressTools).map((tool, i) => (
                <Reveal delay={i * 30}>
                  <a href={tool.href} class="tool-card">
                    <Badge eyebrow="Free" tone="info">{tool.label}</Badge>
                    <p class="text-body-sm tool-desc">{tool.desc}</p>
                  </a>
                </Reveal>
              ))}
            </div>
          </div>
          {['transform', 'convert', 'analyze'].map((cat) => (
            <div class="tab-panel" data-panel={cat} hidden>
              <div class="tools-grid">
                {getToolsByCategory(cat, tools, getName, getDesc).map((tool, i) => (
                  <Reveal delay={i * 30}>
                    <a href={tool.href} class:list={['tool-card', tool.status !== 'Live' && 'tool-card-coming']}>
                      <Badge eyebrow={tool.status === 'Live' ? 'Free' : tool.status === 'Planned' ? _('nav.planned') : _('tools.soon')} tone={tool.status === 'Live' ? 'info' : 'warning'}>{tool.label}</Badge>
                      <p class="text-body-sm tool-desc">{tool.desc}</p>
                    </a>
                  </Reveal>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    ) : isLiveTool ? (
      isCompressorPage ? <><CompressorTool lang={langCode} /><CompressorSeoContent variant={slug} lang={langCode} /></> : isRotatorPage ? <><RotatorTool lang={langCode} /><ToolSeoContent toolId="rotator" lang={langCode} /></> : isConverterPage ? <><ConverterTool lang={langCode} /><ToolSeoContent toolId="converter" lang={langCode} /></> : isResizerPage ? <><ResizerTool lang={langCode} /><ToolSeoContent toolId="resizer" lang={langCode} /></> : isCropperPage ? <><CropperTool lang={langCode} /><ToolSeoContent toolId="cropper" lang={langCode} /></> : isWatermarkPage ? <><WatermarkTool lang={langCode} /><ToolSeoContent toolId="watermark" lang={langCode} /></> : isMetadataPage ? <><MetadataTool lang={langCode} /><ToolSeoContent toolId="metadata" lang={langCode} /></> : isPassportPage ? <><PassportTool lang={langCode} /><ToolSeoContent toolId="passport" lang={langCode} /></> : isHeicConverterPage ? <><HeicConverterTool lang={langCode} /><ToolSeoContent toolId="heic-converter" lang={langCode} /></> : isSignaturePage ? <><SignatureTool lang={langCode} /><ToolSeoContent toolId="signature" lang={langCode} /></> : null
    ) : isNonLiveTool ? (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 640px; text-align: center;">
          <Badge eyebrow="ToolBox Image" tone="warning">{_('tools.soon')}</Badge>
          <h1 class="text-display-lg" style="margin-bottom: var(--space-md);">{pageTitle(slug || '')}</h1>
          <p class="text-body-lg" style="color: var(--color-body);">{_('page.other.available')}</p>
          <div class="cta-actions" style="margin-top: var(--space-xl); display: flex; gap: var(--space-sm); justify-content: center;">
            <Button label={_('page.other.cta')} href={`/${slug}`} variant="primary" size="lg" />
          </div>
        </div>
      </section>
    ) : (
      <section class="band band-canvas">
        <div class="container" style="padding-top: var(--space-5xl); max-width: 640px; text-align: center;">
          <h1 class="text-display-lg" style="margin-bottom: var(--space-md);">{pageTitle(slug || '')}</h1>
          <p class="text-body-lg" style="color: var(--color-body); margin-bottom: var(--space-lg);">
            {_('page.other.available')}
          </p>
          <Button label={_('page.other.cta')} href={`/${slug}`} variant="primary" size="lg" />
        </div>
      </section>
    )}
  </AppShell>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.tab;
      tabs.forEach((t) => t.ariaSelected = String(t.dataset.tab === id));
      panels.forEach((p) => p.hidden = p.dataset.panel !== id);
    });
  });
</script>

