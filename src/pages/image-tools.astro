---
import Layout from '../layouts/Layout.astro';
import AppShell from '../components/layout/AppShell.astro';
import Reveal from '../components/shared/Reveal.astro';
import Breadcrumbs from '../components/shared/Breadcrumbs.astro';
import Badge from '../components/ui/Badge.astro';
import { breadcrumbSchema, softwareAppSchema } from '../lib/seo';
import { tools } from '../lib/tools';
import { getAllTools, getCompressTools, getToolsByCategory } from '../lib/tools-dir';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Image Tools', href: '/image-tools' },
];

interface ToolEntry {
  href: string;
  label: string;
  desc: string;
  status: string;
}

const compressTools: ToolEntry[] = [
  { href: '/compressor/', label: 'Image Compressor', desc: 'Compress any image format in your browser.', status: 'Live' },
  { href: '/bulk-image-compressor/', label: 'Bulk Compressor', desc: 'Batch compress hundreds of images.', status: 'Live' },
  { href: '/image-compressor-100kb/', label: 'Compress to 100KB', desc: 'Hit exact file size targets.', status: 'Live' },
  { href: '/image-compressor-for-discord/', label: 'Discord Compressor', desc: 'Compress for Discord limits.', status: 'Live' },
  { href: '/compress-for-email/', label: 'Email Compressor', desc: 'Compress for email attachments.', status: 'Live' },
  { href: '/compress-for-whatsapp/', label: 'WhatsApp Compressor', desc: 'Optimize images for WhatsApp.', status: 'Live' },
  { href: '/compress-for-instagram/', label: 'Instagram Compressor', desc: 'Resize and compress for Instagram.', status: 'Live' },
  { href: '/compress-jpeg/', label: 'JPEG Compressor', desc: 'Reduce JPEG file size.', status: 'Live' },
  { href: '/compress-png/', label: 'PNG Compressor', desc: 'Optimize PNG images.', status: 'Live' },
  { href: '/compress-webp/', label: 'WebP Compressor', desc: 'Make WebP files smaller.', status: 'Live' },
  { href: '/compress-avif/', label: 'AVIF Compressor', desc: 'Compress AVIF efficiently.', status: 'Live' },
  { href: '/compress-gif/', label: 'GIF Compressor', desc: 'Reduce animated and static GIF file sizes.', status: 'Live' },
  { href: '/compress-for-web/', label: 'Web Image Optimizer', desc: 'Optimize images for faster web performance.', status: 'Live' },
  { href: '/compress-for-ecommerce/', label: 'Ecommerce Compressor', desc: 'Compress product images for faster page loads.', status: 'Live' },
  { href: '/image-compressor/', label: 'Image Compressor', desc: 'Compress JPG, PNG, WebP, AVIF, and GIF in your browser.', status: 'Live' },
];

const categoryLabels: Record<string, string> = {
  transform: 'Transform',
  convert: 'Convert',
  analyze: 'Analyze',
};

const categories = ['all', 'compress', ...new Set(tools.filter((t) => t.id !== 'compressor').map((t) => t.category))];

const getName = (id: string) => tools.find((t) => t.id === id)?.name ?? id;
const getDesc = (id: string) => tools.find((t) => t.id === id)?.description ?? id;

const tabLabels: Record<string, string> = {
  all: 'All',
  compress: 'Compress',
  transform: 'Transform',
  convert: 'Convert',
  analyze: 'Analyze',
};
---

<Layout
  title="All Image Tools — Free Online Image Toolkit | ToolBox Image"
  description="Browse all free online image tools from ToolBox Image. Compress, resize, crop, convert, rotate, and optimize images entirely in your browser. No uploads, no sign-up."
  ogImage="/og-image-tools.png"
  schemas={[
    softwareAppSchema(),
    breadcrumbSchema(breadcrumbs),
  ]}
>
  <AppShell>
    <section class="band hero-band">
      <div class="container stack stack-lg">
        <Breadcrumbs items={breadcrumbs} />
        <Reveal>
          <Badge eyebrow="ToolBox Image" tone="info">Free image tools</Badge>
        </Reveal>
        <Reveal delay={80}>
          <h1 class="text-display-xl page-title">All image tools.</h1>
        </Reveal>
        <Reveal delay={160}>
          <p class="text-body-lg page-lead">
            Every tool we offer — compress, resize, crop, convert, rotate, and more.
            All run entirely in your browser. No uploads. No sign-up. No limits.
          </p>
        </Reveal>
      </div>
    </section>

    <section class="band band-canvas">
      <div class="container stack stack-3xl">
        <nav class="tabs" role="tablist" aria-label="Tool categories">
          {categories.map((cat) => (
            <button
              type="button"
              class="tab"
              role="tab"
              aria-selected={cat === 'all'}
              data-tab={cat}
            >
              {tabLabels[cat] ?? cat}
            </button>
          ))}
        </nav>

        <div class="tab-panel" data-panel="all">
          <div class="tools-grid">
            {getAllTools(compressTools, tools, getName, getDesc).map((tool, i) => (
              <Reveal delay={i * 30}>
                <a
                  href={tool.href}
                  class:list={['tool-card', tool.status !== 'Live' && 'tool-card-coming']}
                >
                  <Badge
                    eyebrow={tool.status === 'Live' ? 'Free' : tool.status === 'Planned' ? 'Planned' : 'Soon'}
                    tone={tool.status === 'Live' ? 'info' : 'warning'}
                  >
                    {tool.label}
                  </Badge>
                  <p class="text-body-sm tool-desc">{tool.desc}</p>
                </a>
              </Reveal>
            ))}
          </div>
        </div>

        <div class="tab-panel" data-panel="compress" hidden>
          <div class="tools-grid">
            {getCompressTools(compressTools).map((tool, i) => (
              <Reveal delay={i * 30}>
                <a href={tool.href} class="tool-card">
                  <Badge eyebrow="Free" tone="info">{tool.label}</Badge>
                  <p class="text-body-sm tool-desc">{tool.desc}</p>
                </a>
              </Reveal>
            ))}
          </div>
        </div>

        {['transform', 'convert', 'analyze'].map((cat) => (
          <div class="tab-panel" data-panel={cat} hidden>
            <div class="tools-grid">
              {getToolsByCategory(cat, tools, getName, getDesc).map((tool, i) => (
                <Reveal delay={i * 30}>
                  <a
                    href={tool.href}
                    class:list={['tool-card', tool.status !== 'Live' && 'tool-card-coming']}
                  >
                    <Badge
                      eyebrow={tool.status === 'Live' ? 'Free' : tool.status === 'Planned' ? 'Planned' : 'Soon'}
                      tone={tool.status === 'Live' ? 'info' : 'warning'}
                    >
                      {tool.label}
                    </Badge>
                    <p class="text-body-sm tool-desc">{tool.desc}</p>
                  </a>
                </Reveal>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="band cta-band">
      <div class="container cta-inner">
        <Reveal>
          <p class="text-caption-mono cta-eyebrow">Get started</p>
          <h2 class="text-display-xl cta-title">Ready to compress your first image?</h2>
          <p class="text-body-lg cta-sub">Free. Unlimited. Your files never leave your device.</p>
        </Reveal>
      </div>
    </section>
  </AppShell>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.tab;
      tabs.forEach((t) => t.ariaSelected = String(t.dataset.tab === id));
      panels.forEach((p) => p.hidden = p.dataset.panel !== id);
    });
  });
</script>

<style>
  .band {
    position: relative;
    padding: var(--space-5xl) 0;
  }

  .hero-band {
    padding: calc(var(--space-6xl) + var(--space-2xl)) 0 var(--space-lg);
    background-color: var(--color-canvas);
  }

  .band-canvas { background-color: var(--color-canvas); }

  .page-title { margin: 0; max-width: 16ch; }

  .page-lead {
    margin: 0;
    color: var(--color-body);
    max-width: 56ch;
  }

  .tabs {
    display: flex;
    gap: 2px;
    padding: 4px;
    background-color: var(--color-canvas-soft);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-hairline);
    width: fit-content;
    overflow-x: auto;
  }

  .tab {
    padding: var(--space-xs) var(--space-lg);
    border: none;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .tab:hover {
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-ink) 5%, transparent);
  }

  .tab[aria-selected="true"] {
    background: var(--color-canvas);
    color: var(--color-ink);
    box-shadow: var(--shadow-1);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: transform var(--dur-base) var(--ease-out-quart), box-shadow var(--dur-base) var(--ease-out-quart), border-color var(--dur-base) var(--ease-out-quart);
  }

  .tool-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-2);
    border-color: var(--color-hairline-strong);
  }

  .tool-card-coming { opacity: 0.7; }
  .tool-card-coming:hover { opacity: 1; }

  .tool-desc {
    margin: 0;
    color: var(--color-body);
  }

  .cta-band {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-eyebrow {
    color: color-mix(in srgb, var(--color-on-primary) 60%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .cta-title { margin: 0; color: var(--color-on-primary); }

  .cta-sub {
    margin: 0;
    color: color-mix(in srgb, var(--color-on-primary) 75%, transparent);
  }

  @media (max-width: 1023px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .hero-band { padding: var(--space-4xl) 0 var(--space-md); }
    .band { padding: var(--space-4xl) 0; }
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>
